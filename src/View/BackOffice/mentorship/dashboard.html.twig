{% extends 'BackOffice/mentorship/base_mentorship.html.twig' %}

{% block title %}Dashboard - Mentorship Admin{% endblock %}

{% block header_title %}Overview{% endblock %}

{% block body %}
{% block body %}
    <div class="dashboard-cards" style="margin-bottom: 40px; display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 25px;">
        <div class="card glass-card" style="position: relative; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); background: rgba(111, 86, 255, 0.05); backdrop-filter: blur(10px); padding: 25px;">
            <div style="position: absolute; top: -10px; right: -10px; font-size: 5rem; opacity: 0.1; color: var(--primary);">👤</div>
            <h3 style="font-size: 3rem; margin: 0; color: var(--primary-lighter); text-shadow: 0 0 20px rgba(111, 86, 255, 0.4);">{{ totalMentors }}</h3>
            <p style="text-transform: uppercase; font-size: 0.85rem; letter-spacing: 2px; color: #b0a8d6; margin-top: 5px; font-weight: 600;">Active Mentors</p>
            <div style="width: 40px; height: 3px; background: var(--primary); margin-top: 15px; border-radius: 2px;"></div>
        </div>
        
        <div class="card glass-card" style="position: relative; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); background: rgba(161, 139, 255, 0.05); backdrop-filter: blur(10px); padding: 25px;">
            <div style="position: absolute; top: -10px; right: -10px; font-size: 5rem; opacity: 0.1; color: #a18bff;">📅</div>
            <h3 style="font-size: 3rem; margin: 0; color: #a18bff; text-shadow: 0 0 20px rgba(161, 139, 255, 0.4);">{{ totalBookings }}</h3>
            <p style="text-transform: uppercase; font-size: 0.85rem; letter-spacing: 2px; color: #b0a8d6; margin-top: 5px; font-weight: 600;">Total Bookings</p>
            <div style="width: 40px; height: 3px; background: #a18bff; margin-top: 15px; border-radius: 2px;"></div>
        </div>

        <div class="card glass-card" style="position: relative; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); background: rgba(255, 139, 186, 0.05); backdrop-filter: blur(10px); padding: 25px;">
            <div style="position: absolute; top: -10px; right: -10px; font-size: 5rem; opacity: 0.1; color: #ff8bba;">🎥</div>
            <h3 style="font-size: 3rem; margin: 0; color: #ff8bba; text-shadow: 0 0 20px rgba(255, 139, 186, 0.4);">{{ totalSessions }}</h3>
            <p style="text-transform: uppercase; font-size: 0.85rem; letter-spacing: 2px; color: #b0a8d6; margin-top: 5px; font-weight: 600;">Video Sessions</p>
            <div style="width: 40px; height: 3px; background: #ff8bba; margin-top: 15px; border-radius: 2px;"></div>
        </div>
    </div>

    <div class="card" style="width: 100%; padding: 35px; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 15px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <h3 style="margin: 0; color: var(--text-main); font-weight: 600;">Latest Mentorship Activity</h3>
            <a href="{{ path('app_admin_mentorship_bookings') }}" style="color: var(--primary-light); text-decoration: none; font-size: 0.9rem; font-weight: 600;">View All Bookings &rarr;</a>
        </div>
        
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: separate; border-spacing: 0 10px; text-align: left;">
                <thead>
                    <tr>
                        <th style="padding: 15px; color: #6f56ff; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 1px; font-weight: 700;">Reference</th>
                        <th style="padding: 15px; color: #6f56ff; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 1px; font-weight: 700;">Topic / Purpose</th>
                        <th style="padding: 15px; color: #6f56ff; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 1px; font-weight: 700;">Status</th>
                        <th style="padding: 15px; color: #6f56ff; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 1px; font-weight: 700;">Timestamp</th>
                    </tr>
                </thead>
                <tbody>
                    {% for booking in latestBookings %}
                        <tr style="background: rgba(255,255,255,0.03); transition: all 0.3s;" onmouseover="this.style.background='rgba(111,86,255,0.08)'; this.style.transform='translateY(-2px)'" onmouseout="this.style.background='rgba(255,255,255,0.03)'; this.style.transform='translateY(0)'">
                            <td style="padding: 20px; border-radius: 10px 0 0 10px; font-family: monospace; color: var(--primary-light);">#{{ booking.bookingID }}</td>
                            <td style="padding: 20px; font-weight: 500; color: var(--text-main);">{{ booking.topic }}</td>
                            <td style="padding: 20px;">
                                {% set status = booking.status|lower %}
                                <span style="display: inline-block; padding: 6px 14px; border-radius: 20px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; 
                                {% if status == 'approved' %}background: rgba(46, 204, 113, 0.1); color: #2ecc71; box-shadow: 0 0 10px rgba(46, 204, 113, 0.2);
                                {% elseif status == 'rejected' or status == 'cancelled' %}background: rgba(231, 76, 60, 0.1); color: #e74c3c;
                                {% else %}background: rgba(241, 196, 15, 0.1); color: #f1c40f; box-shadow: 0 0 10px rgba(241, 196, 15, 0.2);{% endif %}">
                                    {{ booking.status }}
                                </span>
                            </td>
                            <td style="padding: 20px; border-radius: 0 10px 10px 0; color: #b0a8d6; font-size: 0.9rem;">
                                {{ booking.creationDate|date('M d, Y') }}
                                <span style="display: block; font-size: 0.75rem; opacity: 0.6;">{{ booking.creationDate|date('H:i') }}</span>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" style="padding: 40px; text-align: center; color: #b0a8d6; font-style: italic;">No recent bookings were found.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
