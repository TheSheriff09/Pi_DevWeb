{% extends 'BackOffice/mentorship/base_mentorship.html.twig' %}

{% block title %}Dashboard - Mentorship Admin{% endblock %}

{% block header_title %}Overview{% endblock %}

{% block body %}
    <div class="dashboard-cards" style="margin-bottom: 40px; display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px;">
        <div class="card">
            <h3 style="font-size: 2.5rem; color: var(--primary-lighter);">{{ totalMentors }}</h3>
            <p style="text-transform: uppercase; font-size: 0.9rem; letter-spacing: 1px; color: var(--text-main);">Total Mentors</p>
        </div>
        <div class="card">
            <h3 style="font-size: 2.5rem; color: #a18bff;">{{ totalBookings }}</h3>
            <p style="text-transform: uppercase; font-size: 0.9rem; letter-spacing: 1px; color: var(--text-main);">Total Bookings</p>
        </div>
        <div class="card">
            <h3 style="font-size: 2.5rem; color: #ff8bba;">{{ totalSessions }}</h3>
            <p style="text-transform: uppercase; font-size: 0.9rem; letter-spacing: 1px; color: var(--text-main);">Total Sessions</p>
        </div>
    </div>

    <div class="card" style="width: 100%; padding: 30px;">
        <h3 style="margin-bottom: 20px; color: var(--primary-lighter); text-align: left;">Latest Mentorship Bookings</h3>
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse; text-align: left;">
                <thead>
                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                        <th style="padding: 15px; color: #b0a8d6;">ID</th>
                        <th style="padding: 15px; color: #b0a8d6;">Topic</th>
                        <th style="padding: 15px; color: #b0a8d6;">Status</th>
                        <th style="padding: 15px; color: #b0a8d6;">Date Requested</th>
                    </tr>
                </thead>
                <tbody>
                    {% for booking in latestBookings %}
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                            <td style="padding: 15px;">#{{ booking.bookingID }}</td>
                            <td style="padding: 15px; font-weight: 500;">{{ booking.topic }}</td>
                            <td style="padding: 15px;">
                                <span style="display: inline-block; padding: 4px 10px; border-radius: 12px; font-size: 0.85em; font-weight: bold; background: rgba(0,0,0,0.1); 
                                {% if booking.status|lower == 'approved' %}color: #2ecc71;{% elseif booking.status|lower == 'rejected' %}color: #e74c3c;{% else %}color: #f1c40f;{% endif %}">
                                    {{ booking.status|upper }}
                                </span>
                            </td>
                            <td style="padding: 15px; color: #b0a8d6;">{{ booking.creationDate|date('Y-m-d H:i') }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" style="padding: 20px; text-align: center; color: #b0a8d6;">No bookings found yet.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
