{% extends 'BackOffice/mentorship/base_mentorship.html.twig' %}

{% block title %}Session Workspace - {{ session.topic|default('Mentorship') }}{% endblock %}

{% block header_title %}Workspace: {{ session.sessionType|default('Session') }} #{{ session.sessionID }}{% endblock %}

{% block body %}
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
        <div>
            <span style="padding: 6px 12px; border-radius: 6px; font-size: 13px; font-weight: bold; background: {% if session.status == 'Ongoing' %}#2ecc71{% elseif session.status == 'Completed' %}#95a5a6{% else %}#f39c12{% endif %}; color: white;">
                {{ session.status }}
            </span>
            <span style="color: #b0a8d6; margin-left: 15px;">Date: {{ session.sessionDate|date('M d, Y') }}</span>
        </div>
        
        {% if session.status == 'Ongoing' and session.meetingLink %}
            {# Assuming the user viewing this is one of them. For full dynamic UI, compare app.user.id with these, but skipping as we don't know the exact auth binding. The logic is handled since it's restricted in controller usually #}
            <div style="display: flex; gap: 15px;">
                <a href="{{ session.meetingLink }}" target="_blank" style="background: #e74c3c; color: white; padding: 10px 20px; border-radius: 8px; text-decoration: none; font-weight: bold; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(231, 76, 60, 0.4);">
                    🎥 Join Video Session
                </a>
                <button onclick="completeSession({{ session.sessionID }})" style="background: #2ecc71; color: white; border: none; padding: 10px 20px; border-radius: 8px; font-weight: bold; cursor: pointer; box-shadow: 0 4px 15px rgba(46, 204, 113, 0.4);">
                    ✓ Mark as Completed
                </button>
            </div>
        {% endif %}
    </div>

    <!-- Tabs Header -->
    <div style="display: flex; gap: 10px; border-bottom: 1px solid rgba(255,255,255,0.1); margin-bottom: 20px;">
        <button class="ws-tab active" onclick="showTab('info')" style="background: none; border: none; padding: 12px 20px; color: var(--primary-lighter); border-bottom: 2px solid var(--primary-accent); cursor: pointer; font-size: 16px;">Information</button>
        <button class="ws-tab" onclick="showTab('notes')" style="background: none; border: none; padding: 12px 20px; color: #888; cursor: pointer; font-size: 16px;">Notes</button>
        <button class="ws-tab" onclick="showTab('todos')" style="background: none; border: none; padding: 12px 20px; color: #888; cursor: pointer; font-size: 16px;">Todos</button>
        <button class="ws-tab" onclick="showTab('feedback')" style="background: none; border: none; padding: 12px 20px; color: #888; cursor: pointer; font-size: 16px;">Feedback</button>
    </div>

    <!-- Tabs Content -->
    <div id="tab-info" class="ws-content mentorship-card">
        <h3 style="margin-top: 0;">Participants</h3>
        <p style="color: #b0a8d6;">⭐ Mentor: <strong>{{ mentor ? mentor.fullName : 'N/A' }}</strong></p>
        <p style="color: #b0a8d6;">🚀 Entrepreneur: <strong>{{ entrepreneur ? entrepreneur.fullName : 'N/A' }}</strong></p>
        <p style="color: #b0a8d6; margin-top: 20px;"><strong>Meeting Link:</strong> {{ session.meetingLink ? session.meetingLink : 'Not generated yet.' }}</p>
    </div>

    <div id="tab-notes" class="ws-content mentorship-card" style="display: none;">
        <h3 style="margin-top: 0;">Session Notes</h3>
        {% for note in notes %}
            <div style="background: rgba(255,255,255,0.05); padding: 15px; border-radius: 8px; margin-bottom: 10px;">
                <p style="color: white; margin: 0;">{{ note.notes }}</p>
                <small style="color: #888;">Score: {{ note.satisfactionScore }} | Date: {{ note.noteDate|date('Y-m-d') }}</small>
            </div>
        {% else %}
            <p style="color: #888;">No notes added yet.</p>
        {% endfor %}
    </div>

    <div id="tab-todos" class="ws-content mentorship-card" style="display: none;">
        <h3 style="margin-top: 0;">Action Items</h3>
        {% for todo in todos %}
            <div style="display: flex; align-items: center; gap: 10px; background: rgba(255,255,255,0.05); padding: 12px; border-radius: 8px; margin-bottom: 10px;">
                <input type="checkbox" {% if todo.isDone %}checked{% endif %} disabled style="width: 18px; height: 18px;">
                <span style="color: white; {% if todo.isDone %}text-decoration: line-through; color: #888;{% endif %}">{{ todo.taskDescription }}</span>
            </div>
        {% else %}
            <p style="color: #888;">No action items assigned.</p>
        {% endfor %}
    </div>

    <div id="tab-feedback" class="ws-content mentorship-card" style="display: none;">
        <h3 style="margin-top: 0;">Feedback & Evaluation</h3>
        {% for feed in feedbacks %}
            <div style="background: rgba(255,255,255,0.05); padding: 15px; border-radius: 8px; margin-bottom: 10px;">
                <div style="display: flex; justify-content: space-between;">
                    <p style="color: #4cd137; margin: 0;"><strong>Strengths:</strong> {{ feed.strengths }}</p>
                    <span style="color: #f39c12; font-weight: bold;">Score: {{ feed.progressScore }}/10</span>
                </div>
                <p style="color: #e74c3c; margin: 5px 0 0 0;"><strong>Weaknesses:</strong> {{ feed.weaknesses }}</p>
            </div>
        {% else %}
            <p style="color: #888;">No feedback submitted yet.</p>
        {% endfor %}
    </div>

    <script>
        function showTab(tabName) {
            document.querySelectorAll('.ws-content').forEach(el => el.style.display = 'none');
            document.querySelectorAll('.ws-tab').forEach(btn => {
                btn.style.color = '#888';
                btn.style.borderBottom = 'none';
            });
            document.getElementById('tab-' + tabName).style.display = 'block';
            event.target.style.color = 'var(--primary-lighter)';
            event.target.style.borderBottom = '2px solid var(--primary-accent)';
        }

        function completeSession(id) {
            if(confirm("Are you sure you want to mark this session as completed?")) {
                fetch('{{ path('app_advanced_complete', {'id': 0}) }}'.replace('0', id), {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(res => res.json())
                .then(data => {
                    alert(data.message);
                    if(data.status === 'success') location.reload();
                })
                .catch(err => {
                    console.error(err);
                    alert("An error occurred.");
                });
            }
        }
    </script>
{% endblock %}
