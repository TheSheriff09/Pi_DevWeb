{% extends 'BackOffice/mentorship/base_mentorship.html.twig' %}

{% block title %}Manage Mentors - Mentorship Admin{% endblock %}

{% block header_title %}Manage Mentors{% endblock %}

{% block body %}
    <div class="card" style="width: 100%; padding: 30px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <h3 style="margin: 0; color: var(--primary-lighter); text-align: left;">Mentor Directory</h3>
            <input type="text" id="mentorSearchInput" placeholder="Search by name or email..." class="form-input" style="padding: 10px 15px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.2); background: rgba(0,0,0,0.1); color: var(--text-main); width: 250px;">
        </div>
        
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse; text-align: left;" id="mentorsTable">
                <thead>
                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                        <th style="padding: 15px; color: #b0a8d6;">ID</th>
                        <th style="padding: 15px; color: #b0a8d6;">Mentor Name</th>
                        <th style="padding: 15px; color: #b0a8d6;">Email</th>
                        <th style="padding: 15px; color: #b0a8d6;">Completed Sessions</th>
                        <th style="padding: 15px; color: #b0a8d6;">Average Rating</th>
                        <th style="padding: 15px; color: #b0a8d6; text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody id="mentorsTableBody">
                    {% include 'BackOffice/mentorship/_mentors_tbody.html.twig' %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Mentor Profile Popup Modal -->
    <div id="mentorModalOverlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center; backdrop-filter: blur(5px);">
        <div style="background: var(--bg-dark, #1a1a2e); border: 1px solid rgba(111, 86, 255, 0.3); border-radius: 15px; width: 400px; max-width: 90%; position: relative; padding: 30px; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
            <button onclick="closeMentorModal()" style="position: absolute; top: 15px; right: 15px; background: transparent; border: none; font-size: 1.5rem; color: #b0a8d6; cursor: pointer;">&times;</button>
            <div style="text-align: center; margin-bottom: 20px;">
                <div id="modalAvatar" style="width: 70px; height: 70px; background: linear-gradient(135deg, #6f56ff, #d2a7ff); border-radius: 50%; margin: 0 auto 15px; display: flex; align-items: center; justify-content: center; font-size: 2rem; font-weight: bold; color: white;">
                    A
                </div>
                <h2 id="modalName" style="color: var(--text-main); margin: 0 0 5px;">Mentor Name</h2>
                <p id="modalEmail" style="color: var(--primary-lighter); margin: 0; font-size: 0.9rem;">email@example.com</p>
            </div>
            
            <div style="background: rgba(255,255,255,0.02); border-radius: 10px; padding: 15px; margin-bottom: 20px;">
                <h4 style="color: #b0a8d6; margin: 0 0 10px; font-size: 0.85rem; text-transform: uppercase;">Expertise</h4>
                <p id="modalExpertise" style="color: var(--text-main); margin: 0; font-size: 0.95rem;">Software Engineering, Marketing</p>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 20px;">
                <div style="background: rgba(111, 86, 255, 0.1); padding: 15px; border-radius: 10px; text-align: center;">
                    <span style="display: block; font-size: 1.5rem; font-weight: bold; color: var(--text-main);" id="modalSessions">0</span>
                    <span style="font-size: 0.8rem; color: #b0a8d6;">Completed Sessions</span>
                </div>
                <div style="background: rgba(241, 196, 15, 0.1); padding: 15px; border-radius: 10px; text-align: center;">
                    <span style="display: block; font-size: 1.5rem; font-weight: bold; color: #f1c40f;" id="modalRating">★ 0.0</span>
                    <span style="font-size: 0.8rem; color: #b0a8d6;">Average Rating</span>
                </div>
            </div>

            <div style="text-align: center; color: #b0a8d6; font-size: 0.8rem;">
                Joined: <span id="modalJoined">YYYY-MM-DD</span>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
<script>
    function openMentorModal(btn) {
        document.getElementById('modalAvatar').innerText = btn.getAttribute('data-name').charAt(0).toUpperCase();
        document.getElementById('modalName').innerText = btn.getAttribute('data-name');
        document.getElementById('modalEmail').innerText = btn.getAttribute('data-email');
        document.getElementById('modalExpertise').innerText = btn.getAttribute('data-expertise');
        document.getElementById('modalSessions').innerText = btn.getAttribute('data-sessions');
        document.getElementById('modalRating').innerText = "★ " + btn.getAttribute('data-rating');
        document.getElementById('modalJoined').innerText = btn.getAttribute('data-joined');

        document.getElementById('mentorModalOverlay').style.display = 'flex';
    }

    function closeMentorModal() {
        document.getElementById('mentorModalOverlay').style.display = 'none';
    }

    // Close on click outside
    document.getElementById('mentorModalOverlay').addEventListener('click', function(e) {
        if (e.target === this) {
            closeMentorModal();
        }
    });

    document.addEventListener("DOMContentLoaded", function() {
        const searchInput = document.getElementById('mentorSearchInput');
        const tableBody = document.getElementById('mentorsTableBody');

        if (searchInput) {
            searchInput.addEventListener('keyup', function() {
                const term = this.value;
                fetch(`{{ path('app_admin_mentorship_mentors') }}?search=${encodeURIComponent(term)}`, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(response => response.text())
                .then(html => {
                    tableBody.innerHTML = html;
                });
            });
        }
    });
</script>
{% endblock %}
