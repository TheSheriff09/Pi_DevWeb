<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; border: 1px solid #eaeaea; border-radius: 10px; overflow: hidden;">
    <div style="background-color: #2ecc71; padding: 20px; text-align: center;">
        <h2 style="color: white; margin: 0;">Mentorship Request Approved ✅</h2>
    </div>
    <div style="padding: 30px;">
        <p style="font-size: 16px; color: #333;">Hello {{ entrepreneur.fullName }},</p>
        <p style="font-size: 16px; color: #555;">Great news! Your mentorship session request with <strong>{{ mentor.fullName }}</strong> has been approved.</p>
        
        <div style="background-color: #f8f9fa; border-left: 4px solid #2ecc71; padding: 15px; margin: 20px 0;">
            <p style="margin: 5px 0;"><strong>Topic:</strong> {{ booking.topic }}</p>
            <p style="margin: 5px 0;"><strong>Status:</strong> Approved & Scheduled</p>
        </div>

        {% if session and session.meetingLink %}
            <div style="text-align: center; margin-top: 30px;">
                <p>Your meeting link is ready. Keep it safe!</p>
                <a href="{{ session.meetingLink }}" style="background-color: #3498db; color: white; padding: 12px 25px; text-decoration: none; border-radius: 6px; font-weight: bold; display: inline-block;">View Meeting Details</a>
            </div>
        {% endif %}
    </div>
    <div style="background-color: #f1f2f6; padding: 15px; text-align: center; font-size: 12px; color: #888;">
        &copy; {{ 'now'|date('Y') }} StartupFlow Inc.
    </div>
</div>
