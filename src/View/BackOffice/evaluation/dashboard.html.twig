{% extends 'BackOffice/evaluation/base_evaluation.html.twig' %}

{% block title %}Evaluation Dashboard{% endblock %}
{% block header_title %}Grading & Analytics{% endblock %}

{% block body %}
    <div style="display: flex; justify-content: flex-end; margin-bottom: 20px;">
        <a href="{{ path('app_admin_evaluation_pdf') }}" class="pill-btn glow-btn" style="background: linear-gradient(135deg, #a18bff, #8256ff); padding: 10px 20px; color: white; text-decoration: none; display: inline-flex; align-items: center; gap: 10px; font-weight: bold; border-radius: 20px;">
            📄 Download Complete PDF Report
        </a>
    </div>

    <div class="dashboard-cards" style="margin-bottom: 40px; display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 25px;">
        <div class="card glass-card" style="position: relative; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); background: rgba(255, 157, 157, 0.05); padding: 25px;">
            <div style="position: absolute; top: -10px; right: -10px; font-size: 5rem; opacity: 0.1; color: #ff9d9d;">📁</div>
            <h3 style="font-size: 3rem; margin: 0; color: #ff9d9d; text-shadow: 0 0 20px rgba(255, 157, 157, 0.4);">{{ applicationsCount }}</h3>
            <p style="text-transform: uppercase; font-size: 0.85rem; letter-spacing: 2px; color: #b0a8d6; margin-top: 5px; font-weight: 600;">Funding Applications</p>
        </div>
        
        <div class="card glass-card" style="position: relative; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); background: rgba(161, 139, 255, 0.05); padding: 25px;">
            <div style="position: absolute; top: -10px; right: -10px; font-size: 5rem; opacity: 0.1; color: #a18bff;">⚖️</div>
            <h3 style="font-size: 3rem; margin: 0; color: #a18bff; text-shadow: 0 0 20px rgba(161, 139, 255, 0.4);">{{ evaluationsCount }}</h3>
            <p style="text-transform: uppercase; font-size: 0.85rem; letter-spacing: 2px; color: #b0a8d6; margin-top: 5px; font-weight: 600;">Total Evaluations</p>
        </div>
    </div>

    <div class="card" style="width: 100%; padding: 35px; background: rgba(255,255,255,0.02); border-radius: 15px;">
        <h3 style="margin-bottom: 25px; color: var(--text-main);">Latest Funding Applications</h3>
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: separate; border-spacing: 0 10px; text-align: left;">
                <thead>
                    <tr>
                        <th style="padding: 15px; color: #ff9d9d; font-size: 0.75rem; text-transform: uppercase;">ID</th>
                        <th style="padding: 15px; color: #ff9d9d; font-size: 0.75rem; text-transform: uppercase;">Amount</th>
                        <th style="padding: 15px; color: #ff9d9d; font-size: 0.75rem; text-transform: uppercase;">Status</th>
                        <th style="padding: 15px; color: #ff9d9d; font-size: 0.75rem; text-transform: uppercase;">Date</th>
                    </tr>
                </thead>
                <tbody>
                    {% for app in latestApplications %}
                        <tr style="background: rgba(255,255,255,0.03); transition: all 0.3s;" onmouseover="this.style.background='rgba(255,157,157,0.08)'" onmouseout="this.style.background='rgba(255,255,255,0.03)'">
                            <td style="padding: 20px; border-radius: 10px 0 0 10px;">#{{ app.id }}</td>
                            <td style="padding: 20px; font-weight: 600; color: var(--text-main);">${{ app.amount|number_format(2) }}</td>
                            <td style="padding: 20px;">
                                <span style="padding: 5px 12px; border-radius: 15px; font-size: 0.75rem; font-weight: 700; background: rgba(255,255,255,0.1); color: #fff;">
                                    {{ app.status|upper }}
                                </span>
                            </td>
                            <td style="padding: 20px; border-radius: 0 10px 10px 0; color: #b0a8d6;">{{ app.submissionDate|date('Y-m-d') }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="4" style="padding: 30px; text-align: center;">No applications found.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
