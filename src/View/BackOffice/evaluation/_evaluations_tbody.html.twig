{% for eval in evaluations %}
    <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
        <td style="padding: 15px;">{{ eval.id }}</td>
        <td style="padding: 15px;">{{ eval.fundingApplicationId }}</td>
        <td style="padding: 15px; font-weight: 500; color: {{ eval.score >= 70 ? '#7fffd4' : (eval.score >= 50 ? '#ffd700' : '#ff6b6b') }};">
            {{ eval.score }}/100
        </td>
        <td style="padding: 15px;">{{ eval.decision }}</td>
        <td style="padding: 15px;">{{ eval.riskLevel }}</td>
        <td style="padding: 15px; text-align: right;">
            <div style="display: flex; gap: 8px; justify-content: flex-end;">
                <a href="{{ path('app_admin_evaluation_evaluation_edit', {'id': eval.id}) }}" class="btn-pill" style="background: rgba(161, 139, 255, 0.1); color: #a18bff; border: 1px solid rgba(161, 139, 255, 0.3); padding: 5px 12px; text-decoration: none; font-size: 0.8rem;">Edit</a>
                <form method="post" action="{{ path('app_admin_evaluation_evaluation_delete', {'id': eval.id}) }}" onsubmit="return confirm('Are you sure you want to delete this evaluation?');" style="margin: 0;">
                    <button class="btn-pill" type="submit" style="background: rgba(231, 76, 60, 0.1); color: #ff5656; border: 1px solid rgba(231, 76, 60, 0.3); padding: 5px 12px; font-size: 0.8rem; cursor: pointer;">Delete</button>
                </form>
            </div>
        </td>
    </tr>
{% else %}
    <tr>
        <td colspan="6" style="padding: 15px; text-align: center; color: #b0a8d6;">No evaluations found.</td>
    </tr>
{% endfor %}
