{% for eval in evaluations %}
    <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
        <td style="padding: 15px;">{{ eval.id }}</td>
        <td style="padding: 15px;">{{ eval.fundingApplicationId }}</td>
        <td style="padding: 15px; font-weight: 500; color: {{ eval.score >= 70 ? '#7fffd4' : (eval.score >= 50 ? '#ffd700' : '#ff6b6b') }};">
            {{ eval.score }}/100
        </td>
        <td style="padding: 15px;">{{ eval.decision }}</td>
        <td style="padding: 15px;">{{ eval.riskLevel }}</td>
        <td style="padding: 15px;">
            <div class="action-btns">
                <a href="{{ path('app_admin_evaluation_evaluation_edit', {'id': eval.id}) }}" class="btn-edit">Edit</a>
                <form method="post" action="{{ path('app_admin_evaluation_evaluation_delete', {'id': eval.id}) }}" onsubmit="return confirm('Are you sure you want to delete this evaluation?');" style="display:inline-block; margin:0;">
                    <button class="btn-delete" type="submit">Delete</button>
                </form>
            </div>
        </td>
    </tr>
{% else %}
    <tr>
        <td colspan="6" style="padding: 15px; text-align: center; color: #b0a8d6;">No evaluations found.</td>
    </tr>
{% endfor %}
