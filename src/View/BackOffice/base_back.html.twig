<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}StartupFlow Admin{% endblock %}</title>
    <link rel="stylesheet" href="{{ asset('Back/css/styles.css') }}?v=2">
    <style>
        :root {
            --sidebar-width: 260px;
        }
        body.dark-mode {
            background-color: #0f0f1a;
            color: #e0e0e0;
        }
        .main-content {
            margin-left: var(--sidebar-width);
            transition: all 0.3s ease;
        }
        .sidebar {
            width: var(--sidebar-width);
            position: fixed;
            height: 100vh;
            left: 0;
            top: 0;
            background: #1a1a2e;
            border-right: 1px solid rgba(255,255,255,0.05);
            z-index: 1000;
            display: flex;
            flex-direction: column;
        }
        .sidebar-menu li a {
            padding: 12px 20px;
            display: block;
            color: #b0a8d6;
            text-decoration: none;
            transition: all 0.3s ease;
            border-radius: 8px;
            margin: 4px 15px;
            font-size: 0.95rem;
        }
        .sidebar-menu li a:hover {
            background: rgba(111,86,255,0.1);
            color: #fff;
            padding-left: 25px;
        }
        .sidebar-menu li a.active {
            background: linear-gradient(90deg, rgba(111,86,255,0.2), transparent);
            border-left: 4px solid var(--primary);
            padding-left: 25px;
            color: #fff;
            font-weight: 600;
        }
        .card {
            background: rgba(255,255,255,0.02);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.2);
        }
        .glass-card {
            backdrop-filter: blur(10px);
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.1);
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <script>
        if (localStorage.getItem('admin_theme') === 'dark') {
            document.body.classList.add('dark-mode');
        }
    </script>

    <!-- SHARED BACKOFFICE SIDEBAR -->
    <aside class="sidebar">
        <div class="sidebar-header" style="padding: 25px; text-align: center;">
            <h2 style="color: var(--primary-light); font-size: 1.4rem; margin: 0; text-transform: uppercase; letter-spacing: 2px;">Admin Hub</h2>
        </div>
        <ul class="sidebar-menu" style="list-style: none; padding: 0; flex-grow: 1;">
            <li><a href="{{ path('app_admin_panel') }}" style="color: #ff9d9d;">&larr; Global Panel</a></li>
            
            <li style="margin-top: 20px; padding: 0 20px 5px; font-size: 0.7rem; color: #666; text-transform: uppercase;">Mentorship Module</li>
            <li><a href="{{ path('app_admin_mentorship') }}" class="{{ current_module|default('') == 'mentorship' and current_menu|default('') == 'dashboard' ? 'active' : '' }}">Dashboard</a></li>
            <li><a href="{{ path('app_admin_mentorship_mentors') }}" class="{{ current_module|default('') == 'mentorship' and current_menu|default('') == 'mentors' ? 'active' : '' }}">Mentors</a></li>
            <li><a href="{{ path('app_admin_mentorship_bookings') }}" class="{{ current_module|default('') == 'mentorship' and current_menu|default('') == 'bookings' ? 'active' : '' }}">Bookings</a></li>
            <li><a href="{{ path('app_admin_mentorship_sessions') }}" class="{{ current_module|default('') == 'mentorship' and current_menu|default('') == 'sessions' ? 'active' : '' }}">Sessions</a></li>
            <li><a href="{{ path('app_admin_mentorship_feedback') }}" class="{{ current_module|default('') == 'mentorship' and current_menu|default('') == 'feedback' ? 'active' : '' }}">Feedback</a></li>
            
            <li style="margin-top: 20px; padding: 0 20px 5px; font-size: 0.7rem; color: #666; text-transform: uppercase;">Evaluation Module</li>
            <li><a href="{{ path('app_admin_evaluation_dashboard') }}" class="{{ current_module|default('') == 'evaluation' and current_menu|default('') == 'dashboard' ? 'active' : '' }}">Analytics</a></li>
            <li><a href="{{ path('app_admin_evaluation_applications') }}" class="{{ current_module|default('') == 'evaluation' and current_menu|default('') == 'applications' ? 'active' : '' }}">Applications</a></li>
            <li><a href="{{ path('app_admin_evaluation_evaluations') }}" class="{{ current_module|default('') == 'evaluation' and current_menu|default('') == 'evaluations' ? 'active' : '' }}">Grading</a></li>
        </ul>
        <div class="sidebar-footer" style="padding: 20px;">
            <a href="{{ path('app_logout') }}" class="btn-pill" style="display: block; text-align: center; color: #ff5656; border: 1px solid rgba(255, 86, 86, 0.3); background: rgba(255, 86, 86, 0.05); padding: 10px; text-decoration: none; border-radius: 8px;">Sign Out</a>
        </div>
    </aside>

    <div class="main-content">
        <header class="topbar" style="padding: 20px 30px; display: flex; justify-content: space-between; align-items: center; background: rgba(0,0,0,0.1); backdrop-filter: blur(5px);">
            <div class="topbar-left">
                <h2 style="margin: 0; color: #fff; font-weight: 600;">{% block header_title %}Admin{% endblock %}</h2>
            </div>
            <div class="topbar-right" style="display: flex; gap: 20px; align-items: center;">
                <button id="themeToggleBtn" class="btn-pill" style="border: 2px solid var(--primary-light); background: transparent; color: var(--primary-light); padding: 5px 15px; cursor: pointer;">🌓 Mode</button>
                <div class="user-profile" style="display: flex; align-items: center; gap: 10px;">
                    <div class="avatar" style="background: var(--primary); width: 35px; height: 35px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; color: white;">A</div>
                    <span>Administrator</span>
                </div>
            </div>
        </header>

        <!-- FLASH MESSAGES -->
        <div id="flash-container" style="padding: 0 30px; margin-top: 20px;">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="card glass-card" style="padding: 15px 25px; margin-bottom: 10px; border-left: 5px solid {% if label == 'success' %}#2ecc71{% else %}#e74c3c{% endif %}; animation: slideIn 0.3s ease-out;">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span style="color: #fff; font-weight: 500;">
                                {% if label == 'success' %}✅{% else %}⚠️{% endif %} {{ message }}
                            </span>
                            <button onclick="this.parentElement.parentElement.remove()" style="background:transparent; border:none; color:white; cursor:pointer; font-size:1.2rem;">&times;</button>
                        </div>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>

        <main class="dashboard-content" style="padding: 30px; min-height: 80vh;">
            {% block body %}{% endblock %}
        </main>
        
        <footer style="padding: 30px; text-align: center; opacity: 0.5; font-size: 0.85rem;">
            &copy; {{ 'now'|date('Y') }} StartupFlow Tunisia. High-Performance Administration Panel.
        </footer>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const toggleBtn = document.getElementById('themeToggleBtn');
            if (toggleBtn) {
                toggleBtn.addEventListener('click', () => {
                    const isDark = document.body.classList.contains('dark-mode');
                    if (isDark) {
                        document.body.classList.remove('dark-mode');
                        localStorage.setItem('admin_theme', 'light');
                    } else {
                        document.body.classList.add('dark-mode');
                        localStorage.setItem('admin_theme', 'dark');
                    }
                });
            }
        });
    </script>
    {% block javascripts %}{% endblock %}
</body>
</html>
