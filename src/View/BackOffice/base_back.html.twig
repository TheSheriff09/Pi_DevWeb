<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}StartupFlow Admin{% endblock %}</title>
    <link rel="stylesheet" href="{{ asset('Back/css/styles.css') }}?v=2">
    <style>
        :root {
            --sidebar-width: 260px;
        }
        body.dark-mode {
            background-color: #0f0f1a;
            color: #e0e0e0;
        }
        .main-content {
            margin-left: var(--sidebar-width);
            transition: all 0.3s ease;
        }
        .sidebar {
            width: var(--sidebar-width);
            position: fixed;
            height: 100vh;
            left: 0;
            top: 0;
            background: #f0eaff; /* Light purple background from image */
            border-right: 1px solid rgba(128,128,128,0.1);
            z-index: 1000;
            display: flex;
            flex-direction: column;
            transition: all 0.3s ease;
        }
        body.dark-mode .sidebar {
            background: #1a1a2e;
            border-color: rgba(255,255,255,0.05);
        }
        .sidebar-menu li a {
            padding: 15px 30px;
            display: block;
            color: #8d79ff;
            text-decoration: none;
            transition: all 0.3s ease;
            font-size: 1.1rem;
            font-weight: 600;
        }
        .sidebar-menu li a:hover {
            background: rgba(122, 92, 255, 0.05);
            padding-left: 35px;
        }
        .sidebar-menu li a.active {
            background: rgba(122, 92, 255, 0.12);
            color: #7a5cff;
            border-left: 6px solid #7a5cff;
            padding-left: 30px;
        }
        body.dark-mode .sidebar-menu li a.active {
            background: rgba(157, 133, 255, 0.15);
            color: #9d85ff;
            border-color: #9d85ff;
        }
        .card {
            background: rgba(255,255,255,0.8);
            border: 1px solid rgba(128,128,128,0.1);
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        }
        body.dark-mode .card {
            background: rgba(255,255,255,0.02);
            border-color: rgba(255,255,255,0.05);
            box-shadow: 0 4px 20px rgba(0,0,0,0.2);
        }
        .glass-card {
            backdrop-filter: blur(10px);
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.1);
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <script>
        if (localStorage.getItem('admin_theme') === 'dark') {
            document.body.classList.add('dark-mode');
        }
    </script>

    <!-- SHARED BACKOFFICE SIDEBAR -->
    <aside class="sidebar">
        <div class="sidebar-content" style="flex-grow: 1; overflow-y: auto; padding-top: 25px;">
            {# Back Link #}
            <div style="padding: 0 30px 25px;">
                <a href="{{ path('app_admin_panel') }}" style="color: #ff9d9d; text-decoration: none; font-weight: bold; font-size: 1.2rem; display: flex; align-items: center; gap: 8px;">&larr; Main Admin</a>
            </div>

            {# Module Specific Links #}
            <ul class="sidebar-menu" style="list-style: none; padding: 0;">
                {% if current_module|default('') == 'users' %}
                    <li><a href="{{ path('app_admin_users') }}" class="{{ current_menu|default('') == 'list' ? 'active' : '' }}">Users List</a></li>
                    <li><a href="{{ path('app_admin_activity') }}" class="{{ current_menu|default('') == 'activity' ? 'active' : '' }}">Activity Log</a></li>
                    <li><a href="{{ path('app_admin_users_charts') }}" class="{{ current_menu|default('') == 'charts' ? 'active' : '' }}">Analytics</a></li>
                    <li><a href="{{ path('app_admin_risk_dashboard') }}" class="{{ current_menu|default('') == 'risk' ? 'active' : '' }}">Risk Engine</a></li>
                
                {% elseif current_module|default('') == 'mentorship' %}
                    <li><a href="{{ path('app_admin_mentorship') }}" class="{{ current_menu|default('') == 'dashboard' ? 'active' : '' }}">Dashboard</a></li>
                    <li><a href="{{ path('app_admin_mentorship_mentors') }}" class="{{ current_menu|default('') == 'mentors' ? 'active' : '' }}">Mentors</a></li>
                    <li><a href="{{ path('app_admin_mentorship_bookings') }}" class="{{ current_menu|default('') == 'bookings' ? 'active' : '' }}">Bookings</a></li>
                    <li><a href="{{ path('app_admin_mentorship_sessions') }}" class="{{ current_menu|default('') == 'sessions' ? 'active' : '' }}">Sessions</a></li>
                    <li><a href="{{ path('app_admin_mentorship_feedback') }}" class="{{ current_menu|default('') == 'feedback' ? 'active' : '' }}">Feedback</a></li>

                {% elseif current_module|default('') == 'evaluation' %}
                    <li><a href="{{ path('app_admin_evaluation_dashboard') }}" class="{{ current_menu|default('') == 'dashboard' ? 'active' : '' }}">Dashboard</a></li>
                    <li><a href="{{ path('app_admin_evaluation_applications') }}" class="{{ current_menu|default('') == 'applications' ? 'active' : '' }}">Applications</a></li>
                    <li><a href="{{ path('app_admin_evaluation_evaluations') }}" class="{{ current_menu|default('') == 'evaluations' ? 'active' : '' }}">Grading</a></li>

                {% elseif current_module|default('') == 'forum' %}
                    <li><a href="{{ path('app_admin_forum_dashboard') }}" class="{{ current_menu|default('') == 'dashboard' ? 'active' : '' }}">Dashboard</a></li>
                    <li><a href="{{ path('app_admin_forum_posts') }}" class="{{ current_menu|default('') == 'posts' ? 'active' : '' }}">Manage Posts</a></li>
                    <li><a href="{{ path('app_admin_forum_comments') }}" class="{{ current_menu|default('') == 'comments' ? 'active' : '' }}">Manage Comments</a></li>
                    <li><a href="{{ path('app_admin_forum_interactions') }}" class="{{ current_menu|default('') == 'interactions' ? 'active' : '' }}">Manage Interactions</a></li>
                    <li><a href="{{ path('app_admin_forum_banned_words') }}" class="{{ current_menu|default('') == 'banned_words' ? 'active' : '' }}">Banned Words</a></li>
                    <li><a href="{{ path('app_admin_forum_reports') }}" class="{{ current_menu|default('') == 'reports' ? 'active' : '' }}">Reported Content</a></li>
                {% endif %}
            </ul>

            {# Global Modules Header #}
            <div style="padding: 40px 30px 15px;">
                <h3 style="color: #8d79ff; font-size: 1.1rem; margin: 0; font-weight: bold;">Global Modules</h3>
            </div>

            {# Global List #}
            <ul class="sidebar-menu" style="list-style: none; padding: 0;">
                <li><a href="{{ path('app_admin_forum_dashboard') }}" class="{{ current_module|default('') == 'forum' ? 'active' : '' }}">Forum</a></li>
                <li><a href="{{ path('app_admin_startup_dashboard') }}" class="{{ current_module|default('') == 'startup' ? 'active' : '' }}">Startup</a></li>
                <li><a href="{{ path('app_admin_evaluation_dashboard') }}" class="{{ current_module|default('') == 'evaluation' ? 'active' : '' }}">Evaluation</a></li>
                <li><a href="{{ path('app_admin_users') }}" class="{{ current_module|default('') == 'users' ? 'active' : '' }}">Users</a></li>
                <li><a href="{{ path('app_admin_mentorship') }}" class="{{ current_module|default('') == 'mentorship' ? 'active' : '' }}">Mentorship</a></li>
                <li><a href="{{ path('app_admin_reclamations') }}" class="{{ current_module|default('') == 'reclamations' ? 'active' : '' }}">Reclamations</a></li>
            </ul>
        </div>

        <div class="sidebar-footer" style="padding: 25px;">
            <a href="{{ path('app_logout') }}" style="display: block; width: 100%; background: #e2d5ff; color: #ff5656; text-align: center; padding: 15px; border-radius: 12px; text-decoration: none; font-weight: bold; font-size: 1.1rem; transition: all 0.3s; border: none; box-shadow: 0 4px 10px rgba(0,0,0,0.05);" onmouseover="this.style.background='#d8c5ff'; this.style.transform='translateY(-2px)'" onmouseout="this.style.background='#e2d5ff'; this.style.transform='translateY(0)'">Sign Out</a>
        </div>
    </aside>

    <div class="main-content" style="display: flex; flex-direction: column; height: 100vh; overflow-y: auto; position: relative;">
        <header class="topbar" style="padding: 30px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(128,128,128,0.1); flex-shrink: 0; background: rgba(255,255,255,0.02); backdrop-filter: blur(10px);">
            <div class="topbar-left">
                <h1 style="margin: 0; color: var(--text-main); font-weight: 800; font-size: 1.8rem; text-transform: uppercase; letter-spacing: 2px;">{% block header_title %}Admin{% endblock %}</h1>
            </div>
            <div class="topbar-right" style="display: flex; gap: 20px; align-items: center;">
                <button id="themeToggleBtn" class="btn-pill" style="border: 2px solid var(--primary); background: transparent; color: var(--primary); padding: 10px 20px; cursor: pointer; font-weight: bold; border-radius: 20px; transition: all 0.3s;">🌓 Toggle Mode</button>
                <div class="user-profile" style="display: flex; align-items: center; gap: 12px; background: rgba(128,128,128,0.05); padding: 5px 15px; border-radius: 30px; border: 1px solid rgba(128,128,128,0.1);">
                    <div class="avatar" style="background: var(--primary); width: 35px; height: 35px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; color: white; box-shadow: 0 0 10px rgba(122, 92, 255, 0.4);">A</div>
                    <span style="font-weight: 600; font-size: 0.9rem;">Administrator</span>
                </div>
            </div>
        </header>

        <!-- FLASH MESSAGES -->
        <div id="flash-container" style="padding: 20px 30px 0;">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="card" style="padding: 15px 25px; margin-bottom: 15px; border-left: 5px solid {% if label == 'success' %}#2ecc71{% else %}#e74c3c{% endif %}; background: rgba(255,255,255,0.9); backdrop-filter: blur(10px);">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span style="font-weight: 500; color: #333;">
                                {% if label == 'success' %}✅{% else %}⚠️{% endif %} {{ message }}
                            </span>
                            <button onclick="this.parentElement.parentElement.remove()" style="background:transparent; border:none; color:#999; cursor:pointer; font-size:1.5rem; line-height: 1;">&times;</button>
                        </div>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>

        <main class="dashboard-content" style="padding: 30px; flex-grow: 1;">
            {% block body %}{% endblock %}
        </main>
        
        <footer style="padding: 30px; text-align: center; opacity: 0.6; font-size: 0.85rem; border-top: 1px solid rgba(128,128,128,0.05); margin-top: auto;">
            &copy; {{ 'now'|date('Y') }} StartupFlow Tunisia. High-Performance Administration Panel.
        </footer>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const toggleBtn = document.getElementById('themeToggleBtn');
            if (toggleBtn) {
                toggleBtn.addEventListener('click', () => {
                    const isDark = document.body.classList.contains('dark-mode');
                    if (isDark) {
                        document.body.classList.remove('dark-mode');
                        localStorage.setItem('admin_theme', 'light');
                    } else {
                        document.body.classList.add('dark-mode');
                        localStorage.setItem('admin_theme', 'dark');
                    }
                });
            }
        });
    </script>
    {% block javascripts %}{% endblock %}
</body>
</html>
