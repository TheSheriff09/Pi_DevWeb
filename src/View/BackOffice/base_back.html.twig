<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}StartupFlow Admin{% endblock %}</title>
    <link rel="stylesheet" href="{{ asset('Back/css/styles.css') }}?v=2">
    <style>
        :root {
            --sidebar-width: 260px;
        }
        body.dark-mode {
            background-color: #0f0f1a;
            color: #e0e0e0;
        }
        .main-content {
            margin-left: var(--sidebar-width);
            transition: all 0.3s ease;
        }
        .sidebar {
            width: var(--sidebar-width);
            position: fixed;
            height: 100vh;
            left: 0;
            top: 0;
            background: #1a1a2e;
            border-right: 1px solid rgba(255,255,255,0.05);
            z-index: 1000;
            display: flex;
            flex-direction: column;
        }
        .sidebar-menu li a {
            padding: 12px 20px;
            display: block;
            color: #b0a8d6;
            text-decoration: none;
            transition: all 0.3s ease;
            border-radius: 8px;
            margin: 4px 15px;
            font-size: 0.95rem;
        }
        .sidebar-menu li a:hover {
            background: rgba(111,86,255,0.1);
            color: #fff;
            padding-left: 25px;
        }
        .sidebar-menu li a.active {
            background: linear-gradient(90deg, rgba(111,86,255,0.2), transparent);
            border-left: 4px solid var(--primary);
            padding-left: 25px;
            color: #fff;
            font-weight: 600;
        }
        .card {
            background: rgba(255,255,255,0.02);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.2);
        }
        .glass-card {
            backdrop-filter: blur(10px);
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.1);
        }
    </style>
