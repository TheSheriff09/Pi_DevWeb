{% extends 'BackOffice/base_back.html.twig' %}

{% block title %}Admin - Reclamations{% endblock %}

{% block header_title %}Reclamations Management{% endblock %}

{% block body %}
<div class="card" style="width: 100%; padding: 25px;">
    <h3 style="margin-bottom: 25px; color: var(--primary); font-size: 1.3rem;">Active Reclamations</h3>
    <div style="overflow-x: auto; border-radius: 12px; border: 1px solid rgba(128,128,128,0.1);">
        <table style="width: 100%; border-collapse: collapse; text-align: left;">
            <thead>
                <tr style="background: rgba(122, 92, 255, 0.05); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;">
                    <th style="padding: 15px 20px; color: var(--primary);">ID</th>
                    <th style="padding: 15px 20px; color: var(--primary);">Type</th>
                    <th style="padding: 15px 20px; color: var(--primary);">Description</th>
                    <th style="padding: 15px 20px; color: var(--primary);">Users</th>
                    <th style="padding: 15px 20px; color: var(--primary);">Date</th>
                    <th style="padding: 15px 20px; color: var(--primary);">Status</th>
                    <th style="padding: 15px 20px; color: var(--primary);">Action</th>
                </tr>
            </thead>
            <tbody style="font-size: 0.9rem;">
                {% for recItem in reclamations %}
                    {% set rec = recItem.entity %}
                    <tr style="border-bottom: 1px solid rgba(128,128,128,0.1); transition: all 0.2s;">
                        <td style="padding: 15px 20px; opacity: 0.7;">{{ rec.id }}</td>
                        <td style="padding: 15px 20px;">
                            <span style="background: rgba(111, 86, 255, 0.1); color: var(--primary); padding: 5px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: bold;">
                                {{ rec.title }}
                            </span>
                        </td>
                        <td style="padding: 15px 20px; max-width: 300px; line-height: 1.4;">{{ rec.description }}</td>
                        <td style="padding: 15px 20px;">
                            <div style="font-size: 0.8rem;">
                                <div style="margin-bottom: 4px;"><span style="opacity: 0.5;">By:</span> {{ usersMap[rec.requestedId] ?? 'Unknown' }}</div>
                                {% if (rec.title == 'User problem' or rec.title == 'AI Bias Alert') %}
                                    <div><span style="opacity: 0.5;">Target:</span> {{ usersMap[rec.targetId] ?? 'Unknown' }}</div>
                                {% endif %}
                            </div>
                        </td>
                        <td style="padding: 15px 20px; opacity: 0.7; font-size: 0.85rem;">{{ rec.createdAt|date('Y-m-d H:i') }}</td>
                        <td style="padding: 15px 20px;">
                            <form action="{{ path('app_admin_reclamation_status', {id: rec.id}) }}" method="POST">
                                <select name="status" onchange="this.form.submit()" style="padding: 6px 10px; border-radius: 8px; border: 1px solid rgba(128,128,128,0.2); background: rgba(0,0,0,0.05); color: var(--text-main); font-size: 0.8rem; cursor: pointer;">
                                    <option value="OPEN" {% if rec.status == 'OPEN' %}selected{% endif %}>Open</option>
                                    <option value="IN_PROGRESS" {% if rec.status == 'IN_PROGRESS' %}selected{% endif %}>In Progress</option>
                                    <option value="RESOLVED" {% if rec.status == 'RESOLVED' %}selected{% endif %}>Resolved</option>
                                    <option value="REJECTED" {% if rec.status == 'REJECTED' %}selected{% endif %}>Rejected</option>
                                </select>
                            </form>
                        </td>
                        <td style="padding: 15px 20px;">
                            <div style="display: flex; gap: 8px;">
                                <div style="display: none;" id="responses-data-{{ rec.id }}">
                                    {% for res in recItem.responsesList %}
                                        <div style="background: rgba(128,128,128,0.05); padding: 12px; margin-bottom: 10px; border-radius: 8px; border-left: 4px solid var(--primary);">
                                            <strong style="color: var(--primary); font-size: 0.85rem;">{{ res.adminName }}:</strong>
                                            <p style="margin: 5px 0; font-size: 0.9rem;">{{ res.content }}</p>
                                            <small style="opacity: 0.5; font-size: 0.75rem;">{{ res.date }}</small>
                                        </div>
                                    {% endfor %}
                                </div>
                                <button onclick="openRespondModal({{ rec.id }})" class="btn-pill" style="padding: 6px 15px; background: rgba(111, 86, 255, 0.1); color: var(--primary); border: 1px solid rgba(111, 86, 255, 0.2); font-size: 0.8rem;">Respond</button>
                                
                                {% if rec.title == 'User problem' or rec.title == 'AI Bias Alert' %}
                                    <a href="{{ path('app_admin_risk_dashboard') }}" style="padding: 6px 12px; text-decoration: none; background: rgba(255, 92, 92, 0.1); color: #ff5c5c; border: 1px solid rgba(255, 92, 92, 0.2); border-radius: 999px; font-size: 0.8rem; font-weight: bold; transition: all 0.3s;">View Risk</a>
                                {% endif %}
                                
                                <form action="{{ path('app_admin_reclamation_delete', {id: rec.id}) }}" method="POST" onsubmit="return confirm('Delete this reclamation?');">
                                    <button type="submit" style="padding: 6px 12px; background: rgba(255, 50, 50, 0.1); color: #ff5656; border: 1px solid rgba(255, 50, 50, 0.2); border-radius: 999px; cursor: pointer; font-size: 0.8rem;">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" style="padding: 40px; text-align: center; opacity: 0.5;">No reclamations found.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<!-- Respond Modal -->
<div id="respondModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 2000; align-items: center; justify-content: center; backdrop-filter: blur(10px);">
    <div class="card" style="width: 500px; max-width: 95%; padding: 30px; box-shadow: 0 20px 40px rgba(0,0,0,0.4);">
        <h3 style="margin: 0 0 20px 0; color: var(--primary);">Manage Responses</h3>
        
        <div id="previousResponsesContainer" style="margin-bottom: 25px; max-height: 250px; overflow-y: auto; padding-right: 10px;">
            <!-- Filled via JS -->
        </div>

        <form id="respondForm" method="POST">
            <div style="margin-bottom: 20px;">
                <label style="display: block; margin-bottom: 8px; font-weight: 600; font-size: 0.9rem; opacity: 0.8;">New Response</label>
                <textarea name="response_content" required rows="4" style="width: 100%; padding: 15px; border-radius: 12px; border: 1px solid rgba(128,128,128,0.2); background: rgba(0, 0, 0, 0.05); color: var(--text-main); font-family: inherit; outline: none; resize: vertical;"></textarea>
            </div>
            <div style="display: flex; justify-content: flex-end; gap: 12px; align-items: center;">
                <button type="button" id="aiRespondBtn" onclick="generateAiResponse()" style="margin-right: auto; background: linear-gradient(135deg, #7a5cff, #4facfe); color: white; padding: 10px 20px; border-radius: 999px; border: none; font-weight: bold; cursor: pointer; display: flex; align-items: center; gap: 8px; font-size: 0.85rem; transition: all 0.3s;">
                    <span>✨</span> Auto-Respond
                </button>
                <button type="button" onclick="closeRespondModal()" style="padding: 10px 25px; background: transparent; border: 1px solid rgba(128,128,128,0.3); color: var(--text-main); border-radius: 999px; cursor: pointer; font-weight: 600; font-size: 0.85rem;">Cancel</button>
                <button type="submit" class="btn-pill" style="background: var(--primary); color: white; padding: 10px 25px; border-radius: 999px; border: none; font-weight: bold; cursor: pointer; font-size: 0.85rem;">Send Reply</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
    let currentRecId = null;

    function openRespondModal(id) {
        currentRecId = id;
        const modal = document.getElementById('respondModal');
        const form = document.getElementById('respondForm');
        const container = document.getElementById('previousResponsesContainer');
        const textarea = document.querySelector('textarea[name="response_content"]');
        
        textarea.value = ''; // Clear previous
        form.action = '/admin/reclamation/respond/' + id;
        
        const sourceDiv = document.getElementById('responses-data-' + id);
        if (sourceDiv && sourceDiv.innerHTML.trim() !== '') {
            container.innerHTML = '<strong style="display:block; margin-bottom:15px; font-size: 0.85rem; opacity: 0.6; text-transform: uppercase;">Conversation History</strong>' + sourceDiv.innerHTML;
        } else {
            container.innerHTML = '<p style="text-align: center; opacity: 0.5; font-style: italic; padding: 20px;">No previous messages.</p>';
        }

        modal.style.display = 'flex';
    }

    function generateAiResponse() {
        if (!currentRecId) return;
        
        const btn = document.getElementById('aiRespondBtn');
        const textarea = document.querySelector('textarea[name="response_content"]');
        const originalBtnText = btn.innerHTML;
        
        btn.innerHTML = '<span>⏳</span> Generating...';
        btn.disabled = true;
        btn.style.opacity = '0.7';
        
        fetch(`/admin/reclamation/ai-respond/${currentRecId}`, {
            method: 'POST',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.response) {
                textarea.value = data.response;
            } else if (data.error) {
                alert("AI Error: " + data.error);
            }
        })
        .catch(err => {
            console.error(err);
            alert("Failed to connect to AI service.");
        })
        .finally(() => {
            btn.innerHTML = originalBtnText;
            btn.disabled = false;
            btn.style.opacity = '1';
        });
    }

    function closeRespondModal() {
        document.getElementById('respondModal').style.display = 'none';
        currentRecId = null;
    }

    // Close modal on click outside
    window.onclick = function(event) {
        const modal = document.getElementById('respondModal');
        if (event.target == modal) {
            closeRespondModal();
        }
    }
</script>

<style>
    tbody tr:hover {
        background: rgba(122, 92, 255, 0.03);
    }
    #previousResponsesContainer::-webkit-scrollbar {
        width: 6px;
    }
    #previousResponsesContainer::-webkit-scrollbar-thumb {
        background: rgba(122, 92, 255, 0.2);
        border-radius: 10px;
    }
</style>
{% endblock %}
