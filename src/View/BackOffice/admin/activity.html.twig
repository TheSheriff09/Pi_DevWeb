{% extends 'BackOffice/base_back.html.twig' %}

{% block title %}Activity Monitor - Users Management{% endblock %}

{% block header_title %}Activity Monitor{% endblock %}

{% block body %}
<div class="activity-container" style="display: flex; flex-direction: column; gap: 20px;">
    
    <div style="display: flex; justify-content: flex-end; gap: 10px; margin-bottom: 10px;">
        <a href="{{ path('app_admin_activity_export_pdf') }}" class="btn-pill" style="border: 2px solid #b58bff; background: transparent; color: #b58bff; text-decoration: none; padding: 8px 20px; border-radius: 20px; font-weight: bold; font-size: 13px; transition: all 0.3s;">📄 Export PDF</a>
        <a href="{{ path('app_admin_activity_export_excel') }}" class="btn-pill" style="border: 2px solid #00ff87; background: transparent; color: #00ff87; text-decoration: none; padding: 8px 20px; border-radius: 20px; font-weight: bold; font-size: 13px; transition: all 0.3s;">📊 Export Excel</a>
        <button onclick="window.location.reload();" class="btn-pill" style="border: 2px solid var(--primary); background: transparent; color: var(--primary); padding: 8px 20px; border-radius: 20px; font-weight: bold; font-size: 13px; transition: all 0.3s; cursor: pointer;">🔄 Refresh</button>
    </div>

    <!-- Analytics Summary Cards -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin-bottom: 10px;">
        <!-- Top Active Users -->
        <div class="card" style="text-align: left; padding: 25px;">
            <h3 style="color: var(--primary); margin-bottom: 20px; font-size: 1.1rem; display: flex; align-items: center; gap: 10px;">
                <span>🏆</span> Top Active Users
            </h3>
            <ul style="list-style: none; padding: 0; margin: 0;">
                {% for userStat in mostActiveUsers %}
                <li style="padding: 12px 0; border-bottom: 1px solid rgba(128,128,128,0.1); display:flex; justify-content:space-between; align-items: center;">
                    <span style="font-weight: 500;">User #{{ userStat.userId }}</span>
                    <span style="background: rgba(122, 92, 255, 0.1); color: var(--primary); padding: 4px 12px; border-radius: 20px; font-size: 0.85rem; font-weight: 700;">{{ userStat.activityCount }} actions</span>
                </li>
                {% else %}
                <li style="color: #888; font-style: italic;">No user activity yet.</li>
                {% endfor %}
            </ul>
        </div>

        <!-- Most Visited Pages -->
        <div class="card" style="text-align: left; padding: 25px;">
            <h3 style="color: var(--primary); margin-bottom: 20px; font-size: 1.1rem; display: flex; align-items: center; gap: 10px;">
                <span>🔥</span> Most Visited Pages
            </h3>
            <ul style="list-style: none; padding: 0; margin: 0;">
                {% for pageStat in mostVisitedPages %}
                <li style="padding: 12px 0; border-bottom: 1px solid rgba(128,128,128,0.1); display:flex; justify-content:space-between; align-items: center;">
                    <span style="font-family: monospace; font-size: 0.85rem; color: var(--text-main); opacity: 0.8; max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{{ pageStat.pageUrl }}</span>
                    <span style="color: var(--primary); font-weight: 700;">{{ pageStat.visitCount }} <small style="font-weight: 400; opacity: 0.7;">views</small></span>
                </li>
                {% else %}
                <li style="color: #888; font-style: italic;">No page visits yet.</li>
                {% endfor %}
            </ul>
        </div>

        <!-- Security Alerts -->
        <div class="card" style="text-align: left; padding: 25px; border-top: 4px solid #ff6b6b;">
            <h3 style="color: #ff6b6b; margin-bottom: 20px; font-size: 1.1rem; display: flex; align-items: center; gap: 10px;">
                <span>⚠️</span> Security Alerts
            </h3>
            <div style="max-height: 250px; overflow-y: auto; padding-right: 5px;">
                {% for alert in securityAlerts %}
                <div style="padding: 12px; border-radius: 8px; background: rgba(255, 107, 107, 0.05); border: 1px solid rgba(255, 107, 107, 0.1); margin-bottom: 10px;">
                    <div style="display:flex; justify-content:space-between; margin-bottom: 5px; font-size: 0.85rem;">
                        <strong style="color: #ff6b6b;">{{ alert.actionType }}</strong>
                        <span style="opacity: 0.6;">{{ alert.createdAt|date('H:i:s') }}</span>
                    </div>
                    <div style="font-size: 0.8rem; opacity: 0.8;">{{ alert.description }}</div>
                </div>
                {% else %}
                <div style="color: #888; font-style: italic; text-align: center; padding: 20px;">No alerts detected.</div>
                {% endfor %}
            </div>
        </div>
    </div>

    <!-- Live Activity Log Table -->
    <div class="card" style="padding: 0; overflow: hidden;">
        <div style="padding: 25px; border-bottom: 1px solid rgba(128,128,128,0.1); display: flex; justify-content: space-between; align-items: center;">
            <h3 style="margin: 0; color: var(--primary); font-size: 1.2rem;">Live Action Log</h3>
            <span style="font-size: 0.8rem; opacity: 0.6;">Showing last 100 activities</span>
        </div>
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse; text-align: left;">
                <thead>
                    <tr style="background: rgba(122, 92, 255, 0.05); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;">
                        <th style="padding: 15px 25px;">Time</th>
                        <th style="padding: 15px 25px;">User</th>
                        <th style="padding: 15px 25px;">Action</th>
                        <th style="padding: 15px 25px;">Resource / Description</th>
                        <th style="padding: 15px 25px;">Status</th>
                    </tr>
                </thead>
                <tbody style="font-size: 0.9rem;">
                    {% for log in recentActivities %}
                    <tr style="border-bottom: 1px solid rgba(128,128,128,0.1); transition: all 0.2s;">
                        <td style="padding: 15px 25px; opacity: 0.7;">{{ log.createdAt|date('Y-m-d H:i:s') }}</td>
                        <td style="padding: 15px 25px;">
                            {% if log.user %}
                                <span style="font-weight: 600;">#{{ log.user.id }}</span>
                            {% else %}
                                <span style="opacity: 0.5; font-style: italic;">Guest</span>
                            {% endif %}
                        </td>
                        <td style="padding: 15px 25px;">
                            {% if log.actionType == 'VIEW_PAGE' %}
                                <span style="color: #4facfe; font-weight: 600;">👁️ VIEW</span>
                            {% elseif log.actionType == 'LOGIN' %}
                                <span style="color: #00f2fe; font-weight: 600;">🔑 LOGIN</span>
                            {% elseif log.actionType == 'LOGOUT' %}
                                <span style="color: #f77062; font-weight: 600;">🚪 LOGOUT</span>
                            {% elseif log.actionType == 'LOGIN_FAILED' %}
                                <span style="color: #ff0844; font-weight: 600;">⚠️ FAILED</span>
                            {% else %}
                                <span style="color: var(--primary); font-weight: 600;">⚡ {{ log.actionType }}</span>
                            {% endif %}
                        </td>
                        <td style="padding: 15px 25px;">
                            {% if log.page %}
                                <div style="font-family: monospace; font-size: 0.8rem; opacity: 0.7; margin-bottom: 4px;">{{ log.page }}</div>
                            {% endif %}
                            {% if log.description %}
                                <div style="font-weight: 400; opacity: 0.9;">{{ log.description }}</div>
                            {% endif %}
                        </td>
                        <td style="padding: 15px 25px;">
                            {% if log.status == 'SUCCESS' %}
                                <span style="display: inline-flex; align-items: center; gap: 5px; color: #00ff87; font-weight: 700; font-size: 0.8rem;">
                                    <span style="width: 8px; height: 8px; border-radius: 50%; background: #00ff87;"></span> SUCCESS
                                </span>
                            {% else %}
                                <span style="display: inline-flex; align-items: center; gap: 5px; color: #ff0055; font-weight: 700; font-size: 0.8rem;">
                                    <span style="width: 8px; height: 8px; border-radius: 50%; background: #ff0055;"></span> {{ log.status }}
                                </span>
                            {% endif %}
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="5" style="text-align: center; padding: 40px; opacity: 0.5;">No activity logged yet.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<style>
    /* Custom Scrollbar for the table and alerts */
    .card div::-webkit-scrollbar {
        width: 6px;
    }
    .card div::-webkit-scrollbar-track {
        background: transparent;
    }
    .card div::-webkit-scrollbar-thumb {
        background: rgba(122, 92, 255, 0.2);
        border-radius: 10px;
    }
    .card div::-webkit-scrollbar-thumb:hover {
        background: rgba(122, 92, 255, 0.4);
    }
    
    /* Table hover effect */
    tbody tr:hover {
        background: rgba(122, 92, 255, 0.03) !important;
    }
    
    body.dark-mode tbody tr:hover {
        background: rgba(255, 255, 255, 0.03) !important;
    }
</style>
{% endblock %}
