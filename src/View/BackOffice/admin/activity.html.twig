{% extends 'BackOffice/base_back.html.twig' %}

{% block title %}Activity Monitor - Users Management{% endblock %}

{% block body %}
<div style="display: flex;">
    <aside class="sidebar">
        <div class="sidebar-header">
            Users<span>Panel</span>
        </div>
        <ul class="sidebar-menu">
            <li><a href="{{ path('app_admin_users') }}">👥 Users List</a></li>
            <li><a href="{{ path('app_admin_activity') }}" class="active">⚡ User Activity</a></li>
        </ul>
        
        <div style="margin-top: 30px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 20px;">
            <p style="color: #666; font-size: 12px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; margin-left: 20px;">Global Modules</p>
            <ul class="sidebar-menu">
                <li><a href="{{ path('app_admin_panel') }}">Dashboard</a></li>
                <li><a href="{{ path('app_admin_forum_dashboard') }}">Forum</a></li>
                <li><a href="{{ path('app_admin_startup_dashboard') }}">Startup</a></li>
                <li><a href="{{ path('app_admin_evaluation_dashboard') }}">Evaluation</a></li>
                <li><a href="{{ path('app_admin_mentorship') }}">Mentorship</a></li>
                <li><a href="{{ path('app_admin_reclamations') }}">Reclamation & Response</a></li>
            </ul>
        </div>
        
        <div class="sidebar-footer">
            <a href="{{ path('app_logout') }}" class="logout-btn glow-btn">Sign Out</a>
        </div>
    </aside>

    <div class="main-content">
        <header class="topbar">
            <div class="topbar-left">
                <h2>Users Management</h2>
            </div>
            <div class="topbar-right" style="display: flex; align-items: center; gap: 10px;">
                <a href="{{ path('app_admin_activity_export_pdf') }}" class="btn-pill" style="border: 2px solid #b58bff; background: transparent; color: #b58bff; text-decoration: none; padding: 5px 15px; border-radius: 20px; font-weight: bold; font-size: 14px; transition: all 0.3s; box-shadow: 0 0 10px rgba(181,139,255,0.2);">📄 Export PDF</a>
                <a href="{{ path('app_admin_activity_export_excel') }}" class="btn-pill" style="border: 2px solid #00ff87; background: transparent; color: #00ff87; text-decoration: none; padding: 5px 15px; border-radius: 20px; font-weight: bold; font-size: 14px; transition: all 0.3s; box-shadow: 0 0 10px rgba(0,255,135,0.2);">📊 Export Excel</a>
                <button onclick="window.location.reload();" class="btn-pill" style="border: 2px solid var(--primary-color); background: transparent; color: var(--primary-color); padding: 5px 15px; border-radius: 20px; font-weight: bold; font-size: 14px; transition: all 0.3s; cursor: pointer; box-shadow: 0 0 10px rgba(79,172,254,0.2);">🔄 Refresh Tracker</button>
                <div class="user-profile">
                    <div class="avatar" style="background-color: var(--primary);">
                        <span style="color: white; font-weight: bold;">A</span>
                    </div>
                    <span>Admin</span>
                </div>
            </div>
        </header>

        <main class="dashboard-content" style="position: relative; z-index: 2;">
            <div style="padding: 20px;">
                <h3 class="page-title" style="margin-bottom: 20px;">FrontOffice Activity Monitor</h3>

                <!-- Analytics Summary Cards -->
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 30px;">
                    <!-- Top Active Users -->
                    <div class="card" style="background: rgba(30, 30, 40, 0.7);">
                        <h3 style="color: var(--primary-light); margin-bottom: 15px;">🏆 Top Active Users</h3>
                        <ul style="list-style: none; padding: 0; margin: 0;">
                            {% for userStat in mostActiveUsers %}
                            <li style="padding: 10px; border-bottom: 1px solid rgba(255,255,255,0.1); display:flex; justify-content:space-between;">
                                <span>User ID #{{ userStat.userId }}</span>
                                <strong style="color:var(--primary-color);">{{ userStat.activityCount }} actions</strong>
                            </li>
                            {% else %}
                            <li style="color: #888;">No user activity yet.</li>
                            {% endfor %}
                        </ul>
                    </div>

                    <!-- Most Visited Pages -->
                    <div class="card" style="background: rgba(30, 30, 40, 0.7);">
                        <h3 style="color: var(--primary-light); margin-bottom: 15px;">🔥 Most Visited Pages</h3>
                        <ul style="list-style: none; padding: 0; margin: 0;">
                            {% for pageStat in mostVisitedPages %}
                            <li style="padding: 10px; border-bottom: 1px solid rgba(255,255,255,0.1); display:flex; justify-content:space-between;">
                                <span style="font-family: monospace; font-size: 0.9em; word-break: break-all; margin-right: 10px;">{{ pageStat.pageUrl }}</span>
                                <strong style="color:var(--primary-color);">{{ pageStat.visitCount }} views</strong>
                            </li>
                            {% else %}
                            <li style="color: #888;">No page visits yet.</li>
                            {% endfor %}
                        </ul>
                    </div>

                    <!-- Security Alerts -->
                    <div class="card" style="background: rgba(255, 50, 50, 0.1); border: 1px solid rgba(255, 50, 50, 0.3);">
                        <h3 style="color: #ff6b6b; margin-bottom: 15px;">⚠️ Recent Security Alerts</h3>
                        <ul style="list-style: none; padding: 0; margin: 0; max-height: 200px; overflow-y: auto;">
                            {% for alert in securityAlerts %}
                            <li style="padding: 10px; border-bottom: 1px solid rgba(255,50,50,0.2);">
                                <div style="display:flex; justify-content:space-between; margin-bottom: 5px;">
                                    <strong style="color: #ff6b6b;">{{ alert.actionType }}</strong>
                                    <span style="font-size: 0.8em; color: #888;">{{ alert.createdAt|date('Y-m-d H:i:s') }}</span>
                                </div>
                                <div style="font-size: 0.9em; color: #ccc;">{{ alert.description }}</div>
                                <div style="font-size: 0.8em; color: #888; margin-top: 5px;">IP: {{ alert.ipAddress|default('Unknown') }}</div>
                            </li>
                            {% else %}
                            <li style="color: #888;">No security alerts detected.</li>
                            {% endfor %}
                        </ul>
                    </div>
                </div>

                <!-- Live Activity Log Table -->
                <div class="table-container" style="background: rgba(20, 20, 30, 0.8); border-radius: 15px; padding: 20px;">
                    <h3 style="margin-bottom: 20px; color: white;">Live Action Log</h3>
                    <table class="data-table" style="width: 100%; text-align: left; border-collapse: collapse;">
                        <thead>
                            <tr style="border-bottom: 2px solid var(--primary-color);">
                                <th style="padding: 12px;">Time</th>
                                <th style="padding: 12px;">User ID</th>
                                <th style="padding: 12px;">Action</th>
                                <th style="padding: 12px;">Page / Description</th>
                                <th style="padding: 12px;">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for log in recentActivities %}
                            <tr style="border-bottom: 1px solid rgba(255,255,255,0.05); transition: background 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.05)'" onmouseout="this.style.background='transparent'">
                                <td style="padding: 12px; color: #aaa; font-size: 0.9em;">{{ log.createdAt|date('Y-m-d H:i:s') }}</td>
                                <td style="padding: 12px;">
                                    {% if log.user %}
                                        <span style="background: rgba(255,255,255,0.1); padding: 3px 8px; border-radius: 12px;">{{ log.user.id }}</span>
                                    {% else %}
                                        <span style="color: #666; font-style: italic;">Guest / System</span>
                                    {% endif %}
                                </td>
                                <td style="padding: 12px;">
                                    {% if log.actionType == 'VIEW_PAGE' %}
                                        <span style="color: #4facfe;">👁️ VIEW</span>
                                    {% elseif log.actionType == 'LOGIN' %}
                                        <span style="color: #00f2fe;">🔑 LOGIN</span>
                                    {% elseif log.actionType == 'LOGOUT' %}
                                        <span style="color: #f77062;">🚪 LOGOUT</span>
                                    {% elseif log.actionType == 'LOGIN_FAILED' %}
                                        <span style="color: #ff0844;">⚠️ FAILED</span>
                                    {% else %}
                                        <span style="color: #b58bff;">⚡ {{ log.actionType }}</span>
                                    {% endif %}
                                </td>
                                <td style="padding: 12px; font-size: 0.9em; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                    {% if log.page %}
                                        <code style="color: #aaa;">{{ log.page }}</code><br>
                                    {% endif %}
                                    {% if log.description %}
                                        <span style="color: #ccc;">{{ log.description }}</span>
                                    {% endif %}
                                </td>
                                <td style="padding: 12px;">
                                    {% if log.status == 'SUCCESS' %}
                                        <span style="color: #00ff87; font-weight: bold;">● SUCCESS</span>
                                    {% else %}
                                        <span style="color: #ff0055; font-weight: bold;">● {{ log.status }}</span>
                                    {% endif %}
                                </td>
                            </tr>
                            {% else %}
                            <tr>
                                <td colspan="5" style="text-align: center; padding: 20px; color: #888;">No activity logged yet.</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
        <footer class="futuristic-footer" style="padding: 20px; text-align: center; border-top: 1px solid rgba(255, 255, 255, 0.1);">
            <p style="color: #b0a8d6;">&copy; {{ 'now'|date('Y') }} StartupFlow Admin.</p>
        </footer>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        if (localStorage.getItem('admin_theme') === 'dark') {
            document.body.classList.add('dark-mode');
        }
    });
</script>
{% endblock %}

