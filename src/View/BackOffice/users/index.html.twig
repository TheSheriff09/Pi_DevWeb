{% extends 'BackOffice/base_back.html.twig' %}

{% block title %}Users Management - Admin{% endblock %}

{% block header_title %}Users Management{% endblock %}

{% block body %}
<div class="card" style="width: 100%; padding: 25px;">
    <div style="display: flex; justify-content: flex-start; align-items: center; gap: 30px; margin-bottom: 25px;">
        <h3 style="margin: 0; color: var(--primary); font-size: 1.3rem;">Platform Users</h3>
        
        <div style="position: relative;">
            <span style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); opacity: 0.5; font-size: 14px;">🔍</span>
            <input type="text" id="searchIdInput" placeholder="Search by ID..." style="padding: 10px 15px 10px 35px; border-radius: 12px; border: 1px solid rgba(128, 128, 128, 0.2); background: rgba(0, 0, 0, 0.05); color: var(--text-main); outline: none; width: 250px; font-family: inherit; font-size: 0.9rem; transition: all 0.3s;">
        </div>
        
        <a href="{{ path('app_admin_users_charts') }}" class="btn-pill" style="border: 2px solid #b58bff; background: transparent; color: #b58bff; text-decoration: none; padding: 10px 25px; border-radius: 20px; font-weight: bold; font-size: 14px; transition: all 0.3s; margin-left: auto; display: flex; align-items: center; gap: 8px;">
            <span>📊</span> Analytics Charts
        </a>
    </div>

    <div style="overflow-x: auto; border-radius: 12px; border: 1px solid rgba(128, 128, 128, 0.1);">
        <table style="width: 100%; border-collapse: collapse; text-align: left;" id="usersTable">
            <thead>
                <tr style="background: rgba(122, 92, 255, 0.05); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;">
                    <th style="padding: 15px 20px; color: var(--primary); cursor: pointer;" class="sortable" data-sort="id">ID <span>&#9650;</span></th>
                    <th style="padding: 15px 20px; color: var(--primary); cursor: pointer;" class="sortable" data-sort="fullName">Full Name <span></span></th>
                    <th style="padding: 15px 20px; color: var(--primary); cursor: pointer;" class="sortable" data-sort="email">Email <span></span></th>
                    <th style="padding: 15px 20px; color: var(--primary); cursor: pointer;" class="sortable" data-sort="role">Role <span></span></th>
                    <th style="padding: 15px 20px; color: var(--primary); cursor: pointer;" class="sortable" data-sort="createdAt">Created At <span></span></th>
                    <th style="padding: 15px 20px; color: var(--primary); cursor: pointer;" class="sortable" data-sort="status">Status <span></span></th>
                </tr>
            </thead>
            <tbody id="usersTableBody" style="font-size: 0.9rem;">
                {% include 'BackOffice/users/_users_tbody.html.twig' %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
    document.addEventListener("DOMContentLoaded", function() {
        // AJAX Sorting and Searching
        let currentSort = 'id';
        let currentDirection = 'ASC';
        const searchInput = document.getElementById('searchIdInput');
        const tableBody = document.getElementById('usersTableBody');
        const sortableHeaders = document.querySelectorAll('.sortable');

        function fetchUsers() {
            const searchId = searchInput.value;
            const params = new URLSearchParams({
                sort: currentSort,
                direction: currentDirection
            });
            
            if (searchId) {
                params.append('searchId', searchId);
            }

            fetch(`{{ path('app_admin_users_ajax') }}?${params.toString()}`, {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.text())
            .then(html => {
                tableBody.innerHTML = html;
            })
            .catch(error => console.error('Error fetching users:', error));
        }

        // Search by ID
        let debounceTimer;
        searchInput.addEventListener('input', () => {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(() => {
                fetchUsers();
            }, 300);
        });

        // Sorting
        sortableHeaders.forEach(header => {
            header.addEventListener('click', () => {
                const sortProperty = header.getAttribute('data-sort');
                
                if (currentSort === sortProperty) {
                    currentDirection = currentDirection === 'ASC' ? 'DESC' : 'ASC';
                } else {
                    currentSort = sortProperty;
                    currentDirection = 'ASC';
                }

                // Update header icons
                sortableHeaders.forEach(h => {
                    const span = h.querySelector('span');
                    if (span) span.innerHTML = '';
                });

                const activeSpan = header.querySelector('span');
                if (activeSpan) {
                    activeSpan.innerHTML = currentDirection === 'ASC' ? '&#9650;' : '&#9660;';
                }

                fetchUsers();
            });
        });
    });
</script>

<style>
    /* Table hover effect */
    tbody tr {
        border-bottom: 1px solid rgba(128,128,128,0.1);
        transition: background 0.3s;
    }
    tbody tr:hover {
        background: rgba(122, 92, 255, 0.03) !important;
    }
    body.dark-mode tbody tr:hover {
        background: rgba(255, 255, 255, 0.03) !important;
    }
    
    /* Search input focus */
    #searchIdInput:focus {
        border-color: var(--primary) !important;
        background: rgba(0, 0, 0, 0.08) !important;
        box-shadow: 0 0 0 4px rgba(122, 92, 255, 0.1);
    }
</style>
{% endblock %}
