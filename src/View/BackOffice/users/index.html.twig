<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Users Management</title>
    <link rel="stylesheet" href="{{ asset('Back/css/styles.css') }}?v=2">
</head>
<body>
    <script>
        if (localStorage.getItem('admin_theme') === 'dark') {
            document.body.classList.add('dark-mode');
        }
    </script>

    <aside class="sidebar">
        <div class="sidebar-header">
            Admin<span>Panel</span>
        </div>
        <ul class="sidebar-menu">
            <li><a href="{{ path('app_admin_panel') }}">Dashboard</a></li>
            <li><a href="{{ path('app_admin_forum_dashboard') }}">Forum</a></li>
            <li><a href="{{ path('app_admin_startup_dashboard') }}">Startup</a></li>
            <li><a href="{{ path('app_admin_evaluation_dashboard') }}">Evaluation</a></li>
            <li><a href="{{ path('app_admin_users') }}" class="active">Users</a></li>
            <li><a href="{{ path('app_admin_mentorship') }}">Mentorship</a></li>
            <li><a href="{{ path('app_admin_reclamations') }}">Reclamation & Response</a></li>
        </ul>
        <div class="sidebar-footer">
            <a href="{{ path('app_logout') }}" class="logout-btn glow-btn">Sign Out</a>
        </div>
    </aside>

    <div class="main-content">
        <header class="topbar">
            <div class="topbar-left">
                <h2>Users Management</h2>
            </div>
            <div class="topbar-right">
                <button id="themeToggleBtn" class="btn-pill" style="border: 2px solid var(--primary-light); background: transparent; color: var(--primary-light);">🌓</button>
                <div class="user-profile">
                    <div class="avatar" style="background-color: var(--primary);">
                        <span style="color: white; font-weight: bold;">A</span>
                    </div>
                    <span>Admin</span>
                </div>
            </div>
        </header>

        <main class="dashboard-content" style="position: relative; z-index: 2;">
            
            <div class="card" style="width: 100%;">
                <h3 style="margin-bottom: 20px; color: var(--primary-lighter);">Platform Users</h3>
                <div style="overflow-x: auto;">
                    <table style="width: 100%; border-collapse: collapse; text-align: left;">
                        <thead>
                            <tr style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                                <th style="padding: 15px; color: #b0a8d6;">Full Name</th>
                                <th style="padding: 15px; color: #b0a8d6;">Email</th>
                                <th style="padding: 15px; color: #b0a8d6;">Role</th>
                                <th style="padding: 15px; color: #b0a8d6;">Created At</th>
                                <th style="padding: 15px; color: #b0a8d6;">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for user in users %}
                                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                    <td style="padding: 15px; font-weight: 500;">
                                        <span style="display: flex; align-items: center; gap: 10px;">
                                            <div style="width: 30px; height: 30px; border-radius: 50%; background: var(--primary); color: white; display: flex; align-items: center; justify-content: center; font-weight: bold;">
                                                {{ user.fullName|slice(0, 1)|upper }}
                                            </div>
                                            {{ user.fullName }}
                                        </span>
                                    </td>
                                    <td style="padding: 15px;">{{ user.email }}</td>
                                    <td style="padding: 15px;">
                                        <span style="background: rgba(111, 86, 255, 0.2); color: #b58bff; padding: 4px 8px; border-radius: 12px; font-size: 0.8rem; font-weight: bold;">
                                            {{ user.role }}
                                        </span>
                                    </td>
                                    <td style="padding: 15px; color: #b0a8d6;">{{ user.createdAt|date('Y-m-d') }}</td>
                                    <td style="padding: 15px;">
                                        {% if user.role|upper != 'ADMIN' %}
                                            <form action="{{ path('app_admin_users_status', {id: user.id}) }}" method="POST" style="margin: 0;">
                                                <select name="status" onchange="this.form.submit()" style="padding: 6px; border-radius: 4px; border: 1px solid {% if user.status == 'ACTIVE' %}rgba(76, 209, 55, 0.5){% else %}rgba(255, 50, 50, 0.5){% endif %}; background: #2a2b42; color: #fff; cursor: pointer; outline: none; transition: border-color 0.2s;">
                                                    <option value="ACTIVE" {% if user.status == 'ACTIVE' %}selected{% endif %}>Active</option>
                                                    <option value="BLOCKED" {% if user.status == 'BLOCKED' %}selected{% endif %}>Blocked</option>
                                                </select>
                                            </form>
                                        {% else %}
                                            <span style="padding: 6px; color: #4cd137; font-weight: bold; display: inline-block;">SUPERADMIN</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="5" style="padding: 15px; text-align: center; color: #b0a8d6;">No users found.</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
            
        </main>
        
        <footer class="futuristic-footer" style="padding: 20px; text-align: center; border-top: 1px solid rgba(255, 255, 255, 0.1);">
            <p style="color: #b0a8d6;">&copy; {{ 'now'|date('Y') }} StartupFlow Admin.</p>
        </footer>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const toggleBtn = document.getElementById('themeToggleBtn');
            if (toggleBtn) {
                toggleBtn.addEventListener('click', () => {
                    const isDark = document.body.classList.contains('dark-mode');
                    if (isDark) {
                        document.body.classList.remove('dark-mode');
                        localStorage.setItem('admin_theme', 'light');
                    } else {
                        document.body.classList.add('dark-mode');
                        localStorage.setItem('admin_theme', 'dark');
                    }
                });
            }
        });
    </script>
</body>
</html>
