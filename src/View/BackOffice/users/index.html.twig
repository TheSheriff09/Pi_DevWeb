<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Users Management</title>
    <link rel="stylesheet" href="{{ asset('Back/css/styles.css') }}?v=2">
</head>
<body>
    <script>
        if (localStorage.getItem('admin_theme') === 'dark') {
            document.body.classList.add('dark-mode');
        }
    </script>

    <aside class="sidebar">
        <div class="sidebar-header">
            Admin<span>Panel</span>
        </div>
        <ul class="sidebar-menu">
            <li><a href="{{ path('app_admin_panel') }}">Dashboard</a></li>
            <li><a href="{{ path('app_admin_forum_dashboard') }}">Forum</a></li>
            <li><a href="{{ path('app_admin_startup_dashboard') }}">Startup</a></li>
            <li><a href="{{ path('app_admin_evaluation_dashboard') }}">Evaluation</a></li>
            <li><a href="{{ path('app_admin_users') }}" class="active">Users</a></li>
            <li><a href="{{ path('app_admin_mentorship') }}">Mentorship</a></li>
            <li><a href="{{ path('app_admin_reclamations') }}">Reclamation & Response</a></li>
        </ul>
        <div class="sidebar-footer">
            <a href="{{ path('app_logout') }}" class="logout-btn glow-btn">Sign Out</a>
        </div>
    </aside>

    <div class="main-content">
        <header class="topbar">
            <div class="topbar-left">
                <h2>Users Management</h2>
            </div>
            <div class="topbar-right">
                <button id="themeToggleBtn" class="btn-pill" style="border: 2px solid var(--primary-light); background: transparent; color: var(--primary-light);">🌓</button>
                <div class="user-profile">
                    <div class="avatar" style="background-color: var(--primary);">
                        <span style="color: white; font-weight: bold;">A</span>
                    </div>
                    <span>Admin</span>
                </div>
            </div>
        </header>

        <main class="dashboard-content" style="position: relative; z-index: 2;">
            
            <div class="card" style="width: 100%;">
                <div style="display: flex; justify-content: flex-start; align-items: center; gap: 30px; margin-bottom: 20px;">
                    <h3 style="margin: 0; color: var(--primary-lighter);">Platform Users</h3>
                    
                    <div style="position: relative;">
                        <span style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.5); font-size: 14px;">🔍</span>
                        <input type="text" id="searchIdInput" placeholder="Search by ID..." style="padding: 10px 15px 10px 35px; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.1); background: rgba(0, 0, 0, 0.2); color: #fff; outline: none; width: 250px; font-family: inherit; font-size: 0.9rem; transition: border-color 0.3s;">
                    </div>
                </div>
                <div style="overflow-x: auto;">
                    <table style="width: 100%; border-collapse: collapse; text-align: left;" id="usersTable">
                        <thead>
                            <tr style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                                <th style="padding: 15px; color: #b0a8d6; cursor: pointer;" class="sortable" data-sort="id">ID <span>&#9650;</span></th>
                                <th style="padding: 15px; color: #b0a8d6; cursor: pointer;" class="sortable" data-sort="fullName">Full Name <span></span></th>
                                <th style="padding: 15px; color: #b0a8d6; cursor: pointer;" class="sortable" data-sort="email">Email <span></span></th>
                                <th style="padding: 15px; color: #b0a8d6; cursor: pointer;" class="sortable" data-sort="role">Role <span></span></th>
                                <th style="padding: 15px; color: #b0a8d6; cursor: pointer;" class="sortable" data-sort="createdAt">Created At <span></span></th>
                                <th style="padding: 15px; color: #b0a8d6; cursor: pointer;" class="sortable" data-sort="status">Status <span></span></th>
                            </tr>
                        </thead>
                        <tbody id="usersTableBody">
                            {% include 'BackOffice/users/_users_tbody.html.twig' %}
                        </tbody>
                    </table>
                </div>
            </div>
            
        </main>
        
        <footer class="futuristic-footer" style="padding: 20px; text-align: center; border-top: 1px solid rgba(255, 255, 255, 0.1);">
            <p style="color: #b0a8d6;">&copy; {{ 'now'|date('Y') }} StartupFlow Admin.</p>
        </footer>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const toggleBtn = document.getElementById('themeToggleBtn');
            if (toggleBtn) {
                toggleBtn.addEventListener('click', () => {
                    const isDark = document.body.classList.contains('dark-mode');
                    if (isDark) {
                        document.body.classList.remove('dark-mode');
                        localStorage.setItem('admin_theme', 'light');
                    } else {
                        document.body.classList.add('dark-mode');
                        localStorage.setItem('admin_theme', 'dark');
                    }
                });
            }

            // AJAX Sorting and Searching
            let currentSort = 'id';
            let currentDirection = 'ASC';
            const searchInput = document.getElementById('searchIdInput');
            const tableBody = document.getElementById('usersTableBody');
            const sortableHeaders = document.querySelectorAll('.sortable');

            function fetchUsers() {
                const searchId = searchInput.value;
                const params = new URLSearchParams({
                    sort: currentSort,
                    direction: currentDirection
                });
                
                if (searchId) {
                    params.append('searchId', searchId);
                }

                fetch(`{{ path('app_admin_users_ajax') }}?${params.toString()}`, {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => response.text())
                .then(html => {
                    tableBody.innerHTML = html;
                })
                .catch(error => console.error('Error fetching users:', error));
            }

            // Search by ID
            let debounceTimer;
            searchInput.addEventListener('input', () => {
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(() => {
                    fetchUsers();
                }, 300);
            });

            // Sorting
            sortableHeaders.forEach(header => {
                header.addEventListener('click', () => {
                    const sortProperty = header.getAttribute('data-sort');
                    
                    if (currentSort === sortProperty) {
                        currentDirection = currentDirection === 'ASC' ? 'DESC' : 'ASC';
                    } else {
                        currentSort = sortProperty;
                        currentDirection = 'ASC';
                    }

                    // Update header icons
                    sortableHeaders.forEach(h => {
                        const span = h.querySelector('span');
                        if (span) span.innerHTML = '';
                    });

                    const activeSpan = header.querySelector('span');
                    if (activeSpan) {
                        activeSpan.innerHTML = currentDirection === 'ASC' ? '&#9650;' : '&#9660;';
                    }

                    fetchUsers();
                });
            });
        });
    </script>
</body>
</html>
