<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - User Analytics Charts</title>
    <link rel="stylesheet" href="{{ asset('Back/css/styles.css') }}?v=2">
</head>
<body>
    <script>
        if (localStorage.getItem('admin_theme') === 'dark') {
            document.body.classList.add('dark-mode');
        }
    </script>

    <aside class="sidebar">
        <div class="sidebar-header">
            Users<span>Panel</span>
        </div>
        <ul class="sidebar-menu">
            <li><a href="{{ path('app_admin_users') }}">👥 Users List</a></li>
            <li><a href="{{ path('app_admin_activity') }}">⚡ User Activity</a></li>
        </ul>
        
        <div style="margin-top: 30px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 20px;">
            <p style="color: #666; font-size: 12px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; margin-left: 20px;">Global Modules</p>
            <ul class="sidebar-menu">
                <li><a href="{{ path('app_admin_panel') }}">Dashboard</a></li>
                <li><a href="{{ path('app_admin_forum_dashboard') }}">Forum</a></li>
                <li><a href="{{ path('app_admin_startup_dashboard') }}">Startup</a></li>
                <li><a href="{{ path('app_admin_evaluation_dashboard') }}">Evaluation</a></li>
                <li><a href="{{ path('app_admin_mentorship') }}">Mentorship</a></li>
                <li><a href="{{ path('app_admin_reclamations') }}">Reclamation & Response</a></li>
            </ul>
        </div>
        
        <div class="sidebar-footer">
            <a href="{{ path('app_logout') }}" class="logout-btn glow-btn">Sign Out</a>
        </div>
    </aside>

    <div class="main-content">
        <header class="topbar">
            <div class="topbar-left">
                <h2>Users Management</h2>
            </div>
            <div class="topbar-right">
                <button id="themeToggleBtn" class="btn-pill" style="border: 2px solid var(--primary-light); background: transparent; color: var(--primary-light);">🌓</button>
                <div class="user-profile">
                    <div class="avatar" style="background-color: var(--primary);">
                        <span style="color: white; font-weight: bold;">A</span>
                    </div>
                    <span>Admin</span>
                </div>
            </div>
        </header>

        <main class="dashboard-content" style="position: relative; z-index: 2;">
            
            <div class="card" style="width: 100%; margin-bottom: 30px; padding: 30px;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h3 style="margin: 0; color: var(--primary-lighter);">Platform Activity Analytics</h3>
                    
                    <div style="display: flex; gap: 15px; align-items: center;">
                        <button id="refreshBtn" onclick="window.location.reload();" class="btn-pill" style="border: 2px solid var(--primary-color); background: transparent; color: var(--primary-color); cursor: pointer; padding: 8px 15px; font-weight: bold; transition: all 0.3s;">
                            <span id="refreshIcon">🔄</span> Refresh
                        </button>
                        
                        <form id="daysFilterForm" method="GET" style="display: flex; align-items: center; gap: 10px; margin: 0;">
                            <label for="days" style="color: #b0a8d6; font-weight: bold;">Timeframe:</label>
                            <select name="days" id="days" onchange="document.getElementById('daysFilterForm').submit();" style="padding: 8px 12px; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.1); background: rgba(0, 0, 0, 0.2); color: #fff; outline: none; font-family: inherit;">
                                <option value="7" {% if days == 7 %}selected{% endif %}>Last 7 Days</option>
                                <option value="30" {% if days == 30 %}selected{% endif %}>Last 30 Days</option>
                                <option value="90" {% if days == 90 %}selected{% endif %}>Last 90 Days</option>
                            </select>
                        </form>
                    </div>
                </div>

                <!-- CHARTS GRID -->
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 30px; margin-top: 20px;">
                    
                    <div style="background: rgba(0,0,0,0.1); border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; padding: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                        <div id="div_line_chart" style="width: 100%; height: 300px;"></div>
                    </div>

                    <div style="background: rgba(0,0,0,0.1); border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; padding: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                        <div id="div_bar_chart" style="width: 100%; height: 300px;"></div>
                    </div>

                    <div style="background: rgba(0,0,0,0.1); border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; padding: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                        <div id="div_pie_chart" style="width: 100%; height: 300px;"></div>
                    </div>

                    <div style="background: rgba(0,0,0,0.1); border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; padding: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                        <div id="div_users_chart" style="width: 100%; height: 300px;"></div>
                    </div>

                </div>
            </div>
            
        </main>
        
        <footer class="futuristic-footer" style="padding: 20px; text-align: center; border-top: 1px solid rgba(255, 255, 255, 0.1);">
            <p style="color: #b0a8d6;">&copy; {{ 'now'|date('Y') }} StartupFlow Admin.</p>
        </footer>
    </div>

    <script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
    <script type="text/javascript">
        {{ gc_draw(lineChart, 'div_line_chart') }}
        {{ gc_draw(barChart, 'div_bar_chart') }}
        {{ gc_draw(pieChart, 'div_pie_chart') }}
        {{ gc_draw(usersChart, 'div_users_chart') }}

        document.addEventListener("DOMContentLoaded", function() {
            const toggleBtn = document.getElementById('themeToggleBtn');
            if (toggleBtn) {
                toggleBtn.addEventListener('click', () => {
                    const isDark = document.body.classList.contains('dark-mode');
                    if (isDark) {
                        document.body.classList.remove('dark-mode');
                        localStorage.setItem('admin_theme', 'light');
                    } else {
                        document.body.classList.add('dark-mode');
                        localStorage.setItem('admin_theme', 'dark');
                    }
                });
            }
        });
    </script>
</body>
</html>
