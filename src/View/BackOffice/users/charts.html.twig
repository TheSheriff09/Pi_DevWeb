{% extends 'BackOffice/base_back.html.twig' %}

{% block title %}User Analytics Charts - Admin{% endblock %}

{% block header_title %}Analytics Charts{% endblock %}

{% block body %}
<div class="card" style="width: 100%; padding: 30px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
        <h3 style="margin: 0; color: var(--primary); font-size: 1.3rem;">Platform Activity Analytics</h3>
        
        <div style="display: flex; gap: 15px; align-items: center;">
            <button onclick="window.location.reload();" class="btn-pill" style="border: 2px solid var(--primary); background: transparent; color: var(--primary); cursor: pointer; padding: 8px 20px; font-weight: bold; transition: all 0.3s;">
                <span>🔄</span> Refresh
            </button>
            
            <form id="daysFilterForm" method="GET" style="display: flex; align-items: center; gap: 10px; margin: 0;">
                <label for="days" style="opacity: 0.7; font-weight: 600; font-size: 0.9rem;">Timeframe:</label>
                <select name="days" id="days" onchange="document.getElementById('daysFilterForm').submit();" style="padding: 8px 12px; border-radius: 12px; border: 1px solid rgba(128, 128, 128, 0.2); background: rgba(0, 0, 0, 0.05); color: var(--text-main); outline: none; font-family: inherit; font-size: 0.9rem; cursor: pointer;">
                    <option value="7" {% if days == 7 %}selected{% endif %}>Last 7 Days</option>
                    <option value="30" {% if days == 30 %}selected{% endif %}>Last 30 Days</option>
                    <option value="90" {% if days == 90 %}selected{% endif %}>Last 90 Days</option>
                </select>
            </form>
        </div>
    </div>

    <!-- CHARTS GRID -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(450px, 1fr)); gap: 30px; margin-top: 10px;">
        
        <div class="card" style="background: rgba(122, 92, 255, 0.02); border: 1px solid rgba(122, 92, 255, 0.1); padding: 25px;">
            <div id="div_line_chart" style="width: 100%; height: 350px;"></div>
        </div>

        <div class="card" style="background: rgba(122, 92, 255, 0.02); border: 1px solid rgba(122, 92, 255, 0.1); padding: 25px;">
            <div id="div_bar_chart" style="width: 100%; height: 350px;"></div>
        </div>

        <div class="card" style="background: rgba(122, 92, 255, 0.02); border: 1px solid rgba(122, 92, 255, 0.1); padding: 25px;">
            <div id="div_pie_chart" style="width: 100%; height: 350px;"></div>
        </div>

        <div class="card" style="background: rgba(122, 92, 255, 0.02); border: 1px solid rgba(122, 92, 255, 0.1); padding: 25px;">
            <div id="div_users_chart" style="width: 100%; height: 350px;"></div>
        </div>

    </div>
</div>
{% endblock %}

{% block javascripts %}
<script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
<script type="text/javascript">
    {{ gc_draw(lineChart, 'div_line_chart') }}
    {{ gc_draw(barChart, 'div_bar_chart') }}
    {{ gc_draw(pieChart, 'div_pie_chart') }}
    {{ gc_draw(usersChart, 'div_users_chart') }}
</script>

<style>
    /* Ensure charts look good in dark mode by adjusting some internal SVG colors if needed */
    /* Note: Google Charts colors were already adjusted in the controller */
    .card:hover {
        transform: none !important; /* Disable hover lift for chart cards to avoid flickering */
    }
</style>
{% endblock %}
