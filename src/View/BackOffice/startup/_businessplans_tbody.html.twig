{% for bp in businessPlans %}
    <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
        <td style="padding: 15px;">{{ bp.businessPlanID }}</td>
        <td style="padding: 15px; font-weight: 500;">{{ bp.title }}</td>
        <td style="padding: 15px;">{{ bp.creationDate ? bp.creationDate|date('Y-m-d') : 'N/A' }}</td>
        <td style="padding: 15px;">${{ bp.fundingRequired|number_format(2) }}</td>
        <td style="padding: 15px;">
            <span style="padding: 4px 10px; border-radius: 20px; font-size: 0.8rem; background: rgba(255,255,255,0.1); color: #fff;">{{ bp.status ?: 'Pending' }}</span>
        </td>
        <td style="padding: 15px;">
            <div class="action-btns">
                <a href="{{ path('app_admin_startup_businessplan_edit', {'id': bp.businessPlanID}) }}" class="btn-edit">Edit</a>
                <form method="post" action="{{ path('app_admin_startup_businessplan_delete', {'id': bp.businessPlanID}) }}" onsubmit="return confirm('Are you sure you want to delete this business plan?');" style="display:inline-block; margin:0;">
                    <button class="btn-delete" type="submit">Delete</button>
                </form>
            </div>
        </td>
    </tr>
{% else %}
    <tr>
        <td colspan="6" style="padding: 15px; text-align: center; color: #b0a8d6;">No business plans found.</td>
    </tr>
{% endfor %}
