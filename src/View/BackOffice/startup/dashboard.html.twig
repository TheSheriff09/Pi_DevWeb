<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Startup Admin - Dashboard</title>
    <link rel="stylesheet" href="{{ asset('Back/css/styles.css') }}?v=2">
</head>
<body>
    <script>
        if (localStorage.getItem('admin_theme') === 'dark') {
            document.body.classList.add('dark-mode');
        }
    </script>

    <!-- SIDEBAR FOR STARTUP MODULE -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <h2>Startup Admin</h2>
        </div>
        <ul class="sidebar-menu">
            <li><a href="{{ path('app_admin_panel') }}" style="color: #ff9d9d;">&larr; Main Admin</a></li>
            <li><a href="{{ path('app_admin_startup_dashboard') }}" class="{{ current_menu == 'dashboard' ? 'active' : '' }}">Dashboard</a></li>
            <li><a href="{{ path('app_admin_startup_startups') }}" class="{{ current_menu == 'startups' ? 'active' : '' }}">Manage Startups</a></li>
            <li><a href="{{ path('app_admin_startup_businessplans') }}" class="{{ current_menu == 'businessplans' ? 'active' : '' }}">Manage Business Plans</a></li>
                    <li style="margin-top:20px; border-top:1px solid rgba(255,255,255,0.1); padding-top:10px;"><a href="{{ path('app_admin_panel') }}" style="color:var(--primary-light);">Global Modules</a></li>
            <li><a href="{{ path('app_admin_forum_dashboard') }}">Forum</a></li>
            <li><a href="{{ path('app_admin_startup_dashboard') }}">Startup</a></li>
            <li><a href="{{ path('app_admin_evaluation_dashboard') }}">Evaluation</a></li>
            <li><a href="{{ path('app_admin_users') }}">Users</a></li>
            <li><a href="{{ path('app_admin_mentorship') }}">Mentorship</a></li>
            <li><a href="{{ path('app_admin_reclamations') }}">Reclamation & Response</a></li>
        </ul>
        <div class="sidebar-footer">
            <a href="{{ path('app_logout') }}" class="logout-btn glow-btn">Sign Out</a>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <div class="main-content">
        <!-- TOPBAR -->
        <header class="topbar">
            <div class="topbar-left">
                <h2>Overview</h2>
            </div>
            <div class="topbar-right">
                <button id="themeToggleBtn" class="btn-pill" style="border: 2px solid var(--primary-light); background: transparent; color: var(--primary-light);">🌓</button>
                <div class="user-profile">
                    <div class="avatar" style="background-color: var(--primary);">
                        <span style="color: white; font-weight: bold;">A</span>
                    </div>
                    <span>Admin</span>
                </div>
            </div>
        </header>

        <!-- DASHBOARD SPECIFIC CONTENT -->
        <main class="dashboard-content" style="position: relative; z-index: 2;">
            
            <div class="dashboard-cards" style="margin-bottom: 40px;">
                <div class="card">
                    <h3 style="font-size: 2.5rem; color: var(--primary-lighter);">{{ startupsCount }}</h3>
                    <p style="text-transform: uppercase; font-size: 0.9rem; letter-spacing: 1px;">Registered Startups</p>
                </div>
                <div class="card">
                    <h3 style="font-size: 2.5rem; color: #a18bff;">{{ businessPlansCount }}</h3>
                    <p style="text-transform: uppercase; font-size: 0.9rem; letter-spacing: 1px;">Business Plans</p>
                </div>
            </div>

            <div class="card" style="width: 100%;">
                <h3 style="margin-bottom: 20px; color: var(--primary-lighter);">Latest Registered Startups</h3>
                <div style="overflow-x: auto;">
                    <table style="width: 100%; border-collapse: collapse; text-align: left;">
                        <thead>
                            <tr style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                                <th style="padding: 15px; color: #b0a8d6;">ID</th>
                                <th style="padding: 15px; color: #b0a8d6;">Startup Name</th>
                                <th style="padding: 15px; color: #b0a8d6;">Sector</th>
                                <th style="padding: 15px; color: #b0a8d6;">Registration Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for startup in latestStartups %}
                                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                    <td style="padding: 15px;">{{ startup.startupID }}</td>
                                    <td style="padding: 15px; font-weight: 500;">{{ startup.name }}</td>
                                    <td style="padding: 15px;">{{ startup.sector }}</td>
                                    <td style="padding: 15px; color: #b0a8d6;">{{ startup.creationDate ? startup.creationDate|date('Y-m-d') : 'N/A' }}</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="4" style="padding: 15px; text-align: center; color: #b0a8d6;">No startups found.</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
            
        </main>
        
        <footer class="futuristic-footer" style="padding: 20px; text-align: center; border-top: 1px solid rgba(255, 255, 255, 0.1);">
            <p style="color: #b0a8d6;">&copy; {{ 'now'|date('Y') }} StartupFlow Admin.</p>
        </footer>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const toggleBtn = document.getElementById('themeToggleBtn');
            if (toggleBtn) {
                toggleBtn.addEventListener('click', () => {
                    const isDark = document.body.classList.contains('dark-mode');
                    if (isDark) {
                        document.body.classList.remove('dark-mode');
                        localStorage.setItem('admin_theme', 'light');
                    } else {
                        document.body.classList.add('dark-mode');
                        localStorage.setItem('admin_theme', 'dark');
                    }
                });
            }
        });
    </script>
</body>
</html>

