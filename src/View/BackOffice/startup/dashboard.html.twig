{% extends 'BackOffice/base_back.html.twig' %}

{% block title %}Startup Admin - Dashboard{% endblock %}

{% block header_title %}Startup Hub Overview{% endblock %}

{% block body %}
<div class="dashboard-cards" style="margin-bottom: 40px; display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 25px;">
    <div class="card glass-card" style="padding: 30px; background: rgba(111, 86, 255, 0.05); border-left: 5px solid var(--primary);">
        <h3 style="font-size: 3rem; color: var(--primary-lighter); margin: 0; line-height: 1;">{{ startupsCount }}</h3>
        <p style="text-transform: uppercase; font-size: 0.85rem; letter-spacing: 2px; opacity: 0.7; margin-top: 10px; font-weight: 600;">Active Startups</p>
    </div>
    <div class="card glass-card" style="padding: 30px; background: rgba(0, 242, 254, 0.05); border-left: 5px solid #00f2fe;">
        <h3 style="font-size: 3rem; color: #00f2fe; margin: 0; line-height: 1;">{{ businessPlansCount }}</h3>
        <p style="text-transform: uppercase; font-size: 0.85rem; letter-spacing: 2px; opacity: 0.7; margin-top: 10px; font-weight: 600;">Business Plans</p>
    </div>
</div>

<div class="card" style="width: 100%; padding: 30px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
        <h3 style="margin: 0; color: var(--primary); font-size: 1.3rem;">Latest Registered Startups</h3>
        <a href="{{ path('app_admin_startup_startups') }}" style="color: var(--primary); text-decoration: none; font-size: 0.9rem; font-weight: 600;">Manage All Startups &rarr;</a>
    </div>
    
    <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; text-align: left;">
            <thead>
                <tr style="background: rgba(122, 92, 255, 0.05); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;">
                    <th style="padding: 15px 20px;">Name</th>
                    <th style="padding: 15px 20px;">Sector</th>
                    <th style="padding: 15px 20px;">Stage</th>
                    <th style="padding: 15px 20px;">Date</th>
                    <th style="padding: 15px 20px;">Status</th>
                </tr>
            </thead>
            <tbody>
                {% for startup in latestStartups %}
                    <tr style="border-bottom: 1px solid rgba(128,128,128,0.1); transition: all 0.2s;">
                        <td style="padding: 15px 20px;">
                            <div style="font-weight: 600; color: var(--text-main);">{{ startup.name }}</div>
                            <small style="opacity: 0.5;">ID: #{{ startup.startupID }}</small>
                        </td>
                        <td style="padding: 15px 20px;">{{ startup.sector }}</td>
                        <td style="padding: 15px 20px;">
                            <span style="background: rgba(122, 92, 255, 0.1); color: var(--primary); padding: 4px 10px; border-radius: 6px; font-size: 0.75rem; font-weight: bold;">
                                {{ startup.stage }}
                            </span>
                        </td>
                        <td style="padding: 15px 20px; opacity: 0.7; font-size: 0.85rem;">{{ startup.creationDate|date('Y-m-d') }}</td>
                        <td style="padding: 15px 20px;">
                            {% set status = startup.status|lower %}
                            <span style="display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 700;
                            {% if status == 'active' %}background: rgba(46, 204, 113, 0.1); color: #2ecc71;
                            {% elseif status == 'pending' %}background: rgba(241, 196, 15, 0.1); color: #f1c40f;
                            {% else %}background: rgba(231, 76, 60, 0.1); color: #e74c3c;{% endif %}">
                                {{ startup.status }}
                            </span>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" style="padding: 40px; text-align: center; opacity: 0.5; font-style: italic;">No startups found.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
<style>
    tbody tr:hover {
        background: rgba(122, 92, 255, 0.03);
    }
</style>
{% endblock %}
