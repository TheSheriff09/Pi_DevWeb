{% for startup in startups %}
    <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
        <td style="padding: 15px;">{{ startup.startupID }}</td>
        <td style="padding: 15px; font-weight: 500;">{{ startup.name }}</td>
        <td style="padding: 15px;">{{ startup.sector }}</td>
        <td style="padding: 15px; font-weight: 500; color: {{ startup.kPIscore >= 70 ? '#7fffd4' : (startup.kPIscore >= 50 ? '#ffd700' : '#ff6b6b') }};">
            {{ startup.kPIscore ? startup.kPIscore ~ '/100' : 'N/A' }}
        </td>
        <td style="padding: 15px;">
            <span style="padding: 4px 10px; border-radius: 20px; font-size: 0.8rem; background: rgba(255,255,255,0.1); color: #fff;">{{ startup.status ?: 'N/A' }}</span>
        </td>
        <td style="padding: 15px;">
            <div class="action-btns">
                <a href="{{ path('app_admin_startup_startup_edit', {'id': startup.startupID}) }}" class="btn-edit">Edit</a>
                <form method="post" action="{{ path('app_admin_startup_startup_delete', {'id': startup.startupID}) }}" onsubmit="return confirm('Are you sure you want to delete this startup?');" style="display:inline-block; margin:0;">
                    <button class="btn-delete" type="submit">Delete</button>
                </form>
            </div>
        </td>
    </tr>
{% else %}
    <tr>
        <td colspan="6" style="padding: 15px; text-align: center; color: #b0a8d6;">No startups found.</td>
    </tr>
{% endfor %}
