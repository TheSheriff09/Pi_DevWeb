<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forum Admin - Posts</title>
    <link rel="stylesheet" href="{{ asset('Back/css/styles.css') }}?v=2">
</head>
<body>
    <script>
        if (localStorage.getItem('admin_theme') === 'dark') {
            document.body.classList.add('dark-mode');
        }
    </script>

    <!-- SIDEBAR FOR FORUM MODULE -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <h2>Forum Admin</h2>
        </div>
        <ul class="sidebar-menu">
            <li><a href="{{ path('app_admin_panel') }}" style="color: #ff9d9d;">&larr; Main Admin</a></li>
            <li><a href="{{ path('app_admin_forum_dashboard') }}" class="{{ current_menu == 'dashboard' ? 'active' : '' }}">Dashboard</a></li>
            <li><a href="{{ path('app_admin_forum_posts') }}" class="{{ current_menu == 'posts' ? 'active' : '' }}">Manage Posts</a></li>
            <li><a href="{{ path('app_admin_forum_comments') }}" class="{{ current_menu == 'comments' ? 'active' : '' }}">Manage Comments</a></li>
            <li><a href="{{ path('app_admin_forum_interactions') }}" class="{{ current_menu == 'interactions' ? 'active' : '' }}">Manage Interactions</a></li>
        </ul>
        <div class="sidebar-footer">
            <a href="{{ path('app_logout') }}" class="logout-btn glow-btn">Sign Out</a>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <div class="main-content">
        <!-- TOPBAR -->
        <header class="topbar">
            <div class="topbar-left">
                <h2>Manage Posts</h2>
            </div>
            <div class="topbar-right">
                <button id="themeToggleBtn" class="btn-pill" style="border: 2px solid var(--primary-light); background: transparent; color: var(--primary-light);">🌓</button>
            </div>
        </header>

        <main class="dashboard-content" style="position: relative; z-index: 2;">
            
            <div class="card" style="width: 100%; margin-bottom: 20px;">
                <form action="{{ path('app_admin_forum_posts') }}" method="get" style="display: flex; gap: 10px;">
                    <input type="text" name="q" class="form-control" style="flex: 1; padding: 10px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.2); background: rgba(0,0,0,0.1); color: var(--text-main);" placeholder="Search posts by title or content..." value="{{ searchQuery }}">
                    <button type="submit" class="btn-pill glow-btn" style="padding: 10px 20px; border: none; cursor: pointer;">Search</button>
                    {% if searchQuery %}
                        <a href="{{ path('app_admin_forum_posts') }}" class="btn-pill" style="padding: 10px 20px; border: 1px solid #ff9d9d; color: #ff9d9d; text-decoration: none;">Clear</a>
                    {% endif %}
                </form>
            </div>

            <div class="card" style="width: 100%;">
                <div style="overflow-x: auto;">
                    <table style="width: 100%; border-collapse: collapse; text-align: left;">
                        <thead>
                            <tr style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                                <th style="padding: 15px; color: #b0a8d6;">ID</th>
                                <th style="padding: 15px; color: #b0a8d6;">Title</th>
                                <th style="padding: 15px; color: #b0a8d6;">Content Snippet</th>
                                <th style="padding: 15px; color: #b0a8d6;">Author</th>
                                <th style="padding: 15px; color: #b0a8d6;">Date</th>
                                <th style="padding: 15px; color: #b0a8d6; text-align: right;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for post in posts %}
                                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                    <td style="padding: 15px;">{{ post.id }}</td>
                                    <td style="padding: 15px; font-weight: 500;">{{ post.title }}</td>
                                    <td style="padding: 15px;">{{ post.content|length > 40 ? post.content|slice(0, 40) ~ '...' : post.content }}</td>
                                    <td style="padding: 15px;">{{ post.authorName }}</td>
                                    <td style="padding: 15px; color: #b0a8d6;">{{ post.createdAt|date('Y-m-d H:i') }}</td>
                                    <td style="padding: 15px; text-align: right;">
                                        <form action="{{ path('app_admin_forum_post_delete', {'id': post.id}) }}" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this post?');">
                                            <button type="submit" style="background: rgba(255, 71, 87, 0.1); border: 1px solid #ff4757; color: #ff4757; padding: 5px 10px; border-radius: 8px; cursor: pointer; transition: 0.3s;">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="6" style="padding: 15px; text-align: center; color: #b0a8d6;">No posts found.</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
            
        </main>
        
        <footer class="futuristic-footer" style="padding: 20px; text-align: center; border-top: 1px solid rgba(255, 255, 255, 0.1);">
            <p style="color: #b0a8d6;">&copy; {{ 'now'|date('Y') }} StartupFlow Admin.</p>
        </footer>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const toggleBtn = document.getElementById('themeToggleBtn');
            if (toggleBtn) {
                toggleBtn.addEventListener('click', () => {
                    const isDark = document.body.classList.contains('dark-mode');
                    if (isDark) {
                        document.body.classList.remove('dark-mode');
                        localStorage.setItem('admin_theme', 'light');
                    } else {
                        document.body.classList.add('dark-mode');
                        localStorage.setItem('admin_theme', 'dark');
                    }
                });
            }
        });
    </script>
</body>
</html>
