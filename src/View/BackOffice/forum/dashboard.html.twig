{% extends 'BackOffice/base_back.html.twig' %}

{% block title %}Forum Admin - Dashboard{% endblock %}

{% block header_title %}Overview{% endblock %}

{% block body %}
<main class="dashboard-content" style="position: relative; z-index: 2;">
    
    <div class="dashboard-cards" style="margin-bottom: 40px; display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 25px;">
        <div class="card" style="padding: 25px;">
            <h3 style="font-size: 2.5rem; color: var(--primary-lighter); margin: 0;">{{ postsCount }}</h3>
            <p style="text-transform: uppercase; font-size: 0.9rem; letter-spacing: 1px; margin-top: 5px;">Total Posts</p>
        </div>
        <div class="card" style="padding: 25px;">
            <h3 style="font-size: 2.5rem; color: #a18bff; margin: 0;">{{ commentsCount }}</h3>
            <p style="text-transform: uppercase; font-size: 0.9rem; letter-spacing: 1px; margin-top: 5px;">Total Comments</p>
        </div>
        <div class="card" style="padding: 25px;">
            <h3 style="font-size: 2.5rem; color: #ff8bba; margin: 0;">{{ interactionsCount }}</h3>
            <p style="text-transform: uppercase; font-size: 0.9rem; letter-spacing: 1px; margin-top: 5px;">Total Interactions</p>
        </div>
    </div>

    <div class="card" style="width: 100%; padding: 25px;">
        <h3 style="margin-bottom: 20px; color: var(--primary-lighter);">Latest Forum Posts</h3>
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse; text-align: left;">
                <thead>
                    <tr style="border-bottom: 1px solid rgba(128,128,128,0.1);">
                        <th style="padding: 15px; color: #8d79ff; font-weight: 700;">ID</th>
                        <th style="padding: 15px; color: #8d79ff; font-weight: 700;">Title</th>
                        <th style="padding: 15px; color: #8d79ff; font-weight: 700;">Author</th>
                        <th style="padding: 15px; color: #8d79ff; font-weight: 700;">Date</th>
                    </tr>
                </thead>
                <tbody>
                    {% for post in latestPosts %}
                        <tr style="border-bottom: 1px solid rgba(128,128,128,0.05);">
                            <td style="padding: 15px;">{{ post.id }}</td>
                            <td style="padding: 15px; font-weight: 500;">{{ post.title }}</td>
                            <td style="padding: 15px;">{{ post.authorName }}</td>
                            <td style="padding: 15px; opacity: 0.7;">{{ post.createdAt|date('Y-m-d H:i') }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" style="padding: 15px; text-align: center; opacity: 0.5;">No posts found.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    
</main>
{% endblock %}
