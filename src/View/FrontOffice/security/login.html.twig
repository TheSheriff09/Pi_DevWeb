{% extends 'FrontOffice/base.html.twig' %}

{% block title %}StartupFlow Tunisia - Login{% endblock %}

{% block body %}
    <div class="split-layout">
        <div class="split-left">
            <!-- Left login card -->
            <div class="auth-card">
                <h2 class="welcome-title">Welcome Back!</h2>

                <form method="post" action="{{ path('app_login') }}">
                    {% if error is defined and error %}
                        <div style="color: #ff5c5c; margin-bottom: 15px; font-weight: 500; text-align: center;">{{ error }}</div>
                    {% endif %}

                    <label class="field-label" for="login-email">Email</label>
                    <input type="email" id="login-email" name="email" class="pillField" placeholder="Entrepreneur@startupflow.in" autofocus>

                    <label class="field-label" for="login-password">Password</label>
                    <div class="password-wrap">
                        <input type="password" id="login-password" name="password" class="pillField" placeholder="**************">
                        <button type="button" class="eyeBtn" onclick="togglePass('login-password')">👁</button>
                    </div>

                    <button type="submit" class="signBtn">sign in</button>
                </form>

                <div style="text-align:center; margin-top:15px; margin-bottom:15px;">
                    <button type="button" id="start-face-login-btn" class="signBtn" style="background:transparent; border:2px solid #7a5cff; color:#7a5cff; width:100%;">📷 Sign in with Face ID</button>
                </div>

                <!-- Webcam Login Modal -->
                <div id="face-login-modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.85); z-index:9999; justify-content:center; align-items:center;">
                    <div style="background:#fff; padding:30px; border-radius:15px; width:450px; text-align:center;">
                        <h3 style="margin-top:0; color:#333;">Biometric Sign In</h3>
                        <div style="width:100%; height:320px; background:#000; border-radius:10px; overflow:hidden; margin-bottom:15px; position:relative;">
                            <video id="webcam-login-video" autoplay playsinline style="width:100%; height:100%; object-fit:cover;"></video>
                        </div>
                        <p id="face-login-status" style="font-size:15px; color:#555; height:20px; margin-bottom:15px; font-weight:500;">Waiting for camera access...</p>
                        <button type="button" id="capture-login-btn" class="signBtn glow-btn" style="width:100%;" disabled>Scan & Login</button>
                        <button type="button" id="close-login-modal-btn" style="background:transparent; border:none; color:#888; margin-top:20px; cursor:pointer; text-decoration:underline;">Return to Email/Password</button>
                    </div>
                </div>

                <a href="{{ path('app_google_login') }}" class="socialBtn" style="display:inline-flex; align-items:center; justify-content:center; text-decoration:none;">
                    <img src="{{ asset('Front/images/google-lens-icon-logo-symbol-free-png.png') }}" alt="Google Login">
                </a>

                <div class="auth-bottom">
                    <span>don't have an account ?</span>
                    <a href="{{ path('app_register') }}" class="link-alt">sign up</a>
                </div>
            </div>
        </div>

        <div class="split-right">
            <!-- 3D Cube Container replacing static image -->
            <div id="threed-cube-container" style="width: 100%; height: 100%; position: absolute; top: 0; left: 0; z-index: 1;"></div>
            <div class="right-overlay" style="z-index: 2;">
                <h2 class="rightTitle">Turn Ideas Into Impact</h2>
                <p class="rightSub">From bold ideas to funded startups, manage mentoring,<br>performance, and growth with clarity and confidence.</p>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script>
        function togglePass(id) {
            const el = document.getElementById(id);
            if (el.type === "password") {
                el.type = "text";
            } else {
                el.type = "password";
            }
        }

        document.addEventListener("DOMContentLoaded", function() {
            // -- FACE LOGIN JS --
            const btnStartFace = document.getElementById('start-face-login-btn');
            const faceModal = document.getElementById('face-login-modal');
            const video = document.getElementById('webcam-login-video');
            const btnCapture = document.getElementById('capture-login-btn');
            const btnCloseFace = document.getElementById('close-login-modal-btn');
            const statusText = document.getElementById('face-login-status');
            
            let stream = null;

            btnStartFace.addEventListener('click', async () => {
                faceModal.style.display = 'flex';
                statusText.innerText = 'Requesting camera access...';
                statusText.style.color = '#555';
                btnCapture.disabled = false;
                try {
                    stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: "user" } });
                    video.srcObject = stream;
                    statusText.innerText = 'Look directly at the camera.';
                } catch (err) {
                    statusText.innerText = 'Camera access denied or unavailable.';
                    statusText.style.color = '#ff5c5c';
                    btnCapture.disabled = true;
                }
            });

            const stopCamera = () => {
                faceModal.style.display = 'none';
                if (stream) {
                    stream.getTracks().forEach(track => track.stop());
                    stream = null;
                }
            };
            btnCloseFace.addEventListener('click', stopCamera);

            btnCapture.addEventListener('click', async () => {
                btnCapture.disabled = true;
                statusText.innerText = 'Authenticating face...';
                statusText.style.color = '#7a5cff';
                
                const canvas = document.createElement('canvas');
                canvas.width = video.videoWidth;
                canvas.height = video.videoHeight;
                canvas.getContext('2d').drawImage(video, 0, 0, canvas.width, canvas.height);
                const base64Image = canvas.toDataURL('image/jpeg', 0.85);

                try {
                    const response = await fetch('/api/face-login', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ image: base64Image })
                    });
                    const data = await response.json();

                    if (data.status === 'success') {
                        statusText.innerText = '✅ Access Granted! Redirecting...';
                        statusText.style.color = '#1f7d54';
                        setTimeout(() => { window.location.href = data.redirect; }, 1000);
                    } else {
                        statusText.innerText = '❌ ' + (data.message || 'This face is not recognized. Access denied.');
                        statusText.style.color = '#ff5c5c';
                        setTimeout(() => {
                            statusText.innerText = 'Please try again or use email/password.';
                            statusText.style.color = '#555';
                            btnCapture.disabled = false;
                        }, 2500);
                    }
                } catch (e) {
                    statusText.innerText = '❌ System Offline - Try Email/Password';
                    statusText.style.color = '#ff5c5c';
                    btnCapture.disabled = false;
                }
            });

            // -- THREE.JS CUBE CATCH --
            const container = document.getElementById('threed-cube-container');
            if (!container) return;

            const scene = new THREE.Scene();
            const camera = new THREE.PerspectiveCamera(75, container.clientWidth / container.clientHeight, 0.1, 1000);
            const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
            
            renderer.setSize(container.clientWidth, container.clientHeight);
            renderer.setPixelRatio(window.devicePixelRatio);
            container.appendChild(renderer.domElement);

            const geometry = new THREE.BoxGeometry(3, 3, 3);
            const material = new THREE.MeshStandardMaterial({  
                color: 0x7a5cff,
                wireframe: true,
                emissive: 0x6f56ff,
                emissiveIntensity: 0.8,
                transparent: true,
                opacity: 0.9
            });
            const cube = new THREE.Mesh(geometry, material);
            scene.add(cube);

            const coreGeometry = new THREE.BoxGeometry(2.1, 2.1, 2.1);
            const coreMaterial = new THREE.MeshPhongMaterial({
                color: 0xcdb5ff,
                shininess: 150,
                transparent: true,
                opacity: 0.8
            });
            const core = new THREE.Mesh(coreGeometry, coreMaterial);
            scene.add(core);

            const particleGeo = new THREE.BufferGeometry();
            const particleCount = 200;
            const posArray = new Float32Array(particleCount * 3);
            for(let i=0; i<particleCount*3; i++) {
                posArray[i] = (Math.random() - 0.5) * 15;
            }
            particleGeo.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
            const particleMat = new THREE.PointsMaterial({
                size: 0.05,
                color: 0xcdb5ff,
                transparent: true,
                opacity: 0.6
            });
            const particles = new THREE.Points(particleGeo, particleMat);
            scene.add(particles);

            const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
            scene.add(ambientLight);

            const pointLight = new THREE.PointLight(0xffffff, 2);
            pointLight.position.set(5, 5, 5);
            scene.add(pointLight);

            camera.position.z = 6;

            function animate() {
                requestAnimationFrame(animate);
                
                cube.rotation.x += 0.005;
                cube.rotation.y += 0.01;
                core.rotation.x -= 0.008;
                core.rotation.y -= 0.008;
                particles.rotation.y += 0.002;

                renderer.render(scene, camera);
            }
            animate();

            window.addEventListener('resize', () => {
                if (container) {
                    camera.aspect = container.clientWidth / container.clientHeight;
                    camera.updateProjectionMatrix();
                    renderer.setSize(container.clientWidth, container.clientHeight);
                }
            });
        });
    </script>
{% endblock %}
