{% extends 'FrontOffice/base.html.twig' %}

{% block title %}StartupFlow Tunisia - Two-Factor Authentication{% endblock %}

{% block body %}
    <div class="split-layout">
        <div class="split-left">
            <div class="auth-card" style="text-align: center;">
                <h2 class="welcome-title">Security Check</h2>
                <p style="color: #666; margin-bottom: 25px; font-size: 14px;">We've sent a 6-digit verification code to your registered email address.</p>

                <form method="post" action="{{ path('app_login_2fa') }}">
                    {% if error is defined and error %}
                        <div style="color: #ff5c5c; margin-bottom: 15px; font-weight: 500; background: rgba(255, 92, 92, 0.1); padding: 10px; border-radius: 8px;">{{ error }}</div>
                    {% endif %}

                    <label class="field-label" for="login-code" style="text-align: left; display: block;">6-Digit Verification Code</label>
                    <input type="text" id="login-code" name="code" class="pillField" placeholder="Enter code here" autofocus style="text-align: center; letter-spacing: 5px; font-size: 1.2rem; font-weight: bold;" maxlength="6">

                    <button type="submit" class="signBtn glow-btn">Verify Account</button>
                </form>

                <div class="auth-bottom" style="margin-top: 30px;">
                    <a href="{{ path('app_login') }}" class="link-alt" style="color: #888;">← Return to Login</a>
                </div>
            </div>
        </div>

        <div class="split-right">
            <!-- 3D Cube Container replacing static image -->
            <div id="threed-cube-container" style="width: 100%; height: 100%; position: absolute; top: 0; left: 0; z-index: 1;"></div>
            <div class="right-overlay" style="z-index: 2;">
                <h2 class="rightTitle">Protect Your Impact</h2>
                <p class="rightSub">StartupFlow employs advanced Two-Factor Authentication ensuring your internal metrics and communications are secure.</p>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // -- THREE.JS CUBE --
            const container = document.getElementById('threed-cube-container');
            if (!container) return;

            const scene = new THREE.Scene();
            const camera = new THREE.PerspectiveCamera(75, container.clientWidth / container.clientHeight, 0.1, 1000);
            const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
            
            renderer.setSize(container.clientWidth, container.clientHeight);
            renderer.setPixelRatio(window.devicePixelRatio);
            container.appendChild(renderer.domElement);

            const geometry = new THREE.BoxGeometry(3, 3, 3);
            const material = new THREE.MeshStandardMaterial({  
                color: 0x4facfe,
                wireframe: true,
                emissive: 0x00f2fe,
                emissiveIntensity: 0.8,
                transparent: true,
                opacity: 0.9
            });
            const cube = new THREE.Mesh(geometry, material);
            scene.add(cube);

            const coreGeometry = new THREE.BoxGeometry(2.1, 2.1, 2.1);
            const coreMaterial = new THREE.MeshPhongMaterial({
                color: 0xcdb5ff,
                shininess: 150,
                transparent: true,
                opacity: 0.8
            });
            const core = new THREE.Mesh(coreGeometry, coreMaterial);
            scene.add(core);

            const particleGeo = new THREE.BufferGeometry();
            const particleCount = 200;
            const posArray = new Float32Array(particleCount * 3);
            for(let i=0; i<particleCount*3; i++) {
                posArray[i] = (Math.random() - 0.5) * 15;
            }
            particleGeo.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
            const particleMat = new THREE.PointsMaterial({
                size: 0.05,
                color: 0x4facfe,
                transparent: true,
                opacity: 0.6
            });
            const particles = new THREE.Points(particleGeo, particleMat);
            scene.add(particles);

            const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
            scene.add(ambientLight);

            const pointLight = new THREE.PointLight(0xffffff, 2);
            pointLight.position.set(5, 5, 5);
            scene.add(pointLight);

            camera.position.z = 6;

            function animate() {
                requestAnimationFrame(animate);
                
                cube.rotation.x += 0.005;
                cube.rotation.y += 0.01;
                core.rotation.x -= 0.008;
                core.rotation.y -= 0.008;
                particles.rotation.y += 0.002;

                renderer.render(scene, camera);
            }
            animate();

            window.addEventListener('resize', () => {
                if (container) {
                    camera.aspect = container.clientWidth / container.clientHeight;
                    camera.updateProjectionMatrix();
                    renderer.setSize(container.clientWidth, container.clientHeight);
                }
            });
        });
    </script>
{% endblock %}
