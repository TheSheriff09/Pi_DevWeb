<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Two-Factor Authentication Code</title>
</head>
<body style="margin:0;padding:0;background:#f6f7fb;font-family:Arial,Helvetica,sans-serif;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#f6f7fb;padding:24px 0;">
    <tr>
        <td align="center">
            <table role="presentation" width="620" cellpadding="0" cellspacing="0" style="background:#ffffff;border-radius:14px;overflow:hidden;box-shadow:0 8px 30px rgba(0,0,0,.08);">
                <tr>
                    <td style="padding:26px 28px;background:linear-gradient(135deg,#4facfe,#00f2fe);color:#ffffff;">
                        <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                            <tr>
                                <td style="vertical-align:middle;">
                                    <h1 style="margin:0;font-size:22px;line-height:1.2;">Your Security Code 🔒</h1>
                                    <p style="margin:10px 0 0 0;font-size:14px;opacity:0.95;">Two-Factor Authentication</p>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>

                <tr>
                    <td style="padding:26px 28px;color:#111827;">
                        <p style="margin:0 0 10px 0;font-size:16px;">Hi <b>{{ full_name }}</b>,</p>
                        <p style="margin:0 0 14px 0;font-size:14px;line-height:1.65;color:#374151;">
                            You are trying to sign in to StartupFlow. Please use the following 6-digit verification code to complete your login securely.
                        </p>

                        <table role="presentation" cellpadding="0" cellspacing="0" style="margin:25px auto; width: 100%;">
                            <tr>
                                <td align="center">
                                    <div style="background: #f0f4f8; border: 2px dashed #4facfe; border-radius: 12px; padding: 20px; text-align: center;">
                                        <h2 style="margin: 0; font-size: 32px; letter-spacing: 8px; color: #4facfe;">{{ code }}</h2>
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <p style="margin:20px 0 14px 0;font-size:13px;line-height:1.65;color:#6b7280;">
                            <b>Security Notice:</b> Never share this code with anyone. If you didn't attempt to sign in, your email and password may be compromised. Please reset your password immediately.
                        </p>

                        <p style="margin:22px 0 0 0;font-size:13px;color:#6b7280;">
                            — The StartupFlow Security Team
                        </p>
                    </td>
                </tr>

                <tr>
                    <td style="padding:14px 28px;background:#111827;color:#9ca3af;font-size:12px;">
                        <p style="margin:0;">© {{ year }} StartupFlow • All rights reserved</p>
                    </td>
                </tr>
            </table>

            <p style="margin:12px 0 0 0;font-size:11px;color:#9ca3af;">
                This email was sent automatically. Please don’t reply.
            </p>
        </td>
    </tr>
</table>
</body>
</html>
