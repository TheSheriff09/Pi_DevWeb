{% extends "FrontOffice/base.html.twig" %}

{% block title %}Edit Startup - StartupFlow Tunisia{% endblock %}

{% block body %}
<div class="auth-container" style="min-height: 100vh; padding: 40px 20px;">
    <div class="auth-card" style="max-width: 800px; margin: 0 auto;">
        <div style="margin-bottom: 30px; text-align: center;">
            <h1 style="color: var(--primary, #6f56ff); margin: 0; font-size: 2.5em;">Edit Startup</h1>
            <p style="color: var(--text-secondary, #aaa); margin: 10px 0 0 0;">Update your startup information</p>
        </div>

        {% if error %}
            <div style="background: rgba(244,67,54,0.2); border: 1px solid rgba(244,67,54,0.5); color: #e57373; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
                {{ error }}
            </div>
        {% endif %}

        <form method="post" style="display: grid; gap: 20px;">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div>
                    <label style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--primary-light, #9d88ff);">Startup Name *</label>
                    <input type="text" name="name" required class="pillField" style="width: 100%;" value="{{ startup.name }}" placeholder="Enter startup name">
                </div>
                <div>
                    <label style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--primary-light, #9d88ff);">Sector</label>
                    <select name="sector" class="pillField" style="width: 100%;">
                        <option value="">Select sector...</option>
                        <option value="Technology" {% if startup.sector == 'Technology' %}selected{% endif %}>Technology</option>
                        <option value="Healthcare" {% if startup.sector == 'Healthcare' %}selected{% endif %}>Healthcare</option>
                        <option value="Finance" {% if startup.sector == 'Finance' %}selected{% endif %}>Finance</option>
                        <option value="Education" {% if startup.sector == 'Education' %}selected{% endif %}>Education</option>
                        <option value="E-commerce" {% if startup.sector == 'E-commerce' %}selected{% endif %}>E-commerce</option>
                        <option value="Real Estate" {% if startup.sector == 'Real Estate' %}selected{% endif %}>Real Estate</option>
                        <option value="Manufacturing" {% if startup.sector == 'Manufacturing' %}selected{% endif %}>Manufacturing</option>
                        <option value="Food & Beverage" {% if startup.sector == 'Food & Beverage' %}selected{% endif %}>Food & Beverage</option>
                        <option value="Transportation" {% if startup.sector == 'Transportation' %}selected{% endif %}>Transportation</option>
                        <option value="Energy" {% if startup.sector == 'Energy' %}selected{% endif %}>Energy</option>
                        <option value="Other" {% if startup.sector == 'Other' %}selected{% endif %}>Other</option>
                    </select>
                </div>
            </div>

            <div>
                <label style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--primary-light, #9d88ff);">Description</label>
                <textarea name="description" rows="4" class="pillField" style="width: 100%; resize: vertical;" placeholder="Describe your startup, mission, and vision...">{{ startup.description }}</textarea>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div>
                    <label style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--primary-light, #9d88ff);">Image URL</label>
                    <input type="url" name="imageURL" class="pillField" style="width: 100%;" value="{{ startup.imageURL }}" placeholder="https://example.com/image.jpg">
                </div>
                <div>
                    <label style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--primary-light, #9d88ff);">Creation Date</label>
                    <input type="date" name="creationDate" class="pillField" style="width: 100%;" value="{% if startup.creationDate %}{{ startup.creationDate|date('Y-m-d') }}{% endif %}">
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px;">
                <div>
                    <label style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--primary-light, #9d88ff);">Stage</label>
                    <select name="stage" class="pillField" style="width: 100%;">
                        <option value="">Select stage...</option>
                        <option value="Idea" {% if startup.stage == 'Idea' %}selected{% endif %}>Idea</option>
                        <option value="Prototype" {% if startup.stage == 'Prototype' %}selected{% endif %}>Prototype</option>
                        <option value="MVP" {% if startup.stage == 'MVP' %}selected{% endif %}>MVP</option>
                        <option value="Early Stage" {% if startup.stage == 'Early Stage' %}selected{% endif %}>Early Stage</option>
                        <option value="Growth" {% if startup.stage == 'Growth' %}selected{% endif %}>Growth</option>
                        <option value="Mature" {% if startup.stage == 'Mature' %}selected{% endif %}>Mature</option>
                    </select>
                </div>
                <div>
                    <label style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--primary-light, #9d88ff);">Status</label>
                    <select name="status" class="pillField" style="width: 100%;">
                        <option value="">Select status...</option>
                        <option value="Active" {% if startup.status == 'Active' %}selected{% endif %}>Active</option>
                        <option value="Pending" {% if startup.status == 'Pending' %}selected{% endif %}>Pending</option>
                        <option value="Inactive" {% if startup.status == 'Inactive' %}selected{% endif %}>Inactive</option>
                    </select>
                </div>
                <div>
                    <label style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--primary-light, #9d88ff);">Incubator Program</label>
                    <input type="text" name="incubatorProgram" class="pillField" style="width: 100%;" value="{{ startup.incubatorProgram }}" placeholder="Program name (if any)">
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div>
                    <label style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--primary-light, #9d88ff);">Funding Amount ($)</label>
                    <input type="number" name="fundingAmount" step="0.01" min="0" class="pillField" style="width: 100%;" value="{{ startup.fundingAmount }}" placeholder="0.00">
                </div>
                <div>
                    <label style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--primary-light, #9d88ff);">KPI Score (0-100)</label>
                    <input type="number" name="kPIscore" step="0.01" min="0" max="100" class="pillField" style="width: 100%;" value="{{ startup.kPIscore }}" placeholder="0.00">
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px;">
                <div>
                    <label style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--primary-light, #9d88ff);">Mentor ID</label>
                    <input type="number" name="mentorID" min="1" class="pillField" style="width: 100%;" value="{{ startup.mentorID }}" placeholder="Mentor ID (optional)">
                </div>
                <div>
                    <label style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--primary-light, #9d88ff);">Founder ID</label>
                    <input type="number" name="founderID" min="1" class="pillField" style="width: 100%;" value="{{ startup.founderID }}" placeholder="Founder ID (optional)">
                </div>
                <div>
                    <label style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--primary-light, #9d88ff);">Business Plan ID</label>
                    <input type="number" name="businessPlanID" min="1" class="pillField" style="width: 100%;" value="{{ startup.businessPlanID }}" placeholder="Business Plan ID (optional)">
                </div>
            </div>

            <div>
                <label style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--primary-light, #9d88ff);">Last Evaluation Date</label>
                <input type="date" name="lastEvaluationDate" class="pillField" style="width: 100%;" value="{% if startup.lastEvaluationDate %}{{ startup.lastEvaluationDate|date('Y-m-d') }}{% endif %}">
            </div>

            <div style="display: flex; gap: 15px; justify-content: center; margin-top: 30px;">
                <button type="submit" class="pill-btn" style="background: linear-gradient(135deg, var(--primary, #6f56ff), #b58bff); padding: 12px 30px; border: none; font-size: 1.1em;">
                    Update Startup
                </button>
                <a href="{{ path('app_entrepreneur_startups') }}" class="pill-btn" style="background: transparent; border: 2px solid var(--primary, #6f56ff); color: var(--primary, #6f56ff); padding: 10px 30px; text-decoration: none; display: inline-flex; align-items: center; justify-content: center;">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
