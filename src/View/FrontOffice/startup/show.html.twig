{% extends "FrontOffice/base.html.twig" %}

{% block title %}{{ startup.name }} - Startup Details{% endblock %}

{% block body %}
<div class="auth-container" style="min-height: 100vh; padding: 40px 20px;">
    <div class="auth-card" style="max-width: 1000px; margin: 0 auto; border-radius: 20px;">
        
        <!-- Startup Header -->
        <div style="display: flex; gap: 20px; align-items: flex-start; margin-bottom: 40px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 20px;">
            {% if startup.imageURL %}
                <img src="{{ startup.imageURL }}" alt="{{ startup.name }}" style="width: 120px; height: 120px; border-radius: 15px; object-fit: cover;">
            {% else %}
                <div style="width: 120px; height: 120px; border-radius: 15px; background: linear-gradient(135deg, var(--primary, #6f56ff), #b58bff); display: flex; align-items: center; justify-content: center; font-size: 3em; font-weight: bold; color: white;">
                    {{ startup.name|first|upper }}
                </div>
            {% endif %}
            
            <div style="flex: 1;">
                <h1 style="color: var(--primary, #6f56ff); margin: 0 0 10px 0; font-size: 2.5em;">{{ startup.name }}</h1>
                <p style="margin: 0 0 15px 0; font-size: 1.1em;">{{ startup.description }}</p>
                
                <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                    <span style="background: rgba(111,86,255,0.2); color: var(--primary-light, #9d88ff); padding: 5px 12px; border-radius: 20px; font-size: 0.9em;">Sector: {{ startup.sector|default('N/A') }}</span>
                    <span style="background: rgba(76,175,80,0.2); color: #81c784; padding: 5px 12px; border-radius: 20px; font-size: 0.9em;">Stage: {{ startup.stage|default('N/A') }}</span>
                    <span style="background: rgba(255,152,0,0.2); color: #ffb74d; padding: 5px 12px; border-radius: 20px; font-size: 0.9em;">Status: {{ startup.status|default('N/A') }}</span>
                </div>
            </div>

            <a href="{{ path('app_entrepreneur_startups') }}" class="pill-btn" style="border: 1px solid var(--primary); padding: 10px 20px; text-decoration: none;">&larr; Back to List</a>
        </div>

        <!-- Business Plan Section -->
        <div style="margin-top: 40px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h2 style="margin: 0; font-size: 1.8em; border-left: 4px solid var(--primary, #6f56ff); padding-left: 15px;">Business Plan</h2>
                {% if businessplan is null %}
                    <a href="{{ path('app_entrepreneur_businessplan_new', {'startupId': startup.startupID}) }}" class="pill-btn glow-btn" style="background: linear-gradient(135deg, #10b981, #34d399); padding: 10px 20px; text-decoration: none; display: inline-flex; align-items: center; gap: 8px;">
                        <span>+</span> Create Business Plan
                    </a>
                {% endif %}
            </div>

            {% if businessplan %}
                <div style="padding: 30px; border-radius: 15px; border: 1px solid rgba(111,86,255,0.2);">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 25px;">
                        <h3 style="color: var(--primary-light, #9d88ff); margin: 0; font-size: 1.5em;">{{ businessplan.title ?: 'Untitled Plan' }}</h3>
                        <div style="display: flex; gap: 10px;">
                            <a href="{{ path('app_entrepreneur_businessplan_edit', {'id': businessplan.businessPlanID}) }}" style="background: rgba(33,150,243,0.2); color: #64b5f6; padding: 8px 15px; border-radius: 8px; text-decoration: none; font-size: 0.9em; transition: all 0.2s;" onmouseover="this.style.background='rgba(33,150,243,0.3)'" onmouseout="this.style.background='rgba(33,150,243,0.2)'">Edit Plan</a>
                            <a href="{{ path('app_entrepreneur_businessplan_delete', {'id': businessplan.businessPlanID}) }}" onclick="return confirm('WARNING: Are you sure you want to permanently delete this business plan?')" style="background: rgba(244,67,54,0.2); color: #e57373; padding: 8px 15px; border-radius: 8px; text-decoration: none; font-size: 0.9em; transition: all 0.2s;" onmouseover="this.style.background='rgba(244,67,54,0.3)'" onmouseout="this.style.background='rgba(244,67,54,0.2)'">Delete Plan</a>
                        </div>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
                        <div>
                            <p style="color: var(--primary); margin-bottom: 5px; font-size: 0.85em; text-transform: uppercase;">Executive Summary / Description</p>
                            <p style="margin-top: 0; line-height: 1.6;">{{ businessplan.description|default('No description provided')|nl2br }}</p>
                        </div>
                        <div>
                            <p style="color: var(--primary); margin-bottom: 5px; font-size: 0.85em; text-transform: uppercase;">Value Proposition</p>
                            <p style="margin-top: 0; line-height: 1.6;">{{ businessplan.valueProposition|default('Not specified')|nl2br }}</p>
                        </div>
                        
                        <div>
                            <p style="color: var(--primary); margin-bottom: 5px; font-size: 0.85em; text-transform: uppercase;">Market Analysis</p>
                            <p style="margin-top: 0; line-height: 1.6;">{{ businessplan.marketAnalysis|default('Not specified')|nl2br }}</p>
                        </div>
                        <div>
                            <p style="color: var(--primary); margin-bottom: 5px; font-size: 0.85em; text-transform: uppercase;">Business Model</p>
                            <p style="margin-top: 0; line-height: 1.6;">{{ businessplan.businessModel|default('Not specified')|nl2br }}</p>
                        </div>

                        <div>
                            <p style="color: var(--primary); margin-bottom: 5px; font-size: 0.85em; text-transform: uppercase;">Financial Data</p>
                            <div style="background: rgba(111,86,255,0.05); padding: 15px; border-radius: 10px;">
                                <div style="margin-bottom: 10px;">
                                    <span style="font-weight: 500;">Funding Required:</span> 
                                    <strong style="color: #81c784; font-size: 1.2em;">${{ businessplan.fundingRequired|default(0)|number_format(0, '.', ',') }}</strong>
                                </div>
                                <div style="line-height: 1.5; font-size: 0.9em;">
                                    <strong style="display: block; margin-bottom: 5px;">Forecast:</strong>
                                    {{ businessplan.financialForecast|default('None')|nl2br }}
                                </div>
                            </div>
                        </div>

                        <div>
                            <p style="color: var(--primary); margin-bottom: 5px; font-size: 0.85em; text-transform: uppercase;">Roadmap & Status</p>
                            <div style="margin-bottom: 15px;">
                                <span style="background: rgba(255,152,0,0.2); color: #ffb74d; padding: 5px 12px; border-radius: 15px; font-size: 0.9em;">Status: {{ businessplan.status|default('Draft') }}</span>
                            </div>
                            <div style="line-height: 1.5; font-size: 0.9em;">
                                <strong style="display: block; margin-bottom: 5px;">Timeline:</strong>
                                {{ businessplan.timeline|default('Not defined')|nl2br }}
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div style="text-align: center; padding: 50px 20px; background: rgba(111,86,255,0.05); border-radius: 15px; border: 2px dashed rgba(111,86,255,0.2);">
                    <div style="font-size: 3em; margin-bottom: 15px; opacity: 0.8;">📄</div>
                    <h3 style="margin-bottom: 10px;">No Business Plan Yet</h3>
                    <p style="margin-bottom: 25px; max-width: 400px; margin-left: auto; margin-right: auto; opacity: 0.8;">A strong business plan increases your chances of getting evaluated positively and funded.</p>
                    <a href="{{ path('app_entrepreneur_businessplan_new', {'startupId': startup.startupID}) }}" class="pill-btn glow-btn" style="background: linear-gradient(135deg, #10b981, #34d399); padding: 10px 25px; text-decoration: none;">
                        Generate Business Plan
                    </a>
                </div>
            {% endif %}
        </div>

        <!-- Funding Applications Section -->
        <div style="margin-top: 50px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h2 style="margin: 0; font-size: 1.8em; border-left: 4px solid #34d399; padding-left: 15px;">Funding Applications</h2>
                <a href="{{ path('app_entrepreneur_funding_new', {'startupId': startup.startupID}) }}" class="pill-btn glow-btn" style="background: linear-gradient(135deg, #10b981, #34d399); padding: 10px 20px; text-decoration: none; display: inline-flex; align-items: center; gap: 8px;">
                    <span>💸</span> Apply for Funding
                </a>
            </div>

            {% if fundingApplications is defined and fundingApplications|length > 0 %}
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
                    {% for fn in fundingApplications %}
                        <div style="padding: 20px; border-radius: 15px; border: 1px solid rgba(16, 185, 129, 0.2); background: rgba(16, 185, 129, 0.05);">
                            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px;">
                                <div>
                                    <h4 style="margin: 0; font-size: 1.25em; color: #34d399;">${{ fn.amount|number_format(0, '.', ',') }}</h4>
                                    <span style="font-size: 0.8em; opacity: 0.6;">Submitted: {{ fn.submissionDate|date('M d, Y') }}</span>
                                </div>
                                <span style="background: {% if fn.status == 'Approved' %}rgba(76,175,80,0.2); color: #81c784;{% elseif fn.status == 'Pending' %}rgba(255,152,0,0.2); color: #ffb74d;{% else %}rgba(244,67,54,0.2); color: #e57373;{% endif %} padding: 4px 10px; border-radius: 12px; font-size: 0.85em;">
                                    {{ fn.status }}
                                </span>
                            </div>

                            <div style="font-size: 0.9em;">
                                <div style="margin-bottom: 10px;">
                                    <strong style="color: var(--primary); display: block; opacity: 0.8;">Reason:</strong>
                                    {{ fn.applicationReason }}
                                </div>
                                <div style="margin-bottom: 10px;">
                                    <strong style="color: var(--primary); display: block; opacity: 0.8;">Schedule:</strong>
                                    {{ fn.paymentSchedule }}
                                </div>
                                {% if fn.attachment %}
                                    <div style="margin-top: 15px; padding-top: 10px; border-top: 1px solid rgba(255,255,255,0.05);">
                                        <a href="{{ fn.attachment }}" target="_blank" style="color: #64b5f6; text-decoration: none; font-size: 0.85em;">&rarr; View Attached Material</a>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div style="text-align: center; padding: 40px 20px; background: rgba(16, 185, 129, 0.05); border-radius: 15px; border: 2px dashed rgba(16, 185, 129, 0.2);">
                    <div style="font-size: 2.5em; margin-bottom: 15px; opacity: 0.8;">🌱</div>
                    <h3 style="margin-bottom: 10px;">No Applications Discovered</h3>
                    <p style="margin-bottom: 25px; max-width: 400px; margin-left: auto; margin-right: auto; opacity: 0.8;">Your project hasn't requested funding yet. Prepare a rock-solid business plan before you ask for capital!</p>
                </div>
            {% endif %}
        </div>

        <!-- SWOT Analysis Section -->
        <div style="margin-top: 50px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h2 style="margin: 0; font-size: 1.8em; border-left: 4px solid #b58bff; padding-left: 15px;">AI SWOT Analysis</h2>
                <button id="generateSwotBtn" class="pill-btn glow-btn" style="background: linear-gradient(135deg, #6f56ff, #b58bff); padding: 10px 20px; border: none; cursor: pointer; color: white; display: inline-flex; align-items: center; gap: 8px;">
                    <span id="swotBtnIcon">✨</span> <span id="swotBtnText">Generate SWOT with AI</span>
                </button>
            </div>
            
            <div id="swotError" style="display: none; padding: 15px; margin-bottom: 20px; background: rgba(244,67,54,0.1); border: 1px solid rgba(244,67,54,0.3); border-radius: 10px; color: #ff8a80;">
            </div>

            <div id="swotLoading" style="display: none; text-align: center; padding: 40px; background: rgba(111,86,255,0.05); border-radius: 15px; border: 1px dashed rgba(111,86,255,0.3);">
                <div style="display: inline-block; width: 30px; height: 30px; border: 3px solid rgba(111,86,255,0.3); border-radius: 50%; border-top-color: #6f56ff; animation: spin 1s ease-in-out infinite;"></div>
                <p style="margin-top: 15px; font-weight: bold; color: var(--primary-light, #9d88ff);">Analyzing startup data... This may take a minute or two.</p>
                <style>@keyframes spin { to { transform: rotate(360deg); } }</style>
            </div>

            <div id="swotResults" style="display: none; grid-template-columns: 1fr 1fr; gap: 20px;">
                <!-- Strengths -->
                <div style="padding: 20px; border-radius: 15px; background: rgba(76,175,80,0.05); border: 1px solid rgba(76,175,80,0.2);">
                    <h3 style="color: #81c784; margin-top: 0; font-size: 1.3em; display: flex; align-items: center; gap: 10px;"><span style="font-size: 1.5em; opacity: 0.8;">💪</span> Strengths</h3>
                    <ul id="swotStrengthsList" style="padding-left: 20px; color: rgba(255,255,255,0.85); line-height: 1.6; margin-bottom: 0;"></ul>
                </div>
                
                <!-- Weaknesses -->
                <div style="padding: 20px; border-radius: 15px; background: rgba(255,152,0,0.05); border: 1px solid rgba(255,152,0,0.2);">
                    <h3 style="color: #ffb74d; margin-top: 0; font-size: 1.3em; display: flex; align-items: center; gap: 10px;"><span style="font-size: 1.5em; opacity: 0.8;">📉</span> Weaknesses</h3>
                    <ul id="swotWeaknessesList" style="padding-left: 20px; color: rgba(255,255,255,0.85); line-height: 1.6; margin-bottom: 0;"></ul>
                </div>

                <!-- Opportunities -->
                <div style="padding: 20px; border-radius: 15px; background: rgba(33,150,243,0.05); border: 1px solid rgba(33,150,243,0.2);">
                    <h3 style="color: #64b5f6; margin-top: 0; font-size: 1.3em; display: flex; align-items: center; gap: 10px;"><span style="font-size: 1.5em; opacity: 0.8;">🚀</span> Opportunities</h3>
                    <ul id="swotOpportunitiesList" style="padding-left: 20px; color: rgba(255,255,255,0.85); line-height: 1.6; margin-bottom: 0;"></ul>
                </div>

                <!-- Threats -->
                <div style="padding: 20px; border-radius: 15px; background: rgba(244,67,54,0.05); border: 1px solid rgba(244,67,54,0.2);">
                    <h3 style="color: #e57373; margin-top: 0; font-size: 1.3em; display: flex; align-items: center; gap: 10px;"><span style="font-size: 1.5em; opacity: 0.8;">⚠️</span> Threats</h3>
                    <ul id="swotThreatsList" style="padding-left: 20px; color: rgba(255,255,255,0.85); line-height: 1.6; margin-bottom: 0;"></ul>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const btn = document.getElementById('generateSwotBtn');
    const loading = document.getElementById('swotLoading');
    const results = document.getElementById('swotResults');
    const errorDiv = document.getElementById('swotError');
    
    // Lists
    const sList = document.getElementById('swotStrengthsList');
    const wList = document.getElementById('swotWeaknessesList');
    const oList = document.getElementById('swotOpportunitiesList');
    const tList = document.getElementById('swotThreatsList');

    if (!btn) return;

    btn.addEventListener('click', function() {
        // Reset states
        errorDiv.style.display = 'none';
        results.style.display = 'none';
        loading.style.display = 'block';
        btn.disabled = true;
        btn.style.opacity = '0.5';
        document.getElementById('swotBtnText').innerText = 'Generating...';
        
        fetch('{{ path("app_entrepreneur_startup_swot", {id: startup.startupID}) }}', {
            method: 'POST',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.json().then(data => ({ status: response.status, body: data })))
        .then(res => {
            if (res.status >= 400 || res.body.error) {
                let errStr = res.body.error || 'Unknown error occurred.';
                if (res.body.raw) {
                    errStr += '<br><small>' + res.body.raw + '</small>';
                }
                throw new Error(errStr);
            }
            
            // Success! Populate lists
            populateList(sList, res.body.strengths);
            populateList(wList, res.body.weaknesses);
            populateList(oList, res.body.opportunities);
            populateList(tList, res.body.threats);
            
            // Show results
            loading.style.display = 'none';
            results.style.display = 'grid';
            
            // Update button
            btn.disabled = false;
            btn.style.opacity = '1';
            document.getElementById('swotBtnText').innerText = 'Regenerate SWOT';
            
            // Scroll down a bit
            results.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        })
        .catch(error => {
            // Error handling
            loading.style.display = 'none';
            errorDiv.innerHTML = '<strong>Error:</strong> ' + error.message;
            errorDiv.style.display = 'block';
            
            btn.disabled = false;
            btn.style.opacity = '1';
            document.getElementById('swotBtnText').innerText = 'Try Again';
        });
    });
    
    function populateList(listEl, items) {
        listEl.innerHTML = '';
        if (!items || items.length === 0) {
            listEl.innerHTML = '<li><em style="opacity:0.5;">No items generated</em></li>';
            return;
        }
        items.forEach(item => {
            const li = document.createElement('li');
            li.style.marginBottom = '8px';
            li.innerText = item;
            listEl.appendChild(li);
        });
    }
});
</script>
{% endblock %}
