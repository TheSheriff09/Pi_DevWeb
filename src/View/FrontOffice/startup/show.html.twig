{% extends "FrontOffice/base.html.twig" %}

{% block title %}{{ startup.name }} - Startup Details{% endblock %}

{% block body %}
<div class="auth-container" style="min-height: 100vh; padding: 40px 20px;">
    <div class="auth-card" style="max-width: 1000px; margin: 0 auto; border-radius: 20px;">
        
        <!-- Startup Header -->
        <div style="display: flex; gap: 20px; align-items: flex-start; margin-bottom: 40px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 20px;">
            {% if startup.imageURL %}
                <img src="{{ startup.imageURL }}" alt="{{ startup.name }}" style="width: 120px; height: 120px; border-radius: 15px; object-fit: cover;">
            {% else %}
                <div style="width: 120px; height: 120px; border-radius: 15px; background: linear-gradient(135deg, var(--primary, #6f56ff), #b58bff); display: flex; align-items: center; justify-content: center; font-size: 3em; font-weight: bold; color: white;">
                    {{ startup.name|first|upper }}
                </div>
            {% endif %}
            
            <div style="flex: 1;">
                <h1 style="color: var(--primary, #6f56ff); margin: 0 0 10px 0; font-size: 2.5em;">{{ startup.name }}</h1>
                <p style="margin: 0 0 15px 0; font-size: 1.1em;">{{ startup.description }}</p>
                
                <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                    <span style="background: rgba(111,86,255,0.2); color: var(--primary-light, #9d88ff); padding: 5px 12px; border-radius: 20px; font-size: 0.9em;">Sector: {{ startup.sector|default('N/A') }}</span>
                    <span style="background: rgba(76,175,80,0.2); color: #81c784; padding: 5px 12px; border-radius: 20px; font-size: 0.9em;">Stage: {{ startup.stage|default('N/A') }}</span>
                    <span style="background: rgba(255,152,0,0.2); color: #ffb74d; padding: 5px 12px; border-radius: 20px; font-size: 0.9em;">Status: {{ startup.status|default('N/A') }}</span>
                </div>
            </div>

            <a href="{{ path('app_entrepreneur_startups') }}" class="pill-btn" style="border: 1px solid var(--primary); padding: 10px 20px; text-decoration: none;">&larr; Back to List</a>
        </div>

        <!-- Business Plan Section -->
        <div style="margin-top: 40px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h2 style="margin: 0; font-size: 1.8em; border-left: 4px solid var(--primary, #6f56ff); padding-left: 15px;">Business Plan</h2>
                {% if businessplan is null %}
                    <a href="{{ path('app_entrepreneur_businessplan_new', {'startupId': startup.startupID}) }}" class="pill-btn glow-btn" style="background: linear-gradient(135deg, #10b981, #34d399); padding: 10px 20px; text-decoration: none; display: inline-flex; align-items: center; gap: 8px;">
                        <span>+</span> Create Business Plan
                    </a>
                {% endif %}
            </div>

            {% if businessplan %}
                <div style="padding: 30px; border-radius: 15px; border: 1px solid rgba(111,86,255,0.2);">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 25px;">
                        <h3 style="color: var(--primary-light, #9d88ff); margin: 0; font-size: 1.5em;">{{ businessplan.title ?: 'Untitled Plan' }}</h3>
                        <div style="display: flex; gap: 10px;">
                            <a href="{{ path('app_entrepreneur_businessplan_edit', {'id': businessplan.businessPlanID}) }}" style="background: rgba(33,150,243,0.2); color: #64b5f6; padding: 8px 15px; border-radius: 8px; text-decoration: none; font-size: 0.9em; transition: all 0.2s;" onmouseover="this.style.background='rgba(33,150,243,0.3)'" onmouseout="this.style.background='rgba(33,150,243,0.2)'">Edit Plan</a>
                            <a href="{{ path('app_entrepreneur_businessplan_delete', {'id': businessplan.businessPlanID}) }}" onclick="return confirm('WARNING: Are you sure you want to permanently delete this business plan?')" style="background: rgba(244,67,54,0.2); color: #e57373; padding: 8px 15px; border-radius: 8px; text-decoration: none; font-size: 0.9em; transition: all 0.2s;" onmouseover="this.style.background='rgba(244,67,54,0.3)'" onmouseout="this.style.background='rgba(244,67,54,0.2)'">Delete Plan</a>
                        </div>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
                        <div>
                            <p style="color: var(--primary); margin-bottom: 5px; font-size: 0.85em; text-transform: uppercase;">Executive Summary / Description</p>
                            <p style="margin-top: 0; line-height: 1.6;">{{ businessplan.description|default('No description provided')|nl2br }}</p>
                        </div>
                        <div>
                            <p style="color: var(--primary); margin-bottom: 5px; font-size: 0.85em; text-transform: uppercase;">Value Proposition</p>
                            <p style="margin-top: 0; line-height: 1.6;">{{ businessplan.valueProposition|default('Not specified')|nl2br }}</p>
                        </div>
                        
                        <div>
                            <p style="color: var(--primary); margin-bottom: 5px; font-size: 0.85em; text-transform: uppercase;">Market Analysis</p>
                            <p style="margin-top: 0; line-height: 1.6;">{{ businessplan.marketAnalysis|default('Not specified')|nl2br }}</p>
                        </div>
                        <div>
                            <p style="color: var(--primary); margin-bottom: 5px; font-size: 0.85em; text-transform: uppercase;">Business Model</p>
                            <p style="margin-top: 0; line-height: 1.6;">{{ businessplan.businessModel|default('Not specified')|nl2br }}</p>
                        </div>

                        <div>
                            <p style="color: var(--primary); margin-bottom: 5px; font-size: 0.85em; text-transform: uppercase;">Financial Data</p>
                            <div style="background: rgba(111,86,255,0.05); padding: 15px; border-radius: 10px;">
                                <div style="margin-bottom: 10px;">
                                    <span style="font-weight: 500;">Funding Required:</span> 
                                    <strong style="color: #81c784; font-size: 1.2em;">${{ businessplan.fundingRequired|default(0)|number_format(0, '.', ',') }}</strong>
                                </div>
                                <div style="line-height: 1.5; font-size: 0.9em;">
                                    <strong style="display: block; margin-bottom: 5px;">Forecast:</strong>
                                    {{ businessplan.financialForecast|default('None')|nl2br }}
                                </div>
                            </div>
                        </div>

                        <div>
                            <p style="color: var(--primary); margin-bottom: 5px; font-size: 0.85em; text-transform: uppercase;">Roadmap & Status</p>
                            <div style="margin-bottom: 15px;">
                                <span style="background: rgba(255,152,0,0.2); color: #ffb74d; padding: 5px 12px; border-radius: 15px; font-size: 0.9em;">Status: {{ businessplan.status|default('Draft') }}</span>
                            </div>
                            <div style="line-height: 1.5; font-size: 0.9em;">
                                <strong style="display: block; margin-bottom: 5px;">Timeline:</strong>
                                {{ businessplan.timeline|default('Not defined')|nl2br }}
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div style="text-align: center; padding: 50px 20px; background: rgba(111,86,255,0.05); border-radius: 15px; border: 2px dashed rgba(111,86,255,0.2);">
                    <div style="font-size: 3em; margin-bottom: 15px; opacity: 0.8;">📄</div>
                    <h3 style="margin-bottom: 10px;">No Business Plan Yet</h3>
                    <p style="margin-bottom: 25px; max-width: 400px; margin-left: auto; margin-right: auto; opacity: 0.8;">A strong business plan increases your chances of getting evaluated positively and funded.</p>
                    <a href="{{ path('app_entrepreneur_businessplan_new', {'startupId': startup.startupID}) }}" class="pill-btn glow-btn" style="background: linear-gradient(135deg, #10b981, #34d399); padding: 10px 25px; text-decoration: none;">
                        Generate Business Plan
                    </a>
                </div>
            {% endif %}
        </div>

        <!-- Funding Applications Section -->
        <div style="margin-top: 50px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h2 style="margin: 0; font-size: 1.8em; border-left: 4px solid #34d399; padding-left: 15px;">Funding Applications</h2>
                <a href="{{ path('app_entrepreneur_funding_new', {'startupId': startup.startupID}) }}" class="pill-btn glow-btn" style="background: linear-gradient(135deg, #10b981, #34d399); padding: 10px 20px; text-decoration: none; display: inline-flex; align-items: center; gap: 8px;">
                    <span>💸</span> Apply for Funding
                </a>
            </div>

            {% if fundingApplications is defined and fundingApplications|length > 0 %}
                <div id="fundingAppsGrid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
                    {% for fn in fundingApplications %}
                        <div class="funding-app-card" style="padding: 20px; border-radius: 15px; border: 1px solid rgba(16, 185, 129, 0.2); background: rgba(16, 185, 129, 0.05);">
                            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px;">
                                <div>
                                    <h4 style="margin: 0; font-size: 1.25em; color: #34d399;">${{ fn.amount|number_format(0, '.', ',') }}</h4>
                                    <span style="font-size: 0.8em; opacity: 0.6;">Submitted: {{ fn.submissionDate|date('M d, Y') }}</span>
                                </div>
                                <span style="background: {% if fn.status == 'Approved' or fn.status == 'Accepted' %}rgba(76,175,80,0.2); color: #81c784;{% elseif fn.status == 'Pending' %}rgba(255,152,0,0.2); color: #ffb74d;{% else %}rgba(244,67,54,0.2); color: #e57373;{% endif %} padding: 4px 10px; border-radius: 12px; font-size: 0.85em;">
                                    {{ fn.status }}
                                </span>
                            </div>

                            <div style="font-size: 0.9em;">
                                <div style="margin-bottom: 10px;">
                                    <strong style="color: var(--primary); display: block; opacity: 0.8;">Reason:</strong>
                                    {{ fn.applicationReason }}
                                </div>
                                <div style="margin-bottom: 10px;">
                                    <strong style="color: var(--primary); display: block; opacity: 0.8;">Schedule:</strong>
                                    {{ fn.paymentSchedule }}
                                </div>
                                {% if fn.attachment %}
                                    <div style="margin-top: 15px; padding-top: 10px; border-top: 1px solid rgba(255,255,255,0.05);">
                                        <a href="{{ fn.attachment }}" target="_blank" style="color: #64b5f6; text-decoration: none; font-size: 0.85em;">&rarr; View Attached Material</a>
                                    </div>
                                {% endif %}
                                
                                <div style="margin-top: 15px; padding-top: 15px; border-top: 1px solid rgba(255,255,255,0.1); display: flex; align-items: center; justify-content: space-between;">
                                    {% if fn.status == 'Rejected' %}
                                        <a href="{{ path('app_counterfactual_simulate', {'id': fn.id}) }}" class="pill-btn glow-btn" style="background: linear-gradient(135deg, #e53935, #ff8a80); padding: 8px 15px; border: none; cursor: pointer; color: white; display: inline-flex; align-items: center; gap: 8px; font-size: 0.85em; border-radius: 12px; text-decoration: none;">
                                            <span>⚡</span> Counterfactual Simulator
                                        </a>
                                    {% else %}
                                        <button onclick="predictApproval({{ fn.id }}, this)" data-url="{{ path('app_entrepreneur_funding_predict', {'id': fn.id}) }}" class="pill-btn glow-btn" style="background: linear-gradient(135deg, #2196f3, #64b5f6); padding: 8px 15px; border: none; cursor: pointer; color: white; display: inline-flex; align-items: center; gap: 8px; font-size: 0.85em; border-radius: 12px; transition: all 0.3s;">
                                            <span>🔮</span> Predict Approval
                                        </button>
                                        <span id="pred-result-{{ fn.id }}" style="font-weight: bold; font-size: 1.1em; display: none; color: #fff;"></span>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>

                {% if fundingApplications|length > 6 %}
                    <div style="display: flex; justify-content: center; align-items: center; gap: 15px; margin-top: 25px;">
                        <button id="prevFundingAppBtn" class="pill-btn glow-btn" style="background: rgba(16, 185, 129, 0.1); border: 1px solid #10b981; color: #10b981; cursor: pointer; padding: 8px 15px; border-radius: 50%; font-weight: bold; width: 40px; height: 40px;" onclick="changeFundingPage(-1)">&larr;</button>
                        <span id="fundingPageInfo" style="color: rgba(255,255,255,0.7); font-size: 0.95em; font-weight: 500;">Page 1 of 3</span>
                        <button id="nextFundingAppBtn" class="pill-btn glow-btn" style="background: rgba(16, 185, 129, 0.1); border: 1px solid #10b981; color: #10b981; cursor: pointer; padding: 8px 15px; border-radius: 50%; font-weight: bold; width: 40px; height: 40px;" onclick="changeFundingPage(1)">&rarr;</button>
                    </div>
                    <script>
                        let currentFundingPage = 1;
                        const totalFundingApps = {{ fundingApplications|length }};
                        const appsPerPage = 6;
                        const totalFundingPages = Math.ceil(totalFundingApps / appsPerPage);
                        
                        function updateFundingAppsVisibility() {
                            const grid = document.getElementById('fundingAppsGrid');
                            if (!grid) return;
                            const cards = grid.getElementsByClassName('funding-app-card');
                            
                            for (let i = 0; i < cards.length; i++) {
                                if (i >= (currentFundingPage - 1) * appsPerPage && i < currentFundingPage * appsPerPage) {
                                    cards[i].style.display = 'block';
                                } else {
                                    cards[i].style.display = 'none';
                                }
                            }
                            
                            document.getElementById('fundingPageInfo').innerText = `Page ${currentFundingPage} of ${totalFundingPages}`;
                            document.getElementById('prevFundingAppBtn').disabled = currentFundingPage === 1;
                            document.getElementById('prevFundingAppBtn').style.opacity = currentFundingPage === 1 ? '0.3' : '1';
                            document.getElementById('nextFundingAppBtn').disabled = currentFundingPage === totalFundingPages;
                            document.getElementById('nextFundingAppBtn').style.opacity = currentFundingPage === totalFundingPages ? '0.3' : '1';
                        }
                        
                        function changeFundingPage(dir) {
                            currentFundingPage += dir;
                            if (currentFundingPage < 1) currentFundingPage = 1;
                            if (currentFundingPage > totalFundingPages) currentFundingPage = totalFundingPages;
                            updateFundingAppsVisibility();
                        }
                        
                        document.addEventListener('DOMContentLoaded', updateFundingAppsVisibility);
                    </script>
                {% endif %}
            {% else %}
                <div style="text-align: center; padding: 40px 20px; background: rgba(16, 185, 129, 0.05); border-radius: 15px; border: 2px dashed rgba(16, 185, 129, 0.2);">
                    <div style="font-size: 2.5em; margin-bottom: 15px; opacity: 0.8;">🌱</div>
                    <h3 style="margin-bottom: 10px;">No Applications Discovered</h3>
                    <p style="margin-bottom: 25px; max-width: 400px; margin-left: auto; margin-right: auto; opacity: 0.8;">Your project hasn't requested funding yet. Prepare a rock-solid business plan before you ask for capital!</p>
                </div>
            {% endif %}
        </div>

        <!-- SWOT Analysis Section -->
        <div style="margin-top: 50px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h2 style="margin: 0; font-size: 1.8em; border-left: 4px solid #b58bff; padding-left: 15px;">AI SWOT Analysis</h2>
                <button id="generateSwotBtn" class="pill-btn glow-btn" style="background: linear-gradient(135deg, #6f56ff, #b58bff); padding: 10px 20px; border: none; cursor: pointer; color: white; display: inline-flex; align-items: center; gap: 8px;">
                    <span id="swotBtnIcon">✨</span> <span id="swotBtnText">Generate SWOT with AI</span>
                </button>
            </div>
            
            <div id="swotError" style="display: none; padding: 15px; margin-bottom: 20px; background: rgba(244,67,54,0.1); border: 1px solid rgba(244,67,54,0.3); border-radius: 10px; color: #ff8a80;">
            </div>

            <div id="swotLoading" style="display: none; text-align: center; padding: 40px; background: rgba(111,86,255,0.05); border-radius: 15px; border: 1px dashed rgba(111,86,255,0.3);">
                <div style="display: inline-block; width: 30px; height: 30px; border: 3px solid rgba(111,86,255,0.3); border-radius: 50%; border-top-color: #6f56ff; animation: spin 1s ease-in-out infinite;"></div>
                <p style="margin-top: 15px; font-weight: bold; color: var(--primary-light, #9d88ff);">Analyzing startup data... This may take a minute or two.</p>
                <style>@keyframes spin { to { transform: rotate(360deg); } }</style>
            </div>

            <div id="swotResults" style="display: none; grid-template-columns: 1fr 1fr; gap: 20px;">
                <!-- Strengths -->
                <div style="padding: 20px; border-radius: 15px; background: rgba(76,175,80,0.05); border: 1px solid rgba(76,175,80,0.2);">
                    <h3 style="color: #81c784; margin-top: 0; font-size: 1.3em; display: flex; align-items: center; gap: 10px;"><span style="font-size: 1.5em; opacity: 0.8;">💪</span> Strengths</h3>
                    <ul id="swotStrengthsList" style="padding-left: 20px; color: rgba(255,255,255,0.85); line-height: 1.6; margin-bottom: 0;"></ul>
                </div>
                
                <!-- Weaknesses -->
                <div style="padding: 20px; border-radius: 15px; background: rgba(255,152,0,0.05); border: 1px solid rgba(255,152,0,0.2);">
                    <h3 style="color: #ffb74d; margin-top: 0; font-size: 1.3em; display: flex; align-items: center; gap: 10px;"><span style="font-size: 1.5em; opacity: 0.8;">📉</span> Weaknesses</h3>
                    <ul id="swotWeaknessesList" style="padding-left: 20px; color: rgba(255,255,255,0.85); line-height: 1.6; margin-bottom: 0;"></ul>
                </div>

                <!-- Opportunities -->
                <div style="padding: 20px; border-radius: 15px; background: rgba(33,150,243,0.05); border: 1px solid rgba(33,150,243,0.2);">
                    <h3 style="color: #64b5f6; margin-top: 0; font-size: 1.3em; display: flex; align-items: center; gap: 10px;"><span style="font-size: 1.5em; opacity: 0.8;">🚀</span> Opportunities</h3>
                    <ul id="swotOpportunitiesList" style="padding-left: 20px; color: rgba(255,255,255,0.85); line-height: 1.6; margin-bottom: 0;"></ul>
                </div>

                <!-- Threats -->
                <div style="padding: 20px; border-radius: 15px; background: rgba(244,67,54,0.05); border: 1px solid rgba(244,67,54,0.2);">
                    <h3 style="color: #e57373; margin-top: 0; font-size: 1.3em; display: flex; align-items: center; gap: 10px;"><span style="font-size: 1.5em; opacity: 0.8;">⚠️</span> Threats</h3>
                    <ul id="swotThreatsList" style="padding-left: 20px; color: rgba(255,255,255,0.85); line-height: 1.6; margin-bottom: 0;"></ul>
                </div>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 50px;">
            <!-- Currency Exchange Section -->
            <div style="background: rgba(111,86,255,0.05); border: 1px solid var(--primary-light, rgba(111, 86, 255, 0.2)); border-radius: 20px; padding: 25px; color: var(--text-main, #333);">
                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px; border-bottom: 1px solid rgba(111, 86, 255, 0.1); padding-bottom: 15px;">
                    <span style="font-size: 1.5rem;">💱</span>
                    <h2 style="margin: 0; font-size: 1.4rem; color: var(--primary, #6f56ff);">Currency Converter</h2>
                </div>
                
                <div style="display: flex; flex-direction: column; gap: 15px;">
                    <div>
                        <label style="display: block; font-size: 0.8rem; opacity: 0.7; margin-bottom: 6px; color: inherit;">Amount to Convert</label>
                        <input type="number" id="currAmount" value="1000" step="any" style="width: 100%; background: rgba(0,0,0,0.05); border: 1px solid rgba(122, 92, 255, 0.2); border-radius: 12px; padding: 12px; color: inherit; outline: none;">
                    </div>
                    
                    <div style="display: grid; grid-template-columns: 1fr auto 1fr; gap: 15px; align-items: center;">
                        <div>
                            <label style="display: block; font-size: 0.75rem; opacity: 0.7; margin-bottom: 4px; color: inherit;">From</label>
                            <select id="currFrom" style="width: 100%; background: rgba(0,0,0,0.05); border: 1px solid rgba(122, 92, 255, 0.2); border-radius: 10px; padding: 10px; color: inherit; outline: none; cursor: pointer;">
                                <option value="USD" style="color: #000;">USD</option>
                                <option value="EUR" style="color: #000;">EUR</option>
                                <option value="TND" style="color: #000;">TND</option>
                                <option value="GBP" style="color: #000;">GBP</option>
                            </select>
                        </div>
                        <div style="margin-top: 20px; opacity: 0.5;">⇌</div>
                        <div>
                            <label style="display: block; font-size: 0.75rem; opacity: 0.7; margin-bottom: 4px; color: inherit;">To</label>
                            <select id="currTo" style="width: 100%; background: rgba(0,0,0,0.05); border: 1px solid rgba(122, 92, 255, 0.2); border-radius: 10px; padding: 10px; color: inherit; outline: none; cursor: pointer;">
                                <option value="TND" style="color: #000;">TND</option>
                                <option value="USD" style="color: #000;">USD</option>
                                <option value="EUR" style="color: #000;">EUR</option>
                                <option value="GBP" style="color: #000;">GBP</option>
                            </select>
                        </div>
                    </div>
                    
                    <div id="currResultArea" style="background: rgba(16, 185, 129, 0.08); border: 1px solid rgba(16, 185, 129, 0.2); border-radius: 15px; padding: 20px; text-align: center; display: none; margin-top: 10px;">
                        <div style="font-size: 0.85rem; opacity: 0.8; margin-bottom: 4px; color: inherit;" id="currLabel">Result</div>
                        <div style="font-size: 1.8rem; font-weight: 800; color: #10b981;" id="currResult">--</div>
                        <div style="font-size: 0.75rem; opacity: 0.5; margin-top: 8px; color: inherit;" id="currRate">Rate: --</div>
                    </div>
                    
                    <button onclick="performConversion()" id="currBtnSend" class="pill-btn glow-btn" style="width: 100%; background: linear-gradient(135deg, #6f56ff, #9d88ff); border: none; border-radius: 12px; padding: 14px; color: #fff; font-weight: 700; cursor: pointer; transition: all 0.3s; margin-top: 5px;">Convert Now</button>
                </div>
            </div>

            <!-- AI Financial Forecast Input (Mini Version) -->
            <div style="background: var(--bg-card, rgba(255, 255, 255, 0.03)); border: 1px solid var(--primary-light, rgba(16, 185, 129, 0.2)); border-radius: 20px; padding: 25px;">
                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px; border-bottom: 1px solid rgba(16, 185, 129, 0.1); padding-bottom: 15px;">
                    <span style="font-size: 1.5rem;">📈</span>
                    <h2 style="margin: 0; font-size: 1.4rem; color: #10b981;">Quick Forecast</h2>
                </div>
                <div style="display: flex; flex-direction: column; gap: 12px;">
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                        <div>
                            <label style="display: block; font-size: 0.75rem; margin-bottom: 4px; opacity: 0.7; color: var(--text-main);">Revenue ($)</label>
                            <input type="number" id="forecastRev" value="10000" style="width: 100%; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 10px; color: var(--text-main);">
                        </div>
                        <div>
                            <label style="display: block; font-size: 0.75rem; margin-bottom: 4px; opacity: 0.7; color: var(--text-main);">Growth (%)</label>
                            <input type="number" id="forecastGrowth" value="10" style="width: 100%; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 10px; color: var(--text-main);">
                        </div>
                    </div>
                    <div>
                        <label style="display: block; font-size: 0.75rem; margin-bottom: 4px; opacity: 0.7; color: var(--text-main);">Monthly Expenses ($)</label>
                        <input type="number" id="forecastExp" value="8000" style="width: 100%; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 10px; color: var(--text-main);">
                    </div>
                    <button id="generateForecastBtn" class="pill-btn glow-btn" style="width: 100%; background: linear-gradient(135deg, #10b981, #34d399); border: none; border-radius: 12px; padding: 14px; color: #white; font-weight: 700; cursor: pointer; margin-top: 10px;">
                        Generate 12-Month Forecast
                    </button>
                </div>
            </div>
        </div>

        <!-- AI Financial Forecast Result Area (Full Width) -->
        <div style="margin-top: 30px;">

            <div id="forecastLoading" style="display: none; text-align: center; padding: 40px; background: rgba(16, 185, 129, 0.05); border-radius: 15px; border: 1px dashed rgba(16, 185, 129, 0.3);">
                <div style="display: inline-block; width: 30px; height: 30px; border: 3px solid rgba(16, 185, 129, 0.3); border-radius: 50%; border-top-color: #10b981; animation: spin 1s ease-in-out infinite;"></div>
                <p style="margin-top: 15px; font-weight: bold; color: #34d399;">Simulating financial models... This will only take a moment.</p>
            </div>

            <div id="forecastResults" style="display: none;">
                <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 15px; padding: 25px; margin-bottom: 20px;">
                    <h3 style="margin-top: 0; color: #34d399; font-size: 1.4em;">Investment Recommendation</h3>
                    <p id="forecastRec" style="font-size: 1.1em; line-height: 1.6; color: #fff; font-weight: 500; font-style: italic; border-left: 4px solid #34d399; padding-left: 20px;"></p>
                </div>

                <div style="overflow-x: auto; background: rgba(255,255,255,0.02); border-radius: 15px; border: 1px solid rgba(255,255,255,0.05);">
                    <table style="width: 100%; border-collapse: collapse; min-width: 600px;">
                        <thead>
                            <tr style="background: rgba(16, 185, 129, 0.1);">
                                <th style="padding: 15px; text-align: left; color: #34d399; border-bottom: 1px solid rgba(255,255,255,0.1);">Month</th>
                                <th style="padding: 15px; text-align: right; color: #34d399; border-bottom: 1px solid rgba(255,255,255,0.1);">Revenue</th>
                                <th style="padding: 15px; text-align: right; color: #34d399; border-bottom: 1px solid rgba(255,255,255,0.1);">Expenses</th>
                                <th style="padding: 15px; text-align: right; color: #34d399; border-bottom: 1px solid rgba(255,255,255,0.1);">Net Profit/Loss</th>
                            </tr>
                        </thead>
                        <tbody id="forecastTableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const btn = document.getElementById('generateSwotBtn');
    const loading = document.getElementById('swotLoading');
    const results = document.getElementById('swotResults');
    const errorDiv = document.getElementById('swotError');
    
    // Lists
    const sList = document.getElementById('swotStrengthsList');
    const wList = document.getElementById('swotWeaknessesList');
    const oList = document.getElementById('swotOpportunitiesList');
    const tList = document.getElementById('swotThreatsList');

    if (!btn) return;

    btn.addEventListener('click', function() {
        // Reset states
        errorDiv.style.display = 'none';
        results.style.display = 'none';
        loading.style.display = 'block';
        btn.disabled = true;
        btn.style.opacity = '0.5';
        document.getElementById('swotBtnText').innerText = 'Generating...';
        
        fetch('{{ path("app_entrepreneur_startup_swot", {id: startup.startupID}) }}', {
            method: 'POST',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.json().then(data => ({ status: response.status, body: data })))
        .then(res => {
            if (res.status >= 400 || res.body.error) {
                let errStr = res.body.error || 'Unknown error occurred.';
                if (res.body.raw) {
                    errStr += '<br><small>' + res.body.raw + '</small>';
                }
                throw new Error(errStr);
            }
            
            // Success! Populate lists
            populateList(sList, res.body.strengths);
            populateList(wList, res.body.weaknesses);
            populateList(oList, res.body.opportunities);
            populateList(tList, res.body.threats);
            
            // Show results
            loading.style.display = 'none';
            results.style.display = 'grid';
            
            // Update button
            btn.disabled = false;
            btn.style.opacity = '1';
            document.getElementById('swotBtnText').innerText = 'Regenerate SWOT';
            
            // Scroll down a bit
            results.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        })
        .catch(error => {
            // Error handling
            loading.style.display = 'none';
            errorDiv.innerHTML = '<strong>Error:</strong> ' + error.message;
            errorDiv.style.display = 'block';
            
            btn.disabled = false;
            btn.style.opacity = '1';
            document.getElementById('swotBtnText').innerText = 'Try Again';
        });
    });
    
    // Currency Conversion Logic
    window.performConversion = function() {
        const amount = document.getElementById('currAmount').value;
        const from = document.getElementById('currFrom').value;
        const to = document.getElementById('currTo').value;
        const resultArea = document.getElementById('currResultArea');
        const btn = document.getElementById('currBtnSend');
        
        if (!amount || amount <= 0) {
            alert('Please enter a valid amount');
            return;
        }
        
        btn.disabled = true;
        btn.innerText = 'Calculating...';
        
        fetch(`/api/currency/convert?amount=${amount}&from=${from}&to=${to}`)
            .then(res => res.json())
            .then(data => {
                btn.disabled = false;
                btn.innerText = 'Convert Now';
                
                if (data.error) {
                    alert('Error: ' + data.error);
                    return;
                }
                
                document.getElementById('currResult').innerText = data.converted.toLocaleString() + ' ' + to;
                document.getElementById('currRate').innerText = `1 ${from} = ${data.rate} ${to}`;
                document.getElementById('currLabel').innerText = `${amount} ${from} is equal to`;
                resultArea.style.display = 'block';
            })
            .catch(err => {
                btn.disabled = false;
                btn.innerText = 'Convert Now';
                alert('Error connecting to currency service');
            });
    }

    // Financial Forecast Logic
    const forecastBtn = document.getElementById('generateForecastBtn');
    const forecastLoading = document.getElementById('forecastLoading');
    const forecastResults = document.getElementById('forecastResults');
    const forecastTableBody = document.getElementById('forecastTableBody');
    const forecastRec = document.getElementById('forecastRec');

    if (forecastBtn) {
        forecastBtn.addEventListener('click', function() {
            const rev = document.getElementById('forecastRev').value;
            const growth = document.getElementById('forecastGrowth').value;
            const exp = document.getElementById('forecastExp').value;

            // Reset UI
            forecastResults.style.display = 'none';
            forecastLoading.style.display = 'block';
            forecastBtn.disabled = true;
            forecastBtn.style.opacity = '0.5';

            const formData = new FormData();
            formData.append('revenue', rev);
            formData.append('growth', growth);
            formData.append('expenses', exp);

            fetch('{{ path("app_entrepreneur_startup_forecast", {id: startup.startupID}) }}', {
                method: 'POST',
                body: formData,
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(res => res.json())
            .then(data => {
                forecastLoading.style.display = 'none';
                forecastBtn.disabled = false;
                forecastBtn.style.opacity = '1';

                if (data.error) {
                    alert('Error: ' + data.error);
                    return;
                }

                // Populate Recommendation
                forecastRec.innerText = data.recommendation;

                // Populate Table
                forecastTableBody.innerHTML = '';
                data.forecast.forEach(m => {
                    const tr = document.createElement('tr');
                    tr.style.borderBottom = '1px solid rgba(255,255,255,0.05)';
                    const profitColor = m.profit >= 0 ? '#81c784' : '#e57373';
                    tr.innerHTML = `
                        <td style="padding: 12px 15px; color: #fff;">Month ${m.month}</td>
                        <td style="padding: 12px 15px; text-align: right;">$${m.revenue.toLocaleString()}</td>
                        <td style="padding: 12px 15px; text-align: right;">$${m.expenses.toLocaleString()}</td>
                        <td style="padding: 12px 15px; text-align: right; color: ${profitColor}; font-weight: bold;">$${m.profit.toLocaleString()}</td>
                    `;
                    forecastTableBody.appendChild(tr);
                });

                forecastResults.style.display = 'block';
                forecastResults.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            })
            .catch(err => {
                forecastLoading.style.display = 'none';
                forecastBtn.disabled = false;
                forecastBtn.style.opacity = '1';
                alert('Error generating forecast');
            });
        });
    }

    function populateList(listEl, items) {
        listEl.innerHTML = '';
        if (!items || items.length === 0) {
            listEl.innerHTML = '<li><em style="opacity:0.5;">No items generated</em></li>';
            return;
        }
        items.forEach(item => {
            const li = document.createElement('li');
            li.style.marginBottom = '8px';
            li.innerText = item;
            listEl.appendChild(li);
        });
    }
});

function predictApproval(applicationId, btn) {
    const url = btn.getAttribute('data-url');
    const resultSpan = document.getElementById('pred-result-' + applicationId);
    const originalText = btn.innerHTML;
    
    btn.innerHTML = '<div style="width:16px;height:16px;border:2px solid #fff;border-top:2px solid transparent;border-radius:50%;animation:spin 1s linear infinite;"></div> <span>Predicting...</span>';
    btn.disabled = true;
    btn.style.opacity = '0.7';
    resultSpan.style.display = 'none';
    
    fetch(url, {
        method: 'POST',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        btn.innerHTML = originalText;
        btn.disabled = false;
        btn.style.opacity = '1';
        
        if (data.error) {
            alert('Prediction Error: ' + data.error);
        } else if (data.probability !== undefined) {
            const prob = (data.probability * 100).toFixed(1);
            resultSpan.innerHTML = prob + '% Likely';
            resultSpan.style.color = data.probability > 0.5 ? '#81c784' : '#e57373';
            resultSpan.style.display = 'block';
        }
    })
    .catch(error => {
        btn.innerHTML = originalText;
        btn.disabled = false;
        btn.style.opacity = '1';
        alert('An error occurred predicting the application approval likelihood.');
    });
}
</script>
{% endblock %}
