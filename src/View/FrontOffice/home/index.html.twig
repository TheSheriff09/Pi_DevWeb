{% extends 'FrontOffice/base.html.twig' %}

{% block title %}StartupFlow Tunisia - Home{% endblock %}

{% block body %}
    <style>
        /* Optional: add some top margin to hero if navbar overlaps, but sticky top:0 usually pushes it down implicitly */
    </style>

    <!-- Hero Content -->
    <main class="hero-container">
        <!-- Left text -->
        <div class="hero-left">
            <h1 class="hero-title">StartupFlow Tunisia</h1>
            <p class="hero-subtitle">Startup Incubation &amp; Innovation Management Platform</p>

            <div class="cta-row">
                <a href="#" class="btn-cta glow-btn">GET STARTED</a>
                <a href="#" class="btn-cta-outline">GET INCORPORATED</a>
            </div>
        </div>

        <!-- Right image (3D Cube) -->
        <div class="hero-right" id="threed-cube-container" style="width: 100%; height: 480px; display: flex; justify-content: center; align-items: center;">
            <!-- Three.js Canvas -->
        </div>
    </main>

{% endblock %}

{% block javascripts %}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const container = document.getElementById('threed-cube-container');
            
            if (!container) return;

            // 3D Scene setup
            const scene = new THREE.Scene();
            const camera = new THREE.PerspectiveCamera(75, container.clientWidth / container.clientHeight, 0.1, 1000);
            const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
            
            renderer.setSize(container.clientWidth, container.clientHeight);
            renderer.setPixelRatio(window.devicePixelRatio);
            container.appendChild(renderer.domElement);

            // Futuristic Cube (Outer wireframe)
            const geometry = new THREE.BoxGeometry(2.5, 2.5, 2.5);
            const material = new THREE.MeshStandardMaterial({  
                color: 0x7a5cff,
                wireframe: true,
                emissive: 0x6f56ff,
                emissiveIntensity: 0.8,
                transparent: true,
                opacity: 0.9
            });
            const cube = new THREE.Mesh(geometry, material);
            scene.add(cube);

            // Inner solid core
            const coreGeometry = new THREE.BoxGeometry(1.8, 1.8, 1.8);
            const coreMaterial = new THREE.MeshPhongMaterial({
                color: 0xcdb5ff,
                shininess: 150,
                transparent: true,
                opacity: 0.8
            });
            const core = new THREE.Mesh(coreGeometry, coreMaterial);
            scene.add(core);

            // Particles
            const particleGeo = new THREE.BufferGeometry();
            const particleCount = 200;
            const posArray = new Float32Array(particleCount * 3);
            for(let i=0; i<particleCount*3; i++) {
                posArray[i] = (Math.random() - 0.5) * 10;
            }
            particleGeo.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
            const particleMat = new THREE.PointsMaterial({
                size: 0.05,
                color: 0xcdb5ff,
                transparent: true,
                opacity: 0.6
            });
            const particles = new THREE.Points(particleGeo, particleMat);
            scene.add(particles);

            // Lighting
            const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
            scene.add(ambientLight);

            const pointLight = new THREE.PointLight(0xffffff, 2);
            pointLight.position.set(5, 5, 5);
            scene.add(pointLight);

            const pointLight2 = new THREE.PointLight(0x7a5cff, 2);
            pointLight2.position.set(-5, -5, -5);
            scene.add(pointLight2);

            camera.position.z = 5;

            // Animation Loop
            function animate() {
                requestAnimationFrame(animate);
                
                // Rotate cube and core
                cube.rotation.x += 0.005;
                cube.rotation.y += 0.01;
                
                core.rotation.x -= 0.008;
                core.rotation.y -= 0.008;

                // Rotate particles slowly
                particles.rotation.y += 0.002;
                particles.rotation.x += 0.001;

                renderer.render(scene, camera);
            }

            animate();

            // Responsive resize
            window.addEventListener('resize', () => {
                if (container) {
                    camera.aspect = container.clientWidth / container.clientHeight;
                    camera.updateProjectionMatrix();
                    renderer.setSize(container.clientWidth, container.clientHeight);
                }
            });
        });
    </script>
{% endblock %}
