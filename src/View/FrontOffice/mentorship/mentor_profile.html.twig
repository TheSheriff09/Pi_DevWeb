{% extends 'FrontOffice/base.html.twig' %}

{% block title %}{{ mentor.fullName }} - Profile{% endblock %}

{% block body %}
<div class="container" style="padding: 40px 20px; max-width: 900px; margin: auto;">
    
    <a href="{{ path('app_mentors_list') }}" style="color: var(--primary-light); text-decoration: none; margin-bottom: 20px; display: inline-block;">&larr; Back to Mentors</a>

    <div class="mentorship-card" style="padding: 40px; display: flex; gap: 30px; margin-bottom: 30px; align-items: center; flex-wrap: wrap;">
        <div style="width: 120px; height: 120px; background: linear-gradient(135deg, #6f56ff, #d2a7ff); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 3em; font-weight: bold; color: white; flex-shrink: 0;">
            {{ mentor.fullName|slice(0,1)|upper }}
        </div>
        
        <div style="flex: 1;">
            <div style="display: flex; align-items: center; gap: 15px;">
                <h2 style="margin: 0; color: var(--text-main); font-size: 2.5em;">{{ mentor.fullName }}</h2>
                <button class="favorite-btn btn-pill" data-id="{{ mentor.id }}" style="padding: 8px 15px; background: transparent; border: 1px solid rgba(122,92,255,0.3); color: {{ isFavorite ? '#ff5656' : 'var(--text-main)' }}; cursor: pointer; font-size: 1.2em;">
                    {% if isFavorite %}❤️{% else %}🤍{% endif %}
                </button>
            </div>
            
            <p style="color: var(--primary); font-size: 1.1em; margin: 10px 0 20px;">
                {{ mentor.mentorExpertise ?: 'Experienced Business Mentor' }}
            </p>
            
            <div style="color: var(--text-main); opacity: 0.8; line-height: 1.6;">
                <p style="margin: 0;">Status: <span style="background: rgba(46, 204, 113, 0.15); color: #2ecc71; padding: 3px 8px; border-radius: 10px; font-size: 0.8em; font-weight: bold; border: 1px solid #2ecc71;">Active</span></p>
            </div>
        </div>
    </div>

    <!-- Booking Section -->
    <h3 style="color: var(--text-main, #fff); font-size: 1.5em; margin-bottom: 20px;">Available Weekly Schedule</h3>
    
    <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 10px; margin-bottom: 40px; overflow-x: auto; padding-bottom: 15px;">
        {% for day, slots in groupedSchedule %}
            <div style="background: rgba(122,92,255,0.03); border: 1px solid rgba(122,92,255,0.1); border-radius: 8px; min-width: 100px;">
                <div style="text-align: center; padding: 10px; border-bottom: 1px solid rgba(122,92,255,0.1); font-weight: bold; color: var(--primary); font-size: 0.9em;">
                    {{ day|slice(0,3) }}
                </div>
                <div style="padding: 10px; display: flex; flex-direction: column; gap: 8px;">
                    {% for slot in slots %}
                        <a href="{{ path('app_mentorship_book', {'mentorId': mentor.id, 'scheduleId': slot.scheduleID}) }}" 
                           class="btn-pill" style="display: block; text-align: center; background: rgba(111,86,255,0.15); border: 1px solid var(--primary); color: var(--primary); padding: 6px; text-decoration: none; border-radius: 4px; font-size: 0.85em; transition: background 0.2s;" title="Book for {{ slot.availableDate|date('M j') }}">
                            {{ slot.startTime|date('H:i') }}
                        </a>
                    {% else %}
                        <div style="text-align: center; opacity: 0.4; color: var(--text-main); font-size: 0.8em; padding: 10px 0;">-</div>
                    {% endfor %}
                </div>
            </div>
        {% endfor %}
    </div>

    <!-- Mentor Reviews / Evaluations section -->
    <div class="mentorship-card" style="margin-top: 30px; text-align: left;">
        <h3 style="margin-top: 0; display: flex; align-items: center; justify-content: space-between;">
            Session Reviews 
            <span style="font-size: 0.9em; background: rgba(241, 196, 15, 0.2); color: #f1c40f; padding: 5px 10px; border-radius: 8px;">
                ⭐ {{ avgRating }} / 5.0 ({{ evaluations|length }} reviews)
            </span>
        </h3>
        <hr style="border: 0; border-top: 1px solid rgba(122,92,255,0.1); margin: 20px 0;">
        
        {% if evaluations is empty %}
            <p style="text-align: center; opacity: 0.6;">This mentor hasn't received any reviews yet.</p>
        {% else %}
            <div style="display: flex; flex-direction: column; gap: 15px;">
                {% for review in evaluations %}
                    <div style="background: rgba(122,92,255,0.05); border-radius: 8px; padding: 15px; border: 1px solid rgba(122,92,255,0.1);">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
                            <strong style="color: var(--primary);">{{ review.rating }} / 5 ⭐</strong>
                            <small style="opacity: 0.6;">{{ review.createdAt|date('M j, Y') }}</small>
                        </div>
                        <p style="margin: 0; font-size: 0.95em;">"{{ review.comment }}"</p>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>

</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const favBtn = document.querySelector('.favorite-btn');
    if(favBtn) {
        favBtn.addEventListener('click', () => {
            const mentorId = favBtn.getAttribute('data-id');
            fetch(`/mentorship/mentor/${mentorId}/toggle-favorite`, { method: 'POST' })
            .then(res => res.json())
            .then(data => {
                if(data.status === 'success') {
                    favBtn.innerHTML = data.action === 'added' ? '❤️' : '🤍';
                    favBtn.style.color = data.action === 'added' ? '#ff5656' : 'var(--text-main)';
                }
            });
        });
    }
});
</script>
{% endblock %}
