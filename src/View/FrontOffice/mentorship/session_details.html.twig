{% extends 'FrontOffice/base.html.twig' %}

{% block title %}Session Details - StartupFlow{% endblock %}

{% block body %}
<div class="container" style="padding: 40px 20px; max-width: 1100px; margin: auto;">
    
    <a href="{{ path('app_my_sessions') }}" style="color: var(--primary-light); text-decoration: none; margin-bottom: 20px; display: inline-block;">&larr; Back to Sessions</a>

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
        <h2 style="margin: 0;">Session Workspace</h2>
        {% set today = date() %}
        {% set sDate = sessionObj.sessionDate|date('Y-m-d') %}
        {% set cDate = today|date('Y-m-d') %}
        {% if sDate < cDate %}
            {% set dynStatus = 'Completed' %}
            {% set dynColor = '#95a5a6' %}
        {% elseif sDate == cDate %}
            {% set dynStatus = 'Ongoing' %}
            {% set dynColor = '#3498db' %}
        {% else %}
            {% set dynStatus = 'Upcoming' %}
            {% set dynColor = '#2ecc71' %}
        {% endif %}
        
        <div style="display: flex; gap: 15px; align-items: center;">
            <span style="background: rgba(255,255,255,0.8); border: 1px solid {{ dynColor }}; padding: 6px 12px; border-radius: 8px; font-weight: bold; color: {{ dynColor }};">{{ dynStatus }}</span>
            {% if dynStatus == 'Ongoing' and sessionObj.status != 'Completed' %}
                <a href="{{ sessionObj.meetingLink|default('https://meet.jit.si/Mentorship_' ~ sessionObj.sessionID) }}" target="_blank" class="btn-pill" style="background: #e74c3c; color: white; padding: 10px 20px; text-decoration: none; font-weight: bold; display: flex; align-items: center; gap: 8px; border-radius: 8px; box-shadow: 0 4px 15px rgba(231, 76, 60, 0.4);">
                    🎥 Join Video Session
                </a>
            {% endif %}
        </div>
    </div>

    <!-- Tabs Header -->
    <div style="display: flex; gap: 10px; border-bottom: 1px solid rgba(122,92,255,0.2); margin-bottom: 20px;">
        <button class="ws-tab active" onclick="showTab('info')" style="background: none; border: none; padding: 12px 20px; color: var(--primary); border-bottom: 2px solid var(--primary); cursor: pointer; font-size: 16px; font-weight: bold;">Information</button>
        <button class="ws-tab" onclick="showTab('todos')" style="background: none; border: none; padding: 12px 20px; color: #888; cursor: pointer; font-size: 16px; font-weight: bold;">Todos <span style="background:rgba(122,92,255,0.1); padding:2px 8px; border-radius:12px; font-size:12px;">{{ todos|length }}</span></button>
        <button class="ws-tab" onclick="showTab('notes')" style="background: none; border: none; padding: 12px 20px; color: #888; cursor: pointer; font-size: 16px; font-weight: bold;">Notes <span style="background:rgba(122,92,255,0.1); padding:2px 8px; border-radius:12px; font-size:12px;">{{ notes|length }}</span></button>
        {% if role == 'ENTREPRENEUR' %}
        <button class="ws-tab" onclick="showTab('feedback')" style="background: none; border: none; padding: 12px 20px; color: #888; cursor: pointer; font-size: 16px; font-weight: bold;">Feedback</button>
        {% endif %}
    </div>

    <!-- Tabs Content -->
    
    <!-- INFO TAB -->
    <div id="tab-info" class="ws-content mentorship-card" style="padding: 30px;">
        <h3 style="margin-top: 0; color: var(--text-main);">Session Overview</h3>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 20px;">
            <div style="background: rgba(122,92,255,0.05); padding: 20px; border-radius: 12px;">
                <p style="color: #888; margin-bottom: 5px;">{% if role == 'MENTOR' %}Entrepreneur{% else %}Mentor{% endif %}</p>
                <p style="font-size: 18px; font-weight: bold; margin: 0; color: var(--primary);">{{ partner.fullName }}</p>
            </div>
            <div style="background: rgba(122,92,255,0.05); padding: 20px; border-radius: 12px;">
                <p style="color: #888; margin-bottom: 5px;">Date & Time</p>
                <p style="font-size: 18px; font-weight: bold; margin: 0;">{{ sessionObj.sessionDate|date('D, M j, Y') }}</p>
            </div>
            <div style="background: rgba(122,92,255,0.05); padding: 20px; border-radius: 12px;">
                <p style="color: #888; margin-bottom: 5px;">Session Type</p>
                <p style="font-size: 18px; font-weight: bold; margin: 0;">{{ sessionObj.sessionType }}</p>
            </div>
            <div style="background: rgba(122,92,255,0.05); padding: 20px; border-radius: 12px;">
                <p style="color: #888; margin-bottom: 5px;">Meeting Link</p>
                <p style="font-size: 14px; font-weight: bold; margin: 0; word-break: break-all; color: var(--primary-light);">{{ sessionObj.meetingLink|default('https://meet.jit.si/Mentorship_' ~ sessionObj.sessionID) }}</p>
            </div>
        </div>
    </div>

    <!-- TODOS TAB -->
    <div id="tab-todos" class="ws-content mentorship-card" style="padding: 30px; display: none;">
        <h3 style="margin-top: 0; border-bottom: 1px solid rgba(122,92,255,0.1); padding-bottom: 10px;">Action Items (To-Dos)</h3>
        
        <div style="margin-top: 15px;">
            {% for todo in todos %}
                <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 10px; background: rgba(122,92,255,0.05); padding: 15px; border-radius: 8px; border: 1px solid rgba(122,92,255,0.1);">
                    {% if role == 'ENTREPRENEUR' %}
                        <input type="checkbox" class="todo-check" data-id="{{ todo.id }}" {% if todo.getIsDone() %}checked{% endif %} style="transform: scale(1.3); cursor: pointer;">
                    {% else %}
                        <span style="font-size: 1.2em;">
                            {% if todo.getIsDone() %}✅{% else %}⭕{% endif %}
                        </span>
                    {% endif %}
                    <span style="text-decoration: {{ todo.getIsDone() ? 'line-through' : 'none' }}; flex: 1; font-size: 16px;">
                        {{ todo.taskDescription }}
                    </span>
                    {% if role == 'MENTOR' %}
                        <div style="display: flex; gap: 10px;">
                            <button type="button" onclick="editTodo({{ todo.id }}, '{{ todo.taskDescription|escape('js') }}')" style="background:transparent; border:none; cursor:pointer; font-size: 18px;" title="Edit">✏️</button>
                            <button type="button" onclick="deleteTodo({{ todo.id }})" style="background:transparent; border:none; cursor:pointer; font-size: 18px;" title="Delete">🗑️</button>
                        </div>
                    {% endif %}
                </div>
            {% else %}
                <p style="opacity: 0.6; font-style: italic; text-align: center; padding: 20px;">No to-dos assigned yet.</p>
            {% endfor %}
        </div>

        {% if role == 'MENTOR' %}
            <form method="post" style="margin-top: 25px; display: flex; gap: 10px;">
                <input type="text" name="todo_content" placeholder="Add a new task for the entrepreneur..." required style="flex: 1; padding: 12px; border-radius: 8px; border: 1px solid rgba(122,92,255,0.3); background: transparent; color: var(--text-main);">
                <button type="submit" class="btn-pill" style="background: var(--primary); color: white; border: none; padding: 12px 25px; font-weight: bold;">Add Todo</button>
            </form>
        {% endif %}
    </div>

    <!-- NOTES TAB -->
    <div id="tab-notes" class="ws-content mentorship-card" style="padding: 30px; display: none;">
        <h3 style="margin-top: 0; border-bottom: 1px solid rgba(122,92,255,0.1); padding-bottom: 10px;">Session Notes</h3>
        
        <div style="margin-top: 15px;">
            {% for note in notes %}
                <div style="background: rgba(111,86,255,0.05); border-left: 4px solid var(--primary); padding: 20px; border-radius: 6px; margin-bottom: 15px;">
                    <p style="margin: 0 0 10px; line-height: 1.6; font-size: 16px;">{{ note.notes|nl2br }}</p>
                    <small style="color: var(--primary-light); font-weight: bold;">{{ note.noteDate|date('d M Y - H:i') }}</small>
                </div>
            {% else %}
                <p style="opacity: 0.6; font-style: italic; text-align: center; padding: 20px;">No notes recorded yet.</p>
            {% endfor %}
        </div>

        {% if role == 'MENTOR' %}
            <form method="post" style="margin-top: 25px;">
                <textarea name="note_content" rows="4" placeholder="Write session notes (visible to entrepreneur)..." required style="width: 100%; border-radius: 8px; border: 1px solid rgba(122,92,255,0.3); background: transparent; color: var(--text-main); padding: 15px; margin-bottom: 15px; box-sizing: border-box;"></textarea>
                <button type="submit" class="btn-pill" style="background: var(--primary); color: white; border: none; padding: 12px 25px; font-weight: bold;">Save Note</button>
            </form>
        {% endif %}
    </div>

    {% if role == 'ENTREPRENEUR' %}
    <!-- FEEDBACK TAB -->
    <div id="tab-feedback" class="ws-content mentorship-card" style="padding: 30px; display: none;">
        <h3 style="margin-top: 0; border-bottom: 1px solid rgba(122,92,255,0.1); padding-bottom: 10px;">Provide Feedback</h3>
        <form method="post" action="{{ path('app_session_feedback', {'id': sessionObj.sessionID}) }}" style="margin-top: 20px;">
            <div style="margin-bottom: 20px;">
                <label style="display: inline-block; margin-bottom: 8px; font-weight: bold; color: var(--primary-light);">Rate this Session (1-5)</label>
                <select name="rating" style="width: 100%; border-radius: 8px; border: 2px solid rgba(122,92,255,0.3); background: transparent; color: var(--text-main); padding: 12px; font-size: 16px; cursor: pointer;">
                    <option value="5" style="background: var(--bg-light); color: var(--text-main);">★★★★★ (5) - Excellent</option>
                    <option value="4" style="background: var(--bg-light); color: var(--text-main);">★★★★☆ (4) - Very Good</option>
                    <option value="3" style="background: var(--bg-light); color: var(--text-main);">★★★☆☆ (3) - Good</option>
                    <option value="2" style="background: var(--bg-light); color: var(--text-main);">★★☆☆☆ (2) - Fair</option>
                    <option value="1" style="background: var(--bg-light); color: var(--text-main);">★☆☆☆☆ (1) - Poor</option>
                </select>
            </div>
            <div style="margin-bottom: 20px;">
                <label style="display: inline-block; margin-bottom: 8px; font-weight: bold; color: var(--primary-light);">Add a Comment</label>
                <textarea name="comment" rows="4" placeholder="How was your session? What did you learn?" style="width: 100%; border-radius: 8px; border: 2px solid rgba(122,92,255,0.3); background: transparent; color: var(--text-main); padding: 15px; box-sizing: border-box; font-size: 16px;"></textarea>
            </div>
            <button type="submit" class="btn-pill" style="background: #2ecc71; color: white; border: none; padding: 12px 25px; font-weight: bold; font-size: 16px; width: 100%; cursor: pointer;">Submit Feedback</button>
        </form>
    </div>
    {% endif %}

    <script>
        function showTab(tabName) {
            document.querySelectorAll('.ws-content').forEach(el => el.style.display = 'none');
            document.querySelectorAll('.ws-tab').forEach(btn => {
                btn.style.color = '#888';
                btn.style.borderBottom = 'none';
                btn.classList.remove('active');
            });
            document.getElementById('tab-' + tabName).style.display = 'block';
            event.currentTarget.style.color = 'var(--primary)';
            event.currentTarget.style.borderBottom = '2px solid var(--primary)';
            event.currentTarget.classList.add('active');
        }
    </script>
</div>

{% if role == 'ENTREPRENEUR' %}
<script>
document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.todo-check').forEach(chk => {
        chk.addEventListener('change', (e) => {
            const isDone = e.target.checked;
            const todoId = e.target.getAttribute('data-id');
            const span = e.target.nextElementSibling;
            
            // Optimistic UI update
            if(isDone) {
                span.style.textDecoration = 'line-through';
                span.style.opacity = '0.5';
            } else {
                span.style.textDecoration = 'none';
                span.style.opacity = '1';
            }

            const formData = new FormData();
            formData.append('isDone', isDone);

            fetch(`/mentorship/session/todo/${todoId}/toggle`, {
                method: 'POST',
                body: formData
            }).then(res => res.json()).then(data => {
                if(data.status !== 'success') {
                    alert('Error updating todo status.');
                }
            });
        });
    });
});
</script>
{% endif %}

{% if role == 'MENTOR' %}
<!-- Edit Todo Modal -->
<div id="editTodoModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); z-index: 1000; align-items: center; justify-content: center;">
    <div style="background: var(--bg-light); padding: 30px; border-radius: 12px; border: 1px solid rgba(122,92,255,0.2); width: 100%; max-width: 400px; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
        <h3 style="margin-top: 0; color: var(--text-main);">Edit Task</h3>
        <input type="hidden" id="editTodoId">
        <input type="text" id="editTodoInput" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid rgba(122,92,255,0.3); background: transparent; color: var(--text-main); margin-bottom: 20px; box-sizing: border-box;">
        <div style="display: flex; gap: 10px; justify-content: flex-end;">
            <button type="button" onclick="closeEditModal()" class="btn-pill" style="background: transparent; border: 1px solid rgba(255,255,255,0.3); color: var(--text-main); padding: 8px 15px; cursor: pointer;">Cancel</button>
            <button type="button" onclick="saveTodoEdit()" class="btn-pill" style="background: var(--primary); border: none; color: white; padding: 8px 20px; cursor: pointer;">Save</button>
        </div>
    </div>
</div>
<!-- Delete Todo Modal -->
<div id="deleteTodoModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); z-index: 1000; align-items: center; justify-content: center;">
    <div style="background: var(--bg-light); padding: 30px; border-radius: 12px; border: 1px solid rgba(122,92,255,0.2); width: 100%; max-width: 400px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); text-align: center;">
        <h3 style="margin-top: 0; color: var(--text-main);">Confirm Deletion</h3>
        <p style="color: var(--text-main); opacity: 0.8; margin-bottom: 25px;">Are you sure you want to permanently delete this to-do task?</p>
        <div style="display: flex; gap: 10px; justify-content: center;">
            <button type="button" onclick="closeDeleteModal()" class="btn-pill" style="background: transparent; border: 1px solid rgba(255,255,255,0.3); color: var(--text-main); padding: 8px 20px; cursor: pointer;">Cancel</button>
            <button type="button" onclick="confirmDeleteTodo()" class="btn-pill" style="background: #e74c3c; border: none; color: white; padding: 8px 20px; cursor: pointer;">Delete</button>
        </div>
    </div>
</div>
<script>
let currentEditOldDesc = '';
let currentDeleteTodoId = null;

function editTodo(id, oldDesc) {
    document.getElementById('editTodoId').value = id;
    document.getElementById('editTodoInput').value = oldDesc;
    currentEditOldDesc = oldDesc;
    document.getElementById('editTodoModal').style.display = 'flex';
}

function closeEditModal() {
    document.getElementById('editTodoModal').style.display = 'none';
}

function saveTodoEdit() {
    const id = document.getElementById('editTodoId').value;
    const newDesc = document.getElementById('editTodoInput').value;
    if(newDesc && newDesc !== currentEditOldDesc) {
        const fd = new FormData();
        fd.append('description', newDesc);
        fetch(`/mentorship/session/todo/${id}/edit`, {method:'POST', body:fd})
        .then(r=>r.json()).then(d=>{ if(d.status==='success') location.reload(); });
    } else {
        closeEditModal();
    }
}

function deleteTodo(id) {
    currentDeleteTodoId = id;
    document.getElementById('deleteTodoModal').style.display = 'flex';
}

function confirmDeleteTodo() {
    if(currentDeleteTodoId) {
        fetch(`/mentorship/session/todo/${currentDeleteTodoId}/delete`, {method:'POST'})
        .then(r=>r.json()).then(d=>{ if(d.status==='success') location.reload(); });
    }
}

function closeDeleteModal() {
    document.getElementById('deleteTodoModal').style.display = 'none';
    currentDeleteTodoId = null;
}
</script>
{% endif %}
{% endblock %}
