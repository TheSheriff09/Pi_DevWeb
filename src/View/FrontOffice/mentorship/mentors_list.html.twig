{% extends 'FrontOffice/base.html.twig' %}

{% block title %}Find Mentors - StartupFlow{% endblock %}

{% block body %}
<div class="container" style="padding: 40px 20px; max-width: 1200px; margin: auto;">
    
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <h2 style="color: var(--text-main, #fff); font-size: 2em; margin: 0;">Find <span style="color: var(--primary, #6f56ff);">Mentors</span></h2>
        
        <form id="mentorSearchForm" style="display: flex; gap: 10px; align-items: center;" onsubmit="event.preventDefault();">
            <input type="text" id="searchInput" name="q" value="{{ search }}" placeholder="Search by name or expertise..." 
                   style="padding: 10px 15px; border-radius: 8px; border: 1px solid rgba(122,92,255,0.3); background: transparent; color: var(--text-main); width: 250px;">
            <label style="color: var(--text-main); display: flex; align-items: center; gap: 5px;">
                <input type="checkbox" id="availableOnly" name="available_only" value="1" {% if app.request.query.get('available_only') %}checked{% endif %}>
                Available Only
            </label>
        </form>
    </div>

    <div id="mentorsGrid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
        {% include 'FrontOffice/mentorship/_mentors_list_cards.html.twig' %}
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    function bindFavoriteBtns() {
        document.querySelectorAll('.favorite-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const mentorId = btn.getAttribute('data-id');
                fetch(`/mentorship/mentor/${mentorId}/toggle-favorite`, { method: 'POST', headers: {'X-Requested-With': 'XMLHttpRequest'} })
                .then(res => res.json())
                .then(data => {
                    if(data.status === 'success') {
                        btn.innerHTML = data.action === 'added' ? '❤️' : '🤍';
                        btn.style.color = data.action === 'added' ? '#ff5656' : 'var(--text-main)';
                    }
                });
            });
        });
    }
    
    bindFavoriteBtns();

    const searchInput = document.getElementById('searchInput');
    const availableOnly = document.getElementById('availableOnly');
    const mentorsGrid = document.getElementById('mentorsGrid');

    function fetchMentors() {
        const q = searchInput.value;
        const available = availableOnly.checked ? '1' : '';
        fetch(`{{ path('app_mentors_list') }}?q=${encodeURIComponent(q)}&available_only=${available}`, {
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(res => res.text())
        .then(html => {
            mentorsGrid.innerHTML = html;
            bindFavoriteBtns(); // Re-bind interactive buttons after DOM update
        });
    }

    searchInput.addEventListener('keyup', fetchMentors);
    availableOnly.addEventListener('change', fetchMentors);
});
</script>
{% endblock %}
