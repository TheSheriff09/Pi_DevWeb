{% extends 'FrontOffice/base.html.twig' %}

{% block title %}Mentorship Overview - StartupFlow{% endblock %}

{% block body %}
<div class="container" style="padding: 40px 20px; max-width: 1200px; margin: auto;">
    
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <h2 style="color: var(--text-main, #fff); font-size: 2em; margin: 0;">Mentorship <span style="color: var(--primary, #6f56ff);">Overview</span></h2>
    </div>

    <!-- Stats Cards -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 30px;">
        <div class="mentorship-card" style="text-align: center;">
            <h3 style="margin: 0 0 10px; font-size: 1.2em; opacity: 0.8;">Total Sessions</h3>
            <p style="margin: 0; font-size: 3em; font-weight: bold; color: var(--primary);">{{ totalSessions }}</p>
        </div>
        
        <div class="mentorship-card" style="text-align: center;">
            <h3 style="margin: 0 0 10px; font-size: 1.2em; opacity: 0.8;">To-Do Progress</h3>
            <div style="width: 100%; background: rgba(122,92,255,0.2); border-radius: 999px; height: 16px; margin: 15px 0;">
                <div style="background: linear-gradient(90deg, #6f56ff, #d2a7ff); height: 100%; border-radius: 999px; width: {{ progressPercentage }}%;"></div>
            </div>
            <p style="margin: 0; font-weight: bold;">{{ completedTodos }} / {{ totalTodos }} Tasks Completed ({{ progressPercentage }}%)</p>
        </div>
    </div>

    <div style="display: flex; flex-wrap: wrap; gap: 30px; align-items: flex-start;">
        <!-- Left Column: Tasks -->
        <div style="flex: 2; min-width: 300px;">
            {% if role == 'MENTOR' %}
                <h3 style="color: var(--text-main, #fff); margin-bottom: 20px;">Entrepreneurs' To-Do Progress</h3>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px;">
                    {% for group in groupedTodos %}
                        <div class="mentorship-card" style="text-align: left;">
                            <h4 style="margin: 0 0 15px; font-size: 1.2em; color: var(--primary); border-bottom: 1px solid rgba(122,92,255,0.1); padding-bottom: 10px;">👤 {{ group.name }}</h4>
                            {% for item in group.tasks %}
                                <div style="display: flex; gap: 15px; align-items: center; padding: 10px 0; border-bottom: 1px solid rgba(122,92,255,0.05);">
                                    <div style="width: 24px; height: 24px; padding-top: 1px; border-radius: 6px; border: 2px solid {{ item.todo.getIsDone() ? '#2ecc71' : 'var(--primary-light)' }}; background: {{ item.todo.getIsDone() ? '#2ecc71' : 'transparent' }}; display: flex; justify-content: center; align-items: center; color: white; font-weight: bold; font-size: 14px; flex-shrink: 0;">
                                        {% if item.todo.getIsDone() %}✓{% endif %}
                                    </div>
                                    <div style="flex: 1;">
                                        <p style="margin: 0; font-weight: bold; text-decoration: {{ item.todo.getIsDone() ? 'line-through' : 'none' }}; opacity: {{ item.todo.getIsDone() ? '0.6' : '1' }};">{{ item.todo.taskDescription }}</p>
                                        <small style="opacity: 0.6; color: var(--text-main);">From Session on {{ item.sessionDate|date('M j, Y') }}</small>
                                    </div>
                                </div>
                            {% else %}
                                <p style="opacity: 0.6; text-align: center; font-style: italic;">No tasks assigned to this entrepreneur yet.</p>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="mentorship-card" style="grid-column: 1 / -1; text-align: center;">
                            <p style="opacity: 0.6; text-align: center;">No entrepreneurs have tasks assigned.</p>
                        </div>
                    {% endfor %}
                </div>
                <div style="margin-top: 20px;">
                    <a href="{{ path('app_my_sessions') }}" class="btn-pill" style="text-decoration: none; display: inline-block;">Manage Specific Sessions</a>
                </div>
            {% else %}
                <h3 style="color: var(--text-main, #fff); margin-bottom: 20px;">My Assigned Tasks</h3>
                <div class="mentorship-card" style="text-align: left;">
                    {% if recentTodos is empty %}
                        <p style="opacity: 0.6; text-align: center;">No tasks assigned yet. Start a session or check back later!</p>
                    {% else %}
                        {% for todo in recentTodos %}
                            <div style="display: flex; gap: 15px; align-items: center; padding: 15px 0; border-bottom: 1px solid rgba(122,92,255,0.1);">
                                <div style="width: 24px; height: 24px; padding-top: 1px; border-radius: 6px; border: 2px solid {{ todo.getIsDone() ? '#2ecc71' : 'var(--primary-light)' }}; background: {{ todo.getIsDone() ? '#2ecc71' : 'transparent' }}; display: flex; justify-content: center; align-items: center; color: white; font-weight: bold; font-size: 14px; flex-shrink: 0;">
                                    {% if todo.getIsDone() %}✓{% endif %}
                                </div>
                                <div style="flex: 1;">
                                    <p style="margin: 0; font-weight: bold; text-decoration: {{ todo.getIsDone() ? 'line-through' : 'none' }}; opacity: {{ todo.getIsDone() ? '0.6' : '1' }};">{{ todo.taskDescription }}</p>
                                    <small style="opacity: 0.6; color: var(--text-main);">From Session #{{ todo.sessionID }}</small>
                                </div>
                            </div>
                        {% endfor %}
                        <div style="text-align: left; margin-top: 20px;">
                            <a href="{{ path('app_my_sessions') }}" class="btn-pill" style="text-decoration: none; display: inline-block;">View All Work in Sessions</a>
                        </div>
                    {% endif %}
                </div>
            {% endif %}
        </div>

        <!-- Right Column: Upcoming Sessions -->
        <div style="flex: 1; min-width: 300px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h3 style="color: var(--text-main, #fff); margin: 0;">Upcoming Sessions</h3>
                <a href="{{ path('app_my_sessions') }}" style="color: var(--primary); text-decoration: none; font-size: 0.9em; font-weight: bold;">View All &rarr;</a>
            </div>
            
            <div style="display: flex; flex-direction: column; gap: 15px;">
                {% for item in upcomingSessions %}
                    <a href="{{ path('app_session_details', {'id': item.session.sessionID}) }}" style="text-decoration: none; color: inherit; display: block;">
                        <div class="mentorship-card hover-glow" style="padding: 20px; position: relative; overflow: hidden;">
                            {% if item.isToday %}
                                <div style="position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: #2ecc71;"></div>
                            {% else %}
                                <div style="position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: var(--primary);"></div>
                            {% endif %}
                            
                            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                                <h4 style="margin: 0 0 10px; color: var(--text-main);">{{ item.partnerName }}</h4>
                                {% if item.isToday %}
                                    <span style="background: rgba(46, 204, 113, 0.15); color: #2ecc71; padding: 3px 8px; border-radius: 10px; font-size: 0.7em; font-weight: bold; border: 1px solid #2ecc71;">TODAY</span>
                                {% else %}
                                    <span style="background: rgba(111,86,255,0.1); color: var(--primary); padding: 3px 8px; border-radius: 10px; font-size: 0.7em; font-weight: bold;">{{ item.session.sessionType|upper }}</span>
                                {% endif %}
                            </div>
                            
                            <p style="margin: 0 0 5px; color: var(--primary-light); font-weight: bold; font-family: 'Inter', sans-serif;">
                                📅 {{ item.session.sessionDate|date('M j, Y') }}
                            </p>
                            <p style="margin: 0; opacity: 0.7; font-size: 0.9em;">
                                💡 ID: #{{ item.session.sessionID }}
                            </p>
                        </div>
                    </a>
                {% else %}
                    <div class="mentorship-card" style="text-align: center;">
                        <p style="opacity: 0.6; font-style: italic; margin: 0;">No upcoming sessions scheduled.</p>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

</div>
{% endblock %}
