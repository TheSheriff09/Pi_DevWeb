{% extends 'FrontOffice/base.html.twig' %}

{% block title %}StartupFlow Tunisia - {{ post.title }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .post-container {
            max-width: 900px;
            margin: 100px auto 50px;
            padding: 40px;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 20px;
            color: var(--text-main);
            position: relative;
            z-index: 2;
        }

        body.dark-mode .post-container {
            background: rgba(30, 30, 45, 0.8);
            border-color: rgba(255, 255, 255, 0.1);
        }

        .post-header {
            margin-bottom: 20px;
        }

        .post-title {
            font-size: 2.5rem;
            color: var(--primary-lighter);
            margin-bottom: 10px;
        }

        .post-meta {
            color: #b0a8d6;
            font-size: 1rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            padding-bottom: 15px;
        }

        .post-image {
            width: 100%;
            max-height: 400px;
            object-fit: cover;
            border-radius: 12px;
            margin-bottom: 30px;
            box-shadow: var(--shadow-main);
        }

        .post-content {
            font-size: 1.1rem;
            line-height: 1.8;
            color: #111; /* Light mode contrast */
            margin-bottom: 40px;
            white-space: pre-wrap;
        }
        body.dark-mode .post-content {
            color: #e2dcff;
        }

        .post-actions {
            display: flex;
            gap: 20px;
            margin-bottom: 40px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            padding-top: 20px;
            align-items: center;
            position: relative;
        }

        /* REACTION SYSTEM */
        .reaction-container {
            position: relative;
        }
        .reactions-box {
            position: absolute;
            bottom: 45px;
            left: 50%;
            transform: translateX(-50%) scale(0);
            background: white;
            border-radius: 30px;
            padding: 8px 12px;
            display: flex;
            gap: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            transition: transform 0.2s ease-out;
            z-index: 10;
        }
        body.dark-mode .reactions-box {
            background: #2a2a3c;
            box-shadow: 0 5px 15px rgba(0,0,0,0.5);
        }
        .reaction-container:hover .reactions-box {
            transform: translateX(-50%) scale(1);
        }
        .reaction-emoji {
            font-size: 1.5rem;
            cursor: pointer;
            transition: transform 0.2s;
        }
        .reaction-emoji:hover {
            transform: scale(1.3) translateY(-5px);
        }

        .like-btn {
            background: rgba(0, 0, 0, 0.05);
            border: 1px solid rgba(0, 0, 0, 0.1);
            color: #111;
            padding: 8px 20px;
            border-radius: 20px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s ease;
            font-size: 1rem;
        }
        body.dark-mode .like-btn {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(255, 255, 255, 0.2);
            color: var(--text-main);
        }

        .like-btn:hover {
            background: rgba(0, 0, 0, 0.1);
        }
        body.dark-mode .like-btn:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        .like-btn.liked {
            background: rgba(255, 71, 87, 0.2);
            border-color: #ff4757;
            color: #ff4757;
        }
        body.dark-mode .like-btn.liked {
            background: rgba(255, 71, 87, 0.2);
            border-color: #ff4757;
            color: #ff4757;
        }

        .delete-btn {
            background: rgba(255, 71, 87, 0.1);
            border: 1px solid #ff4757;
            color: #ff4757;
            padding: 8px 20px;
            border-radius: 20px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
        }

        .delete-btn:hover {
            background: rgba(255, 71, 87, 0.3);
            color: white;
        }

        /* Comments Section */
        .comments-section {
            margin-top: 20px;
        }

        .comments-title {
            font-size: 1.8rem;
            color: var(--primary-lighter);
            margin-bottom: 20px;
        }

        .comment {
            background: rgba(0, 0, 0, 0.05);
            padding: 15px 20px;
            border-radius: 12px;
            margin-bottom: 15px;
            border: 1px solid rgba(0, 0, 0, 0.05);
        }
        body.dark-mode .comment {
            background: rgba(0, 0, 0, 0.2);
            border-color: rgba(255, 255, 255, 0.05);
        }

        .comment-meta {
            font-size: 0.85rem;
            color: #666;
            margin-bottom: 8px;
        }
        body.dark-mode .comment-meta {
            color: #b0a8d6;
        }

        .comment-content {
            font-size: 1rem;
            color: #111;
        }
        body.dark-mode .comment-content {
            color: #e2dcff;
        }

        .add-comment {
            margin-top: 30px;
            background: rgba(0, 0, 0, 0.02);
            padding: 20px;
            border-radius: 12px;
            position: relative;
        }
        body.dark-mode .add-comment {
            background: rgba(255, 255, 255, 0.05);
        }

        .mention-item {
            padding: 8px 12px;
            cursor: pointer;
            border-bottom: 1px solid #eee;
            color: #333;
            font-size: 0.9rem;
        }
        .mention-item:hover {
            background: #f0f0f0;
        }
        body.dark-mode .mention-item {
            color: #222; /* keep black for list inside white box */
        }

        /* Flash messages */
        .comment-flash {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 18px;
            border-radius: 10px;
            margin-bottom: 14px;
            font-size: 0.95rem;
            font-weight: 500;
            animation: slideDown 0.3s ease;
        }
        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-8px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .comment-flash--error {
            background: rgba(255, 71, 87, 0.12);
            border: 1px solid rgba(255, 71, 87, 0.4);
            color: #c0392b;
        }
        body.dark-mode .comment-flash--error {
            background: rgba(255, 71, 87, 0.2);
            color: #ff6b7a;
        }
        .comment-flash--success {
            background: rgba(46, 213, 115, 0.12);
            border: 1px solid rgba(46, 213, 115, 0.4);
            color: #1e8449;
        }
        body.dark-mode .comment-flash--success {
            background: rgba(46, 213, 115, 0.2);
            color: #2ed573;
        }
        .flash-close {
            background: none;
            border: none;
            cursor: pointer;
            font-size: 1rem;
            color: inherit;
            opacity: 0.7;
            padding: 0 0 0 12px;
        }
        .flash-close:hover { opacity: 1; }

        /* Inline validation states */
        #commentValidationMsg.valid   { color: #27ae60; }
        #commentValidationMsg.invalid { color: #e74c3c; }
        #commentContent.input-error   { border-color: #e74c3c !important; box-shadow: 0 0 0 2px rgba(231,76,60,0.15); }
        #commentContent.input-ok      { border-color: #27ae60 !important; box-shadow: 0 0 0 2px rgba(39,174,96,0.15); }

        #commentSubmitBtn:disabled {
            opacity: 0.45;
            cursor: not-allowed;
        }

        /* Modal classes */
        .modal {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(5px);
            z-index: 10000;
            align-items: center;
            justify-content: center;
        }
        .modal.active {
            display: flex !important;
        }
        .modal-content {
            background: #fff;
            border: 1px solid var(--primary);
            padding: 30px;
            border-radius: 20px;
            width: 90%;
            max-width: 500px;
            position: relative;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }
        body.dark-mode .modal-content {
            background: #1e1e2d;
        }

        /* Translation UI */
        .translate-container {
            position: relative;
        }
        .translate-btn {
            background: linear-gradient(135deg, #6c5ce7, #a29bfe);
            color: #fff;
            border: none;
            padding: 8px 18px;
            border-radius: 20px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 7px;
            font-size: 0.95rem;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 2px 10px rgba(108,92,231,0.35);
        }
        .translate-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 18px rgba(108,92,231,0.5);
        }
        .lang-dropdown {
            position: absolute;
            bottom: 48px;
            left: 50%;
            transform: translateX(-50%) scale(0.9);
            opacity: 0;
            pointer-events: none;
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 8px 30px rgba(0,0,0,0.18);
            padding: 10px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 6px;
            min-width: 260px;
            transition: all 0.25s cubic-bezier(.34,1.56,.64,1);
            z-index: 50;
        }
        body.dark-mode .lang-dropdown {
            background: #1e1e2e;
            box-shadow: 0 8px 30px rgba(0,0,0,0.5);
        }
        .translate-container.open .lang-dropdown {
            opacity: 1;
            pointer-events: all;
            transform: translateX(-50%) scale(1);
        }
        .lang-option {
            background: rgba(108,92,231,0.07);
            border: 1px solid rgba(108,92,231,0.15);
            border-radius: 10px;
            padding: 7px 12px;
            cursor: pointer;
            font-size: 0.88rem;
            text-align: left;
            transition: all 0.2s;
            color: #333;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        body.dark-mode .lang-option { color: #ccc; }
        .lang-option:hover {
            background: rgba(108,92,231,0.2);
            border-color: #6c5ce7;
            color: #6c5ce7;
        }
        /* Translated content panel */
        #translationPanel {
            display: none;
            margin-bottom: 30px;
            border-radius: 16px;
            border: 2px solid rgba(108,92,231,0.3);
            background: rgba(108,92,231,0.05);
            overflow: hidden;
            animation: fadeInUp 0.4s ease;
        }
        body.dark-mode #translationPanel {
            background: rgba(108,92,231,0.1);
        }
        @keyframes fadeInUp {
            from { opacity:0; transform:translateY(12px); }
            to   { opacity:1; transform:translateY(0); }
        }
        .translation-header {
            background: linear-gradient(135deg,#6c5ce7,#a29bfe);
            color: #fff;
            padding: 10px 18px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-weight: 600;
            font-size: 0.9rem;
        }
        .translation-body {
            padding: 20px 24px;
        }
        #translatedTitle {
            font-size: 1.6rem;
            font-weight: 700;
            color: #6c5ce7;
            margin-bottom: 14px;
        }
        #translatedContent {
            font-size: 1.05rem;
            line-height: 1.8;
            color: #333;
            white-space: pre-wrap;
        }
        body.dark-mode #translatedTitle   { color: #a29bfe; }
        body.dark-mode #translatedContent { color: #ccc; }
        .close-translation {
            background: rgba(255,255,255,0.25);
            border: none;
            color: #fff;
            border-radius: 50%;
            width: 26px; height: 26px;
            cursor: pointer;
            font-size: 1rem;
            display: flex; align-items:center; justify-content:center;
            transition: background 0.2s;
        }
        .close-translation:hover { background: rgba(255,255,255,0.45); }
        /* Spinner */
        .translate-spinner {
            width: 18px; height: 18px;
            border: 3px solid rgba(255,255,255,0.4);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
            display: none;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
    </style>
{% endblock %}

{% block body %}


    <div class="post-container">
        <div class="post-header">
            <a href="{{ path('app_forum_index') }}" style="color: var(--primary-light); text-decoration: none; margin-bottom: 20px; display: inline-block;">&larr; Back to Forum</a>
            <h1 class="post-title" style="color: #000;">{{ post.title }}</h1>
            <div class="post-meta">
                <span style="color: #666;">Posted by <strong style="color: var(--primary);"><a href="{{ path('app_forum_profile', {'id': post.userId}) }}" style="color: inherit; text-decoration: none;" onmouseover="this.style.textDecoration='underline';" onmouseout="this.style.textDecoration='none';">{{ post.authorName }}</a></strong></span>
                <span style="color: #666;">{{ post.createdAt|date('F j, Y, g:i a') }}</span>
            </div>
        </div>

        {% if post.imageUrl %}
            {% if 'http' in post.imageUrl %}
                <img src="{{ post.imageUrl }}" onerror="this.src='{{ asset('Front/images/default_post.png') }}'" alt="Post Image" class="post-image">
            {% else %}
                <img src="{{ asset('uploads/forum/' ~ post.imageUrl) }}" onerror="this.src='{{ asset('Front/images/default_post.png') }}'" alt="Post Image" class="post-image">
            {% endif %}
        {% endif %}

        <div class="post-content" id="originalContent">
            {{ post.content }}
        </div>

        {# ── Translation panel (hidden until a language is chosen) ─────────── #}
        <div id="translationPanel">
            <div class="translation-header">
                <span id="translationLabel">🌐 Translation</span>
                <button class="close-translation" onclick="closeTranslation()" title="Close translation">✕</button>
            </div>
            <div class="translation-body">
                <div id="translatedTitle"></div>
                <div id="translatedContent"></div>
            </div>
        </div>

        <div class="post-actions">
            {% if isLoggedIn %}
                <div class="reaction-container">
                    <div class="reactions-box">
                        <span class="reaction-emoji" onclick="toggleLike('LIKE', '👍')">👍</span>
                        <span class="reaction-emoji" onclick="toggleLike('LOVE', '❤️')">❤️</span>
                        <span class="reaction-emoji" onclick="toggleLike('HAHA', '😆')">😆</span>
                        <span class="reaction-emoji" onclick="toggleLike('WOW', '😲')">😲</span>
                        <span class="reaction-emoji" onclick="toggleLike('SAD', '😢')">😢</span>
                        <span class="reaction-emoji" onclick="toggleLike('ANGRY', '😡')">😡</span>
                    </div>
                    <button id="likeButton" class="like-btn {{ userLiked ? 'liked' : '' }}" onclick="toggleLike('LIKE', '👍')">
                        <span id="likeIcon">{{ userLiked ? '❤️' : '🤍' }}</span> <span id="likeText">React</span> (<span id="likeCount">{{ likeCount }}</span>)
                    </button>
                </div>
            {% else %}
                <a href="{{ path('app_login') }}" class="like-btn">🤍 React ({{ likeCount }})</a>
            {% endif %}

            {# ── Translate button ─────────────────────────────────────────── #}
            <div class="translate-container" id="translateContainer">
                <button class="translate-btn" onclick="toggleLangPicker(event)" id="translateBtn">
                    🌐 <span id="translateBtnLabel">Translate</span>
                    <div class="translate-spinner" id="translateSpinner"></div>
                </button>
                <div class="lang-dropdown" id="langDropdown">
                    {% for code, lang in languages %}
                        <button class="lang-option" onclick="doTranslate('{{ code }}', '{{ lang.name }}')">
                            {{ lang.flag }} {{ lang.name }}
                        </button>
                    {% endfor %}
                </div>
            </div>

            <div style="color: #b0a8d6; margin-left: 10px;">💬 {{ totalComments }} Comments</div>
            
            <!-- Spacer -->
            <div style="flex: 1;"></div>

            {% if isLoggedIn %}
                <button type="button" class="delete-btn" style="border-color:#ffa502; color:#ffa502; background:rgba(255,165,2,0.1);" onclick="openReport('post', {{ post.id }})">🚩 Report</button>
            {% endif %}

            {% if isLoggedIn and currentUserId == post.userId %}
                <form action="{{ path('app_forum_toggle_lock', {'id': post.id}) }}" method="post" style="display:inline; margin-right: 10px;" onsubmit="promptConfirm(event, 'Are you sure you want to {{ post.isCommentsLocked ? 'unlock' : 'lock' }} comments?', this);">
                    <button type="submit" class="delete-btn" style="border-color:#3498db; color:#3498db; background:rgba(52,152,219,0.1);">{{ post.isCommentsLocked ? '🔓 Unlock Comments' : '🔒 Lock Comments' }}</button>
                </form>
                <form action="{{ path('app_forum_delete', {'id': post.id}) }}" method="post" onsubmit="promptConfirm(event, 'Are you sure you want to delete this post?', this);">
                    <button type="submit" class="delete-btn">Delete Post</button>
                </form>
            {% endif %}
        </div>

        <div class="comments-section">
            <h2 class="comments-title" style="color: #000;">Comments</h2>

            {# ── Flash messages ─────────────────────────────────────────── #}
            {% for message in app.flashes('error') %}
                <div class="comment-flash comment-flash--error">
                    <span>{{ message }}</span>
                    <button class="flash-close" onclick="this.parentElement.remove()">✕</button>
                </div>
            {% endfor %}
            {% for message in app.flashes('success') %}
                <div class="comment-flash comment-flash--success">
                    <span>{{ message }}</span>
                    <button class="flash-close" onclick="this.parentElement.remove()">✕</button>
                </div>
            {% endfor %}

            {% for comment in rootComments %}
                <div class="comment" id="comment-{{ comment.id }}">
                    <div class="comment-meta" style="display:flex; justify-content:space-between; align-items:flex-start;">
                        <span>
                            <strong>{{ comment.authorName }}</strong> - Posted on {{ comment.createdAt|date('F j, Y') }} at {{ comment.createdAt|date('g:i a') }}
                            {% if comment.isEdited %}<em style="font-size:0.75rem;">(edited)</em>{% endif %}
                        </span>
                        <div style="display:flex; gap: 8px; align-items:center;">
                            <button onclick="voteComment({{ comment.id }}, 'upvote')" style="background:none;border:none;cursor:pointer;" title="Upvote">👍 <span id="upvotes_{{ comment.id }}">{{ comment.upvotes }}</span></button>
                            <button onclick="voteComment({{ comment.id }}, 'downvote')" style="background:none;border:none;cursor:pointer;" title="Downvote">👎 <span id="downvotes_{{ comment.id }}">{{ comment.downvotes }}</span></button>
                            
                            {% if isLoggedIn %}
                                <button onclick="toggleReplyForm({{ comment.id }})" style="background:none;border:none;cursor:pointer;color:var(--primary-light);" title="Reply">↩️ Reply</button>
                            {% endif %}

                            {% if isLoggedIn and comment.userId == app.session.get('user_id') %}
                                <button onclick="editCommentPrompt({{ comment.id }}, '{{ comment.content|escape('js') }}')" style="background:none;border:none;cursor:pointer;color:#ffa502;" title="Edit">✏️</button>
                                <form action="{{ path('app_forum_comment_delete_user', {'id': comment.id}) }}" method="post" style="display:inline;" onsubmit="promptConfirm(event, 'Delete this comment?', this);">
                                    <button type="submit" style="background:none;border:none;cursor:pointer;color:#e74c3c;" title="Delete">🗑️</button>
                                </form>
                            {% else %}
                                <button onclick="openReport('comment', {{ comment.id }})" style="background:none;border:none;cursor:pointer;color:#e74c3c;" title="Report Comment">🚩</button>
                            {% endif %}
                        </div>
                    </div>
                    <div class="comment-content">
                        {{ comment.content }}
                    </div>

                    {# ── Reply Form (Hidden) ── #}
                    {% if isLoggedIn %}
                        <div id="reply-form-{{ comment.id }}" style="display:none; margin-top: 15px; padding-left: 20px; border-left: 2px solid var(--primary-light);">
                            <form action="{{ path('app_forum_comment', {'id': post.id}) }}" method="post" onsubmit="return validateReply({{ comment.id }})">
                                <input type="hidden" name="parentId" value="{{ comment.id }}">
                                <textarea name="content" id="reply-content-{{ comment.id }}" class="pillField" rows="2" style="width:100%; border-radius:8px; margin-bottom:8px; color:black;" placeholder="Write a reply..."></textarea>
                                <div style="display:flex; gap:10px;">
                                    <button type="submit" class="signBtn" style="padding: 5px 15px; font-size: 0.9rem;">Post Reply</button>
                                    <button type="button" class="signBtn" style="padding: 5px 15px; font-size: 0.9rem; background:transparent; border:1px solid #999; color:#999;" onclick="toggleReplyForm({{ comment.id }})">Cancel</button>
                                </div>
                            </form>
                        </div>
                    {% endif %}

                    {# ── Nested Replies ── #}
                    {% if replies[comment.id] is defined %}
                        <div class="comment-replies" style="margin-top: 15px; margin-left: 30px; padding-left: 15px; border-left: 2px dashed rgba(108,92,231,0.2);">
                            {% for reply in replies[comment.id] %}
                                <div class="comment reply" style="background: rgba(255,255,255,0.02); padding: 12px; border-radius: 8px; margin-bottom: 10px;">
                                    <div class="comment-meta" style="font-size: 0.9rem; margin-bottom: 5px;">
                                        <strong>{{ reply.authorName }}</strong> • {{ reply.createdAt|date('M d, H:i') }}
                                        <div style="float:right; display:flex; gap: 8px;">
                                              <button onclick="voteComment({{ reply.id }}, 'upvote')" style="background:none;border:none;cursor:pointer;font-size:0.8rem;">👍 {{ reply.upvotes }}</button>
                                              {% if isLoggedIn and reply.userId == app.session.get('user_id') %}
                                                  <form action="{{ path('app_forum_comment_delete_user', {'id': reply.id}) }}" method="post" style="display:inline;" onsubmit="promptConfirm(event, 'Delete this reply?', this);">
                                                      <button type="submit" style="background:none;border:none;cursor:pointer;color:#e74c3c;font-size:0.8rem;">🗑️</button>
                                                  </form>
                                              {% endif %}
                                        </div>
                                    </div>
                                    <div class="comment-content" style="font-size: 0.95rem;">
                                        {{ reply.content }}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            {% else %}
                <p style="color: #888;">No comments yet. Be the first to share your thoughts!</p>
            {% endfor %}

            {% if post.isCommentsLocked %}
                <div class="add-comment" style="text-align: center; border: 1px solid rgba(231, 76, 60, 0.3); background: rgba(231, 76, 60, 0.05);">
                    <h3 style="color: #e74c3c; margin-bottom: 10px;">🔒 Comments Locked</h3>
                    <p style="color: #888;">The owner of this post has frozen the discussion. No further comments can be added.</p>
                </div>
            {% elseif isLoggedIn %}
                <div class="add-comment" style="position: relative;">
                    <h3 style="margin-bottom: 15px; color: var(--primary);">Add a Discussion</h3>
                    <div id="mentionBox" style="display:none; position:absolute; bottom:120px; left:20px; background:white; border:1px solid #ccc; max-height:150px; overflow-y:auto; z-index:1000; border-radius:8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); width:250px;"></div>
                    <form id="commentForm" action="{{ path('app_forum_comment', {'id': post.id}) }}" method="post" onsubmit="return validateComment()" novalidate>

                        {# Hidden post content for duplicate detection #}
                        <input type="hidden" id="postContentRef" value="{{ post.content | e('html_attr') }}">

                        <textarea
                            id="commentContent"
                            name="content"
                            class="pillField"
                            rows="4"
                            style="border-radius: 12px; resize: vertical; margin-bottom: 6px; color: #000; width: 100%; box-sizing: border-box;"
                            placeholder="Write your comment here..."
                            oninput="onCommentInput()"
                        ></textarea>

                        {# Live validation message #}
                        <div id="commentValidationMsg" style="min-height: 22px; margin-bottom: 10px; font-size: 0.88rem; font-weight: 500;"></div>

                        {# Character counter #}
                        <div style="text-align: right; font-size: 0.8rem; color: #999; margin-bottom: 12px;">
                            <span id="charCount">0</span> / 2000 characters
                        </div>

                        <button type="submit" id="commentSubmitBtn" class="signBtn" style="padding: 10px 25px;" disabled>
                            💬 Post Comment
                        </button>
                    </form>
                </div>
            {% else %}
                <div class="add-comment" style="text-align: center;">
                    <p style="color: #888; margin-bottom: 15px;">You must be logged in to post a comment.</p>
                    <a href="{{ path('app_login') }}" class="btn-pill" style="border: 1px solid var(--primary);">Log In</a>
                </div>
            {% endif %}
        </div>
    </div>

    <!-- Edit Comment Modal -->
    <div id="editCommentModal" class="modal">
        <div class="modal-content auth-card">
            <span onclick="document.getElementById('editCommentModal').classList.remove('active')" style="position:absolute; top:15px; right:20px; font-size:24px; cursor:pointer;">&times;</span>
            <h2 style="margin-bottom:20px;">Edit Comment</h2>
            <form id="editCommentForm" method="post" action="" novalidate>
                <textarea id="editCommentContent" name="content" class="pillField" rows="4" style="width:100%; box-sizing:border-box; color:black;"></textarea>
                <button type="submit" class="signBtn" style="margin-top:15px;">Update Comment</button>
            </form>
        </div>
    </div>

    <!-- Report Modal -->
    <div id="reportModal" class="modal">
        <div class="modal-content auth-card">
            <span onclick="document.getElementById('reportModal').classList.remove('active')" style="position:absolute; top:15px; right:20px; font-size:24px; cursor:pointer;">&times;</span>
            <h2 style="margin-bottom:20px;">Report Content</h2>
            <form method="post" action="{{ path('app_forum_report') }}" novalidate>
                <input type="hidden" id="reportType" name="type" value="">
                <input type="hidden" id="reportTargetId" name="target_id" value="">
                
                <label class="field-label" for="reportReason">Reason for reporting</label>
                <textarea id="reportReason" name="reason" class="pillField" rows="4" style="width:100%; box-sizing:border-box; color:black;" placeholder="Why are you reporting this?"></textarea>
                
                <button type="submit" class="signBtn" style="margin-top:15px; background: #e74c3c;">Submit Report</button>
            </form>
        </div>
    </div>

    <!-- Custom Confirm Modal -->
    <div id="customConfirmModal" class="modal">
        <div class="modal-content auth-card" style="text-align: center; max-width: 400px;">
             <h3 id="confirmModalText" style="margin-bottom: 25px; color: var(--text-main);">Are you sure?</h3>
             <div style="display: flex; gap: 15px; justify-content: center;">
                 <button onclick="confirmCustomAction()" class="signBtn" style="flex: 1; background: #e74c3c;">Yes</button>
                 <button type="button" onclick="closeCustomConfirm()" class="signBtn" style="flex: 1; background: transparent; border: 1px solid var(--text-main); color: var(--text-main);">Cancel</button>
             </div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Dark mode overrides
            const isDark = document.body.classList.contains('dark-mode');
            if(isDark) {
                document.querySelector('.post-title').style.color = "var(--primary-lighter)";
                document.querySelector('.comments-title').style.color = "var(--primary-lighter)";
            }
        });

        /* Custom Confirm Logic */
        let pendingForm = null;
        function promptConfirm(event, message, formElement) {
            event.preventDefault();
            document.getElementById('confirmModalText').textContent = message;
            pendingForm = formElement;
            document.getElementById('customConfirmModal').classList.add('active');
        }
        function closeCustomConfirm() {
            document.getElementById('customConfirmModal').classList.remove('active');
            pendingForm = null;
        }
        function confirmCustomAction() {
            if (pendingForm) {
                pendingForm.submit();
            }
        }

        /* ── Comment live validation ─────────────────────────────────── */
        const MIN_LEN = 10;

        function onCommentInput() {
            const textarea  = document.getElementById('commentContent');
            const msgEl     = document.getElementById('commentValidationMsg');
            const countEl   = document.getElementById('charCount');
            const submitBtn = document.getElementById('commentSubmitBtn');
            const postRef   = document.getElementById('postContentRef');

            const value     = textarea.value;
            const trimmed   = value.trim();
            countEl.textContent = value.length;

            let error = null;

            if (trimmed.length === 0) {
                error = '✏️ Comment cannot be empty.';
            } else if (trimmed.length < MIN_LEN) {
                error = `✏️ Comment is too short — at least ${MIN_LEN} characters required (${trimmed.length}/${MIN_LEN}).`;
            } else if (postRef && trimmed.toLowerCase() === postRef.value.trim().toLowerCase()) {
                error = '🔁 Your comment cannot be identical to the post content.';
            }

            if (error) {
                msgEl.textContent = error;
                msgEl.className = 'invalid';
                textarea.className = textarea.className.replace('input-ok','').replace('input-error','').trim() + ' input-error';
                submitBtn.disabled = true;
            } else {
                msgEl.textContent = '✅ Looks good — ready to post!';
                msgEl.className = 'valid';
                textarea.className = textarea.className.replace('input-error','').replace('input-ok','').trim() + ' input-ok';
                submitBtn.disabled = false;
            }
        }

        function validateComment() {
            const textarea = document.getElementById('commentContent');
            const trimmed  = textarea ? textarea.value.trim() : '';
            if (trimmed.length < MIN_LEN) {
                alert('Please write at least ' + MIN_LEN + ' characters before posting.');
                return false;
            }
            return true;
        }

        /* Auto-dismiss flash messages after 6 s */
        document.querySelectorAll('.comment-flash').forEach(function(el) {
            setTimeout(function() {
                el.style.transition = 'opacity 0.5s';
                el.style.opacity = '0';
                setTimeout(function() { el.remove(); }, 500);
            }, 6000);
        });

        async function toggleLike(typeStr, emojiChar) {
            const button = document.getElementById('likeButton');
            const icon = document.getElementById('likeIcon');
            const text = document.getElementById('likeText');
            const countDisplay = document.getElementById('likeCount');
            
            try {
                const response = await fetch(`{{ path('app_forum_react', {'id': post.id}) }}?type=${typeStr}`, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                if (response.ok) {
                    const data = await response.json();
                    if (data.reacted) {
                        button.classList.add('liked');
                        icon.innerText = emojiChar;
                        text.innerText = data.type.charAt(0) + data.type.slice(1).toLowerCase();
                    } else {
                        button.classList.remove('liked');
                        icon.innerText = '🤍';
                        text.innerText = 'React';
                    }
                    if(countDisplay) {
                        countDisplay.innerText = data.count;
                    }
                } else if (response.status === 401) {
                    window.location.href = "{{ path('app_login') }}";
                }
            } catch (error) {
                console.error("Error toggling like:", error);
            }
        }

        /* ── Translation feature ─────────────────────────────────────── */
        const TRANSLATE_URL = '{{ path('app_forum_translate', {'id': post.id}) }}';

        function toggleLangPicker(e) {
            e.stopPropagation();
            const container = document.getElementById('translateContainer');
            container.classList.toggle('open');
        }

        // Close dropdown when clicking outside
        document.addEventListener('click', function(e) {
            const container = document.getElementById('translateContainer');
            if (container && !container.contains(e.target)) {
                container.classList.remove('open');
            }
        });

        async function doTranslate(langCode, langName) {
            // Close the picker
            document.getElementById('translateContainer').classList.remove('open');

            const btn     = document.getElementById('translateBtn');
            const label   = document.getElementById('translateBtnLabel');
            const spinner = document.getElementById('translateSpinner');

            // Show loading state
            label.textContent = 'Translating…';
            spinner.style.display = 'block';
            btn.disabled = true;

            try {
                const formData = new FormData();
                formData.append('lang', langCode);

                const res  = await fetch(TRANSLATE_URL, { method: 'POST', body: formData });
                const data = await res.json();

                if (data.error) {
                    alert('Translation failed: ' + data.error);
                    return;
                }

                // Populate panel
                document.getElementById('translatedTitle').textContent   = data.title;
                document.getElementById('translatedContent').textContent = data.content;
                document.getElementById('translationLabel').textContent  = '🌐 Translated to ' + data.langName;

                // Show panel with animation
                const panel = document.getElementById('translationPanel');
                panel.style.display = 'block';
                panel.style.animation = 'none';
                panel.offsetHeight; // reflow
                panel.style.animation = '';

                // Update button
                label.textContent = '🌐 ' + langName;
            } catch (err) {
                alert('Network error — could not reach translation service.');
                console.error(err);
            } finally {
                spinner.style.display = 'none';
                btn.disabled = false;
            }
        }

        function closeTranslation() {
            const panel = document.getElementById('translationPanel');
            panel.style.transition = 'opacity 0.3s';
            panel.style.opacity = '0';
            setTimeout(function() {
                panel.style.display = 'none';
                panel.style.opacity = '1';
                document.getElementById('translateBtnLabel').textContent = 'Translate';
            }, 300);
        }

        /* ── Vote Comment ─────────────────────────────────────── */
        async function voteComment(commentId, typeStr) {
            try {
                const response = await fetch(`{{ path('app_forum_comment_vote', {'id': 'COMMENT_ID'}) }}`.replace('COMMENT_ID', commentId) + `?type=${typeStr}`, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                if (response.ok) {
                    const data = await response.json();
                    document.getElementById('upvotes_'+commentId).innerText = data.upvotes;
                    document.getElementById('downvotes_'+commentId).innerText = data.downvotes;
                } else if (response.status === 401) {
                    window.location.href = "{{ path('app_login') }}";
                }
            } catch (error) {
                console.error("Error toggling comment vote:", error);
            }
        }

        /* ── Mentions (Autocomplete) ─────────────────────────── */
        const textarea = document.getElementById('commentContent');
        if(textarea) {
            let cachedUsers = null;

            textarea.addEventListener('input', async function(e) {
                const text = textarea.value;
                const cursorPos = textarea.selectionStart;
                const textBeforeCursor = text.substring(0, cursorPos);
                const match = textBeforeCursor.match(/@(\w*)$/);
                const box = document.getElementById('mentionBox');

                if (match) {
                    const query = match[1].toLowerCase();
                    
                    if (!cachedUsers) {
                        try {
                            const res = await fetch(`{{ path('app_forum_mention_search') }}?q=`);
                            if(res.ok) cachedUsers = await res.json();
                            else cachedUsers = [];
                        } catch (err) {
                            cachedUsers = [];
                        }
                    }

                    const filtered = cachedUsers.filter(u => u.value.toLowerCase().startsWith(query)).slice(0, 10);

                    box.innerHTML = '';
                    if (filtered.length > 0) {
                        filtered.forEach(u => {
                            const div = document.createElement('div');
                            div.textContent = "@" + u.value;
                            div.className = 'mention-item';
                            div.onclick = function() {
                                const replaceStart = textBeforeCursor.lastIndexOf('@');
                                textarea.value = text.substring(0, replaceStart) + '@' + u.value + ' ' + text.substring(cursorPos);
                                box.style.display = 'none';
                                cachedUsers = null;
                                textarea.focus();
                                if (typeof validateComment === 'function') validateComment();
                            };
                            box.appendChild(div);
                        });
                        box.style.display = 'block';
                    } else {
                        box.style.display = 'none';
                    }
                } else {
                    box.style.display = 'none';
                    cachedUsers = null;
                }
            });
        }

        /* ── Report & Edit Modals ────────────────────────────── */
        function openReport(type, id) {
            document.getElementById('reportType').value = type;
            document.getElementById('reportTargetId').value = id;
            document.getElementById('reportModal').classList.add('active');
        }

        function editCommentPrompt(id, currentContent) {
            document.getElementById('editCommentContent').value = currentContent;
            document.getElementById('editCommentForm').action = `{{ path('app_forum_comment_edit', {'id': 'COMMENT_ID'}) }}`.replace('COMMENT_ID', id);
            document.getElementById('editCommentModal').classList.add('active');
        }

        /* ── Threaded Reply Logic ─────────────────────────────────── */
        function toggleReplyForm(commentId) {
            const form = document.getElementById(`reply-form-${commentId}`);
            if (form.style.display === 'none') {
                // Close other open reply forms first for better focus
                document.querySelectorAll('[id^="reply-form-"]').forEach(f => f.style.display = 'none');
                form.style.display = 'block';
                document.getElementById(`reply-content-${commentId}`).focus();
            } else {
                form.style.display = 'none';
            }
        }

        function validateReply(commentId) {
            const textarea = document.getElementById(`reply-content-${commentId}`);
            const trimmed = textarea.value.trim();
            if (trimmed.length === 0) {
                alert('✏️ Your reply cannot be empty. Please write something before posting.');
                return false;
            }
            if (trimmed.length < 3) {
                alert('✏️ Your reply is too short. Please add more detail.');
                return false;
            }
            return true;
        }
    </script>
{% endblock %}
