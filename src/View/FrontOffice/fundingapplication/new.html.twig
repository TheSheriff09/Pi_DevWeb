{% extends "FrontOffice/base.html.twig" %}

{% block title %}Apply for Funding - StartupFlow{% endblock %}

{% block body %}
<div class="auth-container" style="min-height: 100vh; padding: 40px 20px;">
    <div class="auth-card" style="max-width: 650px; margin: 0 auto; border-radius: 20px;">
        
        <div style="margin-bottom: 30px; border-bottom: 1px solid rgba(111,86,255,0.2); padding-bottom: 20px;">
            <a href="{{ path('app_entrepreneur_startup_show', {'id': startup.startupID}) }}" style="color: var(--primary-light, #9d88ff); text-decoration: none; font-size: 0.9em; display: inline-block; margin-bottom: 15px;">&larr; Back to Startup</a>
            <h1 style="color: var(--primary, #6f56ff); margin: 0; font-size: 2.2em;">Apply for Funding</h1>
            <p style="margin: 10px 0 0 0; opacity: 0.8;">Submit a direct request for your project: <strong>{{ startup.name }}</strong></p>
        </div>

        {% if latestApplication %}
            <div style="margin-bottom: 20px; display: flex; justify-content: flex-end;">
                <button type="button" onclick="autoFillApplication()" class="pill-btn glow-btn" title="Quickly reuse your saved application details." style="background: rgba(33, 150, 243, 0.1); border: 1px solid #64b5f6; color: #64b5f6; padding: 10px 20px; font-size: 0.9em; cursor: pointer; display: inline-flex; align-items: center; gap: 8px; border-radius: 12px; transition: all 0.3s;">
                    <span>⚡</span> Auto‑Fill Application
                </button>
            </div>
            
            <script>
                function autoFillApplication() {
                    const amountInput = document.querySelector('input[name="amount"]');
                    const reasonInput = document.querySelector('textarea[name="applicationReason"]');
                    const scheduleSelect = document.querySelector('select[name="paymentSchedule"]');
                    
                    if(amountInput) amountInput.value = {{ latestApplication.amount|json_encode }};
                    if(reasonInput) reasonInput.value = {{ latestApplication.applicationReason|json_encode|raw }};
                    if(scheduleSelect) scheduleSelect.value = {{ latestApplication.paymentSchedule|json_encode|raw }};
                    
                    let attachmentHint = document.getElementById('attachmentHint');
                    if (!attachmentHint && {{ latestApplication.attachment|json_encode|raw }} !== 'No Attachment') {
                        const fileContainer = document.querySelector('input[name="attachment"]').parentElement;
                        attachmentHint = document.createElement('div');
                        attachmentHint.id = 'attachmentHint';
                        attachmentHint.style.marginTop = '10px';
                        attachmentHint.style.padding = '10px';
                        attachmentHint.style.background = 'rgba(76, 175, 80, 0.1)';
                        attachmentHint.style.borderLeft = '3px solid #81c784';
                        attachmentHint.style.fontSize = '0.85em';
                        attachmentHint.style.color = '#A5D6A7';
                        attachmentHint.innerHTML = '<strong>Attachment Auto-Filled!</strong> Inheriting previous file unless you upload a new one overriding it.';
                        fileContainer.appendChild(attachmentHint);
                        
                        const hiddenInput = document.createElement('input');
                        hiddenInput.type = 'hidden';
                        hiddenInput.name = 'previousAttachment';
                        hiddenInput.value = {{ latestApplication.attachment|json_encode|raw }};
                        document.querySelector('form').appendChild(hiddenInput);
                    }
                }
            </script>
        {% endif %}

        <form method="post" action="{{ path('app_entrepreneur_funding_new', {'startupId': startup.startupID}) }}" enctype="multipart/form-data" style="display: flex; flex-direction: column; gap: 20px;">
            
            <div>
                <label class="field-label" style="font-weight: 500; font-size: 0.95em; display: block; margin-bottom: 8px;">Requested Amount (in USD) <span style="color: #e57373;">*</span></label>
                <div style="position: relative;">
                    <span style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); font-weight: bold; opacity: 0.7;">$</span>
                    <input type="number" step="100" min="0" name="amount" class="pillField" placeholder="e.g. 50000" style="width: 100%; border-radius: 12px; padding-left: 35px;">
                </div>
            </div>

            <div>
                <label class="field-label" style="font-weight: 500; font-size: 0.95em; display: block; margin-bottom: 8px;">Application Reason <span style="color: #e57373;">*</span></label>
                <textarea name="applicationReason" rows="4" class="pillField" placeholder="Explain precisely why these funds are necessary (e.g. scaling infrastructure, R&D...)" style="width: 100%; border-radius: 12px; resize: vertical;"></textarea>
            </div>

            <div>
                <label class="field-label" style="font-weight: 500; font-size: 0.95em; display: block; margin-bottom: 8px;">Payment Schedule</label>
                <select name="paymentSchedule" class="pillField" style="width: 100%; border-radius: 12px;">
                    <option value="Upfront (Lump Sum)">Upfront (Lump Sum)</option>
                    <option value="Milestone-based Tranches">Milestone-based Tranches</option>
                    <option value="Quarterly Installments">Quarterly Installments</option>
                    <option value="Monthly Operations">Monthly Operations</option>
                </select>
            </div>

            <div>
                <label class="field-label" style="font-weight: 500; font-size: 0.95em; display: block; margin-bottom: 8px;">Supplemental Material (Pitch Deck / Excel) <span style="color: rgba(255,255,255,0.5);">(Optional)</span></label>
                <input type="file" name="attachment" class="pillField" style="width: 100%; border-radius: 12px; background: rgba(0,0,0,0.1); padding: 12px; border: 1px solid rgba(111,86,255,0.3);">
                <small style="display: block; margin-top: 5px; opacity: 0.6;">Upload your pitch deck or financial evaluation sheet (.pdf, .xls, .zip, etc.)</small>
            </div>

            <div style="background: rgba(33,150,243,0.1); border-left: 3px solid #64b5f6; padding: 15px; border-radius: 8px; margin-top: 10px; font-size: 0.9em; display: flex; flex-direction: column; gap: 5px;">
                <strong>Security Brief:</strong>
                <span style="opacity: 0.8;">Your unique Entrepreneur Identity Profile and Startup Project Identity are automatically securely attached and masked inside this application payload. Your submission will automatically be labeled "Pending".</span>
            </div>

            <div style="border-top: 1px solid rgba(111,86,255,0.2); padding-top: 25px; margin-top: 10px; text-align: right;">
                <button type="submit" class="pill-btn glow-btn" style="background: linear-gradient(135deg, var(--primary, #6f56ff), #b58bff); padding: 15px 40px; font-size: 1.1em; border: none; cursor: pointer; display: inline-flex; align-items: center; gap: 8px;">
                    <span>🚀</span> Submit Secure Application
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
